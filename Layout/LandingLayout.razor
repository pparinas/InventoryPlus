@inherits LayoutComponentBase
@inject SettingsService AppSettings

<div class="landing-layout">
    <header class="landing-header">
        <div class="landing-brand">
            @if (!string.IsNullOrEmpty(AppSettings.CustomLogoUrl))
            {
                <img src="@AppSettings.CustomLogoUrl" style="height: 32px; width: auto; max-width: 120px; object-fit: contain;" alt="@AppSettings.CompanyName" />
            }
            else
            {
                <i class="fa-solid fa-cube"></i> @AppSettings.CompanyName
            }
        </div>
        <nav class="landing-nav">
            <a href="/">Home</a>
            <a href="/contact">Contact Us</a>
            <a href="/login" class="btn btn-primary btn-sm">Sign In / App</a>
        </nav>
    </header>
    
    <main class="landing-main">
        @Body
    </main>
    
    <footer class="landing-footer">
        <p>&copy; @DateTime.Now.Year @AppSettings.CompanyName. All rights reserved.</p>
    </footer>
</div>
