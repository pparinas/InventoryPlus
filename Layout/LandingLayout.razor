@inherits LayoutComponentBase
@inject SettingsService AppSettings
@inject IJSRuntime JSRuntime

<div class="landing">
    <nav class="land-nav">
        <a href="" class="land-logo">
            <div class="land-logo-mark"><span>N</span></div>
            negosyo<b>360</b>
        </a>
        <div class="land-spacer"></div>
        <div class="land-nav-links">
            <a class="land-nav-link hide-mobile" href="#features">Features</a>
            <a class="land-nav-link hide-mobile" href="#pricing">Pricing</a>
            <a class="land-nav-link hide-mobile" href="contact">Contact</a>
            <button class="topbar-btn" @onclick="ToggleTheme" @onclick:stopPropagation title="Toggle Theme">
                <i class="fa-solid @(isLightMode ? "fa-moon" : "fa-sun")"></i>
            </button>
            <a class="hero-cta-primary" href="login" style="padding:8px 16px;font-size:12px;">Sign In</a>
        </div>
    </nav>
    
    <main>
        @Body
    </main>
    
    <footer class="land-footer">
        &copy; @DateTime.Now.Year @AppSettings.CompanyName. All rights reserved.
    </footer>
</div>

@code {
    private bool showMobileMenu = false;
    private bool isLightMode = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Check if user has a saved preference, otherwise default to light
                var savedTheme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "theme");
                if (string.IsNullOrEmpty(savedTheme))
                {
                    // No saved preference — default landing page to light mode
                    isLightMode = true;
                    await JSRuntime.InvokeVoidAsync("themeInterop.toggle", true);
                }
                else
                {
                    isLightMode = await JSRuntime.InvokeAsync<bool>("themeInterop.isLight");
                }
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ToggleTheme()
    {
        isLightMode = !isLightMode;
        await JSRuntime.InvokeVoidAsync("themeInterop.toggle", isLightMode);
    }
}
