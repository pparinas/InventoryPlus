@inherits LayoutComponentBase

<div class="app-container" @onclick="HandleGlobalClick" @onkeydown="HandleKeyDown" tabindex="0">
    <header class="top-nav">
        <div class="d-flex align-items-center gap-2">
            <div class="d-flex align-items-center gap-2 fw-bold" style="color: var(--brand-color); flex-shrink: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">
                @if (AppSettings.UseLogoForBranding && !string.IsNullOrEmpty(AppSettings.CustomLogoUrl))
                {
                    <img src="@AppSettings.CustomLogoUrl" style="height: 32px; width: auto; max-width: 120px; object-fit: contain;" alt="@AppSettings.CompanyName" />
                }
                else
                {
                    <i class="fa-solid fa-cube" style="color: var(--accent);"></i>
                    <span style="font-size: 1.2rem;">@AppSettings.CompanyName</span>
                }
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" @onclick="ToggleTheme" @onclick:stopPropagation style="width: 36px; height: 36px; padding: 0;" title="Toggle Dark/Light Mode">
                @if (isLightMode) { <i class="fa-solid fa-moon"></i> } else { <i class="fa-solid fa-sun"></i> }
            </button>
            <button class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1" @onclick="LeaveSession" style="border-radius: 50px; padding: 0.5rem 1rem;">
                <i class="fa-solid fa-right-from-bracket"></i> <span class="d-none d-sm-inline">Leave</span>
            </button>
        </div>
    </header>

    @* ── Pilot Banner ── *@
    <div style="background: var(--primary); color: white; text-align: center; padding: 0.35rem 1rem; font-size: 0.8rem; font-weight: 500;">
        <i class="fa-solid fa-tower-broadcast me-1"></i>
        Pilot Mode — Operating as <strong>@PilotService.OperatorName</strong> for @AppSettings.CompanyName
    </div>

    @if (!PilotService.IsSessionStillActive())
    {
        <div style="background: var(--warning); color: #000; text-align: center; padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 600;">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>
            Session ended or expired. <a href="login" style="color: #000; text-decoration: underline;">Return to login</a>
        </div>
    }

    <main class="main-content" style="margin-left: 0; padding-bottom: 80px;">
        <ErrorBoundary @ref="errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="glass-panel text-center p-4" style="max-width: 500px; margin: 2rem auto;">
                    <i class="fa-solid fa-triangle-exclamation fa-3x mb-3" style="color: var(--warning);"></i>
                    <h3>Something went wrong</h3>
                    <p class="text-muted">An unexpected error occurred. Please try again.</p>
                    <button class="btn btn-primary" @onclick="ResetError"><i class="fa-solid fa-rotate-right me-1"></i> Try Again</button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    @* ── Mobile Bottom Bar (POS + Products only) ── *@
    <nav class="mobile-bottom-bar d-md-none">
        <a href="sales" class="bottom-bar-item @(IsActive("sales") ? "active" : "")">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>POS</span>
        </a>
        <a href="products" class="bottom-bar-item @(IsActive("products") ? "active" : "")">
            <i class="fa-solid fa-leaf"></i>
            <span>Products</span>
        </a>
    </nav>

    <ToastContainer />
</div>
