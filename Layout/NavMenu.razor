<nav>
    @if (AppSettings.IsPosMode)
    {
        @* ── POS Mode: minimal nav ── *@
        <div class="nav-section-title">
            <i class="fa-solid fa-cash-register fa-fw" style="color: var(--primary);"></i> POS Mode
        </div>

        <button class="nav-item @(AppSettings.PosActiveView == "pos" ? "active" : "")" style="border: none; background: none; cursor: pointer; width: 100%; text-align: left; color: inherit;" @onclick="SetViewPos">
            <i class="fa-solid fa-cash-register fa-fw"></i>
            <span>Point of Sale</span>
        </button>

        <button class="nav-item @(AppSettings.PosActiveView == "history" ? "active" : "")" style="border: none; background: none; cursor: pointer; width: 100%; text-align: left; color: inherit;" @onclick="SetViewHistory">
            <i class="fa-solid fa-clock-rotate-left fa-fw"></i>
            <span>Sales History</span>
        </button>

        <div style="flex: 1"></div>
    }
    else
    {
        @* ── Normal navigation ── *@
        <NavLink class="nav-item" href="dashboard" Match="NavLinkMatch.All">
            <i class="fa-solid fa-chart-line fa-fw"></i>
            <span>Dashboard</span>
        </NavLink>
        
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-section-title">
                    Administration
                </div>
                <NavLink class="nav-item" href="admin">
                    <i class="fa-solid fa-shield-halved fa-fw"></i>
                    <span>Admin Settings</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        
        @if (AppSettings.ShowInventoryTab)
        {
        <div class="nav-section-title">
            Inventory
        </div>

        <NavLink class="nav-item" href="stocks">
            <i class="fa-solid fa-boxes-stacked fa-fw"></i>
            <span>Inventory</span>
        </NavLink>
        }
        
        <NavLink class="nav-item" href="products">
            <i class="fa-solid fa-leaf fa-fw"></i>
            <span>Products</span>
        </NavLink>
        
        @if (AppSettings.ShowOpexTab)
        {
        <NavLink class="nav-item" href="expenses">
            <i class="fa-solid fa-file-invoice-dollar fa-fw"></i>
            <span>OPEX</span>
        </NavLink>
        }

        <div class="nav-section-title">
            Business
        </div>
        
        <NavLink class="nav-item" href="sales">
            <i class="fa-solid fa-cash-register fa-fw"></i>
            <span>Point of Sale</span>
        </NavLink>
        
        <NavLink class="nav-item" href="reports">
            <i class="fa-solid fa-file-invoice-dollar fa-fw"></i>
            <span>Reports</span>
        </NavLink>

        <NavLink class="nav-item" href="settings">
            <i class="fa-solid fa-gear fa-fw"></i>
            <span>Settings</span>
        </NavLink>
        
        <div style="flex: 1"></div>
    }
</nav>
