<AppModal IsOpen="IsVisible" IsOpenChanged="@(async (v) => { if (!v) await Cancel(); })" Size="Small" HasCloseButton="false">
    <Content>
        <div style="text-align:center;padding:8px 0">
            <i class="@Icon" style="font-size:28px;color:var(--red);margin-bottom:10px;display:block"></i>
            <h3 style="margin-bottom:6px;font-size:14px">@Title</h3>
            <p style="color:var(--fg2);font-size:12px;margin-bottom:0">@Message</p>
        </div>
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="Cancel">@CancelText</button>
        <button class="btn @ConfirmButtonClass" @onclick="Confirm">@ConfirmText</button>
    </Footer>
</AppModal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Are you sure?";
    [Parameter] public string Message { get; set; } = "This action cannot be undone.";
    [Parameter] public string Icon { get; set; } = "fa-solid fa-triangle-exclamation";
    [Parameter] public string IconClass { get; set; } = "text-warning";
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string ConfirmButtonClass { get; set; } = "btn-danger";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
