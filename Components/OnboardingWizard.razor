@inject InventoryPlus.Services.InventoryService Inventory
@inject InventoryPlus.Services.SettingsService AppSettings
@inject InventoryPlus.Services.ToastService Toast
@inject Supabase.Client SupabaseClient
@inject NavigationManager Nav

<AppModal IsOpen="IsVisible" Size="Large" IsStaticBackdrop="true" HasCloseButton="false">
    <Content>
        <div class="onboarding-container">
            <div class="onboarding-progress">
                @for (int i = 0; i < totalSteps; i++)
                {
                    var idx = i;
                    <div class="onboarding-dot @(idx == step ? "active" : "") @(idx < step ? "completed" : "")"></div>
                }
            </div>

            @switch (step)
            {
                case 0:
                    <div class="onboarding-step">
                        <div class="onboarding-icon"><i class="fa-solid fa-rocket"></i></div>
                        <h2>Welcome to @AppSettings.CompanyName!</h2>
                        <p class="text-muted">Let's set up your business in just a few steps. This will only take a minute.</p>
                        <div class="onboarding-actions">
                            <button class="btn btn-primary btn-lg" @onclick="NextStep"><i class="fa-solid fa-arrow-right"></i> Let's Go!</button>
                            <button class="btn btn-ghost btn-sm" @onclick="SkipOnboarding">Skip setup</button>
                        </div>
                    </div>
                    break;

                case 1:
                    <div class="onboarding-step">
                        <div class="onboarding-icon"><i class="fa-solid fa-store"></i></div>
                        <h2>Name Your Business</h2>
                        <p class="text-muted">What's your business called? This will appear throughout the app.</p>
                        <div class="mb-3" style="max-width: 400px; margin: 0 auto;">
                            <input type="text" @bind="businessName" placeholder="e.g. Maria's Cafe" class="text-center" style="font-size: 1.1rem;" />
                        </div>
                        <div class="onboarding-actions">
                            <button class="btn btn-ghost" @onclick="PrevStep"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" @onclick="SaveBusinessName" disabled="@string.IsNullOrWhiteSpace(businessName)">Continue <i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </div>
                    break;

                case 2:
                    <div class="onboarding-step">
                        <div class="onboarding-icon"><i class="fa-solid fa-sliders"></i></div>
                        <h2>Configure Your Modules</h2>
                        <p class="text-muted">Choose which features to enable. You can change these anytime in Settings.</p>
                        <div style="max-width: 420px; margin: 0 auto;">
                            <div class="card card-p p-3 mb-3">
                                <label class="toggle-row mb-2" style="cursor: pointer;">
                                    <input type="checkbox" @bind="enableInventory" />
                                    <span><i class="fa-solid fa-boxes-stacked me-2" style="color: var(--primary);"></i><strong>Inventory / Stock Tracking</strong></span>
                                </label>
                                <p class="text-muted text-sm mb-0 ms-4">Track raw materials, ingredients, and stock levels separately from products. Uncheck to add stock items directly as products.</p>
                            </div>
                            <div class="card card-p p-3 mb-3">
                                <label class="toggle-row mb-2" style="cursor: pointer;">
                                    <input type="checkbox" @bind="enableOpex" />
                                    <span><i class="fa-solid fa-file-invoice-dollar me-2" style="color: var(--warning);"></i><strong>OPEX (Operating Expenses)</strong></span>
                                </label>
                                <p class="text-muted text-sm mb-0 ms-4">Track rent, utilities, salaries, and other recurring business expenses for accurate profit calculations.</p>
                            </div>
                        </div>
                        <div class="onboarding-actions">
                            <button class="btn btn-ghost" @onclick="PrevStep"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" @onclick="SaveModulePreferences">Continue <i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </div>
                    break;

                case 3:
                    <div class="onboarding-step">
                        <div class="onboarding-icon"><i class="fa-solid fa-tag"></i></div>
                        <h2>Create Your First Product</h2>
                        <p class="text-muted">Products are what you sell. Set a name and price to create one.</p>
                        <div style="max-width: 400px; margin: 0 auto;">
                            <div class="mb-3">
                                <label class="form-label">Product Name</label>
                                <input type="text" class="form-control" @bind="productName" placeholder="e.g. Iced Coffee, T-Shirt" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Selling Price (₱)</label>
                                <input type="number" class="form-control" step="0.01" @bind="productPrice" />
                            </div>
                            @if (!enableInventory)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Starting Stock</label>
                                    <input type="number" class="form-control" step="1" @bind="productStockQty" />
                                </div>
                            }
                        </div>
                        <div class="onboarding-actions">
                            <button class="btn btn-ghost" @onclick="PrevStep"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" @onclick="SaveProduct" disabled="@(string.IsNullOrWhiteSpace(productName) || isSaving)">
                                @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> } Add & Continue <i class="fa-solid fa-arrow-right"></i>
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="NextStep">Skip this step</button>
                        </div>
                    </div>
                    break;

                case 4:
                    @if (enableInventory)
                    {
                    <div class="onboarding-step">
                        <div class="onboarding-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
                        <h2>Add Your First Stock Item</h2>
                        <p class="text-muted">Stock items are your raw materials or ingredients. Products can be linked to these later.</p>
                        <div style="max-width: 400px; margin: 0 auto;">
                            <div class="mb-3">
                                <label class="form-label">Item Name</label>
                                <input type="text" class="form-control" @bind="stockName" placeholder="e.g. Coffee Beans, Paper Cups" />
                            </div>
                            <div class="row g-3">
                                <div class="col-4">
                                    <label class="form-label">Unit</label>
                                    <input type="text" class="form-control" @bind="stockUnit" placeholder="e.g. kg" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label">Stock</label>
                                    <input type="number" class="form-control" step="0.1" @bind="stockQty" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label">Cost/Unit (₱)</label>
                                    <input type="number" class="form-control" step="0.01" @bind="stockCost" />
                                </div>
                            </div>
                        </div>
                        <div class="onboarding-actions">
                            <button class="btn btn-ghost" @onclick="PrevStep"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" @onclick="SaveStock" disabled="@(string.IsNullOrWhiteSpace(stockName) || isSaving)">
                                @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> } Add & Continue <i class="fa-solid fa-arrow-right"></i>
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="NextStep">Skip this step</button>
                        </div>
                    </div>
                    }
                    else
                    {
                        @* Skip stock step when inventory is disabled — auto-advance *@
                        <div class="onboarding-step">
                            <div class="onboarding-icon"><i class="fa-solid fa-spinner fa-spin"></i></div>
                        </div>
                    }
                    break;

                case 5:
                    <div class="onboarding-step">
                        <div class="onboarding-icon text-success" style="font-size: 4rem;"><i class="fa-solid fa-circle-check"></i></div>
                        <h2>You're All Set!</h2>
                        <p class="text-muted">Your business is ready. Here's what you can do:</p>
                        <div class="onboarding-tips">
                            <div class="onboarding-tip"><i class="fa-solid fa-cash-register text-primary"></i> Use <strong>Point of Sale</strong> to record sales quickly</div>
                            <div class="onboarding-tip"><i class="fa-solid fa-leaf text-success"></i> Manage your <strong>Products</strong> catalog and pricing</div>
                            @if (enableInventory)
                            {
                                <div class="onboarding-tip"><i class="fa-solid fa-boxes-stacked" style="color: var(--primary);"></i> Track <strong>Inventory</strong> and get low-stock alerts</div>
                            }
                            @if (enableOpex)
                            {
                                <div class="onboarding-tip"><i class="fa-solid fa-file-invoice-dollar" style="color: var(--warning);"></i> Log <strong>Operating Expenses</strong> for profit tracking</div>
                            }
                            <div class="onboarding-tip"><i class="fa-solid fa-chart-line text-success"></i> Check <strong>Reports</strong> for business analytics</div>
                            <div class="onboarding-tip"><i class="fa-solid fa-gear text-muted"></i> Customize everything in <strong>Settings</strong></div>
                        </div>
                        <div class="onboarding-actions">
                            <button class="btn btn-primary btn-lg" @onclick="CompleteOnboarding"><i class="fa-solid fa-chart-line"></i> Go to Dashboard</button>
                        </div>
                    </div>
                    break;
            }
        </div>
    </Content>
</AppModal>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnComplete { get; set; }

    private int step = 0;
    private int totalSteps = 6;
    private bool isSaving = false;

    // Step 1 — Business name
    private string businessName = "My Business";

    // Step 2 — Module toggles
    private bool enableInventory = true;
    private bool enableOpex = false;

    // Step 3 — Product
    private string productName = "";
    private double productPrice = 0;
    private double productStockQty = 10;

    // Step 4 — Stock item (only if inventory enabled)
    private string stockName = "";
    private string stockUnit = "pcs";
    private double stockQty = 10;
    private double stockCost = 0;

    private void NextStep()
    {
        step++;
        // Auto-skip stock step if inventory is disabled
        if (step == 4 && !enableInventory)
            step++;
    }

    private void PrevStep()
    {
        if (step > 0) step--;
        // Auto-skip stock step backwards
        if (step == 4 && !enableInventory)
            step--;
    }

    private async Task SaveBusinessName()
    {
        AppSettings.CompanyName = businessName;
        var user = SupabaseClient.Auth.CurrentUser;
        if (user != null)
        {
            try { await AppSettings.SaveAsync(user.Id); } catch { }
        }
        NextStep();
    }

    private async Task SaveModulePreferences()
    {
        AppSettings.ShowInventoryTab = enableInventory;
        AppSettings.ShowOpexTab = enableOpex;
        var user = SupabaseClient.Auth.CurrentUser;
        if (user != null)
        {
            try { await AppSettings.SaveAsync(user.Id); } catch { }
        }
        NextStep();
    }

    private async Task SaveStock()
    {
        if (string.IsNullOrWhiteSpace(stockName)) return;
        isSaving = true;
        try
        {
            var ing = new InventoryPlus.Models.Ingredient
            {
                Name = stockName,
                Unit = stockUnit,
                Stock = stockQty,
                CostPerUnit = stockCost,
                Type = "Ingredient"
            };
            await Inventory.AddIngredientAsync(ing);
            Toast.Show($"\"{stockName}\" added to stock!");
            NextStep();
        }
        finally { isSaving = false; }
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(productName)) return;
        isSaving = true;
        try
        {
            var product = new InventoryPlus.Models.Product
            {
                Guid = Guid.NewGuid(),
                Name = productName,
                SellingPrice = productPrice,
                Category = "Other",
                HasIngredients = enableInventory
            };

            // When inventory is disabled, store stock directly on the product
            if (!enableInventory)
            {
                product.StockCount = productStockQty;
            }

            await Inventory.AddProductAsync(product);
            Toast.Show($"\"{productName}\" created!");
            NextStep();
        }
        finally { isSaving = false; }
    }

    private async Task SkipOnboarding() => await CompleteOnboarding();

    private async Task CompleteOnboarding()
    {
        AppSettings.OnboardingCompleted = true;
        var user = SupabaseClient.Auth.CurrentUser;
        if (user != null)
        {
            try { await AppSettings.SaveAsync(user.Id); } catch { }
        }
        await OnComplete.InvokeAsync();
    }
}
