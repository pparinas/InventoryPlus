@inject InventoryPlus.Services.SettingsService AppSettings
@inject InventoryPlus.Services.ToastService Toast
@inject NavigationManager Nav

@if (IsVisible)
{
<div class="modal-backdrop" @onclick="Cancel">
    <div class="modal-panel modal-sm" @onclick:stopPropagation>
        <div class="modal-header">
            <h3>@Title</h3>
        </div>
        <div class="modal-body" style="text-align:center">
            @if (!AppSettings.HasPin)
            {
                <div style="margin-bottom:12px">
                    <i class="fa-solid fa-lock" style="font-size:28px;color:var(--amber);margin-bottom:8px;display:block"></i>
                    <p style="color:var(--fg2);font-size:12px">You need to create a PIN first before performing this action.</p>
                </div>
                <button class="btn btn-primary" style="width:100%" @onclick="GoToSettings">
                    <i class="fa-solid fa-gear"></i> Go to Settings
                </button>
            }
            else
            {
                <p style="color:var(--fg2);font-size:12px;margin-bottom:12px">Enter your 4-digit PIN to continue.</p>
                <div style="display:flex;justify-content:center;gap:8px;margin-bottom:12px">
                    @for (int i = 0; i < 4; i++)
                    {
                        var idx = i;
                        <input type="password" maxlength="1" inputmode="numeric" pattern="[0-9]"
                               class="form-control"
                               style="width:48px;height:56px;font-size:1.5rem;text-align:center;font-weight:700;letter-spacing:0"
                               value="@(pinDigits.Length > idx ? pinDigits[idx].ToString() : "")"
                               @oninput="(e) => HandlePinInput(idx, e)"
                               @onkeydown="(e) => HandlePinKeyDown(idx, e)"
                               id="pin-digit-@idx" />
                    }
                </div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div style="color:var(--red);font-size:11px;margin-bottom:8px">@error</div>
                }
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" @onclick="Cancel">Cancel</button>
        </div>
    </div>
</div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EventCallback OnVerified { get; set; }
    [Parameter] public string Title { get; set; } = "PIN Required";

    private string pinDigits = "";
    private string error = "";

    private void HandlePinInput(int idx, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (val.Length > 0 && char.IsDigit(val[^1]))
        {
            // Build pin string
            var c = val[^1];
            if (idx < pinDigits.Length)
            {
                var arr = pinDigits.ToCharArray();
                arr[idx] = c;
                pinDigits = new string(arr);
            }
            else
            {
                pinDigits += c;
            }

            if (pinDigits.Length == 4)
            {
                VerifyPin();
            }
        }
    }

    private void HandlePinKeyDown(int idx, Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && idx > 0 && (idx >= pinDigits.Length || pinDigits.Length == 0))
        {
            if (pinDigits.Length > 0)
                pinDigits = pinDigits[..^1];
        }
    }

    private async void VerifyPin()
    {
        if (AppSettings.VerifyPin(pinDigits))
        {
            error = "";
            pinDigits = "";
            await IsVisibleChanged.InvokeAsync(false);
            await OnVerified.InvokeAsync();
        }
        else
        {
            error = "Incorrect PIN. Try again.";
            pinDigits = "";
        }
        StateHasChanged();
    }

    private async void Cancel()
    {
        pinDigits = "";
        error = "";
        await IsVisibleChanged.InvokeAsync(false);
    }

    private void GoToSettings()
    {
        Cancel();
        Nav.NavigateTo("settings");
    }
}
