@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@inject InventoryPlus.Services.PilotService PilotService
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@(PilotService.IsPilotMode ? typeof(Layout.PilotLayout) : typeof(MainLayout))">
                <Authorizing>
                    <div style="display:flex;justify-content:center;align-items:center;height:100vh;flex-direction:column;gap:1rem;">
                        <div class="loader-pulse"></div>
                        <div style="color:var(--text-secondary);font-size:1rem;">Authenticating...</div>
                    </div>
                </Authorizing>
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
