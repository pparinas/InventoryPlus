@page "/login"
@layout InventoryPlus.Layout.AuthLayout
@attribute [AllowAnonymous]


<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh; padding: 1.5rem;" @onkeydown="HandleKeyDown">
    <div class="card login-card p-4 p-sm-5 w-100" style="max-width: 450px; animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
        <div class="auth-brand">
            <i class="fa-solid fa-cube"></i>
        </div>
        <h2>Welcome Back</h2>
        <p class="text-muted text-center" style="margin-bottom: 1.5rem; margin-top: -0.5rem;">Sign in to @AppSettings.CompanyName</p>
        
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="mb-3">
            <label for="email" class="form-label small fw-medium text-muted">Email</label>
            <input id="email" type="email" @bind="Email" class="form-control" placeholder="you@example.com" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label small fw-medium text-muted">Password</label>
            <input id="password" type="password" @bind="Password" class="form-control" placeholder="Your password" />
        </div>

        <div class="form-check mb-3">
            <input id="rememberMe" type="checkbox" class="form-check-input" @bind="RememberMe" style="accent-color: var(--primary);" />
            <label for="rememberMe" class="form-check-label small text-muted">Remember me</label>
        </div>

        <button @onclick="HandleLogin" class="btn btn-primary w-100" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner"></span> <span>Signing in...</span>
            }
            else
            {
                <i class="fa-solid fa-right-to-bracket me-1"></i> <span>Sign In</span>
            }
        </button>

        <div class="d-flex align-items-center gap-3 my-3">
            <hr class="flex-grow-1" style="border-color: var(--border);" />
            <span class="text-muted small">or</span>
            <hr class="flex-grow-1" style="border-color: var(--border);" />
        </div>

        <button @onclick="HandleGuestMode" class="btn btn-outline-secondary w-100" disabled="@IsLoading">
            <i class="fa-solid fa-user-secret me-1"></i> Continue as Guest
        </button>
        <p class="text-center mt-2 small text-muted" style="font-size: 0.75rem;">
            <i class="fa-solid fa-circle-info me-1"></i> Guest data is stored locally on this device only
        </p>

        <div class="d-flex align-items-center gap-3 my-3">
            <hr class="flex-grow-1" style="border-color: var(--border);" />
            <span class="text-muted small">or</span>
            <hr class="flex-grow-1" style="border-color: var(--border);" />
        </div>

        @if (!showPilotJoin)
        {
            <button @onclick="() => showPilotJoin = true" class="btn btn-outline-primary w-100">
                <i class="fa-solid fa-tower-broadcast me-1"></i> Join as Operator
            </button>
        }
        else
        {
            <div class="p-3 rounded-3" style="background: var(--bg-surface); border: 1px solid var(--border);">
                <h6 class="mb-2"><i class="fa-solid fa-tower-broadcast me-1" style="color: var(--primary);"></i> Pilot Mode</h6>
                <div class="mb-2">
                    <input type="text" class="form-control form-control-sm" @bind="pilotCode" maxlength="6" inputmode="numeric" placeholder="6-digit access code" />
                </div>
                <div class="mb-2">
                    <input type="text" class="form-control form-control-sm" @bind="pilotName" placeholder="Your name" />
                </div>
                @if (!string.IsNullOrEmpty(pilotError))
                {
                    <div class="alert alert-danger py-1 small mb-2">@pilotError</div>
                }
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm flex-grow-1" @onclick="HandlePilotJoin" disabled="@IsPilotJoining">
                        @if (IsPilotJoining) { <i class="fa-solid fa-spinner fa-spin me-1"></i> } <span>Connect</span>
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { showPilotJoin = false; pilotError = string.Empty; }">Cancel</button>
                </div>
            </div>
        }
        
        <div class="text-center mt-3 small text-muted">
            <p>Don't have an account? <a href="contact" class="fw-semibold text-decoration-none" style="color: var(--primary);">Contact us to subscribe</a></p>
            <p><a href="/InventoryPlus" class="text-decoration-none" style="color: var(--primary);">Back to home</a></p>
        </div>
    </div>
</div>

