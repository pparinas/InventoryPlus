@page "/login"
@layout InventoryPlus.Layout.AuthLayout
@attribute [AllowAnonymous]


<div class="login-container" @onkeydown="HandleKeyDown">
    <div class="login-card">
        <div class="auth-brand">
            <i class="fa-solid fa-cube"></i>
        </div>
        <h2>Welcome Back</h2>
        <p class="text-muted" style="margin-bottom: 1.5rem; margin-top: -0.5rem;">Sign in to @AppSettings.CompanyName</p>
        
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-error">@ErrorMessage</div>
        }

        <div class="form-group">
            <label for="email">Email</label>
            <input id="email" type="email" @bind="Email" class="form-control" placeholder="you@example.com" />
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input id="password" type="password" @bind="Password" class="form-control" placeholder="Your password" />
        </div>

        <div class="form-check">
            <input id="rememberMe" type="checkbox" @bind="RememberMe" />
            <label for="rememberMe">Remember me</label>
        </div>

        <button @onclick="HandleLogin" class="btn btn-primary w-full" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner"></span> <span>Signing in...</span>
            }
            else
            {
                <i class="fa-solid fa-right-to-bracket"></i> <span>Sign In</span>
            }
        </button>
        
        <div class="login-links">
            <p>Don't have an account? <a href="register">Create one</a></p>
            <p><a href="/">Back to home</a></p>
        </div>
    </div>
</div>

