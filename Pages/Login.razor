@page "/login"
@layout InventoryPlus.Layout.AuthLayout
@attribute [AllowAnonymous]


<div class="auth-wrap" @onkeydown="HandleKeyDown">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="mark"><span>N</span></div>
            <h2>Welcome Back</h2>
            <p>Sign in to @AppSettings.CompanyName</p>
        </div>
        
        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success"><i class="fa-solid fa-circle-check me-1"></i> @SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="mb-3">
            <label for="email" class="form-label small fw-medium text-muted">Email or Username</label>
            <input id="email" type="text" @bind="Email" @bind:event="oninput" class="form-control" placeholder="you@example.com or username" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label small fw-medium text-muted">Password</label>
            <input id="password" type="password" @bind="Password" @bind:event="oninput" class="form-control" placeholder="Your password" />
        </div>

        <div class="form-check mb-3">
            <input id="rememberMe" type="checkbox" class="form-check-input" @bind="RememberMe" style="accent-color: var(--primary);" />
            <label for="rememberMe" class="form-check-label small text-muted">Remember me</label>
        </div>

        <button @onclick="HandleLogin" class="btn btn-primary w-100" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner"></span> <span>Signing in...</span>
            }
            else
            {
                <i class="fa-solid fa-right-to-bracket me-1"></i> <span>Sign In</span>
            }
        </button>

        <div class="text-center mt-3" style="font-size:12px;color:var(--fg3);">
            <p>Don't have an account? <a href="register" class="auth-link">Create a free account</a></p>
            <p><a href="/" class="auth-link">Back to home</a></p>
        </div>
    </div>
</div>

