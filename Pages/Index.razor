@page "/"
@layout InventoryPlus.Layout.LandingLayout
@inject SettingsService AppSettings
@inject IJSRuntime JSRuntime
@attribute [AllowAnonymous]

<PageTitle>@AppSettings.CompanyName - Smart Inventory & POS for Small Businesses</PageTitle>

<!-- HERO -->
<section class="hero-section">
    <div>
        <div class="hero-badge"><i class="fa-solid fa-bolt"></i> Trusted by growing businesses</div>
        <h1 class="hero-title">Run Your Business<br/><span class="text-gradient">Smarter, Not Harder</span></h1>
        <p class="hero-subtitle">All-in-one inventory management and point of sale system. Track stock, record sales, and get real-time insights — from any device.</p>
        <div class="d-flex flex-column flex-sm-row gap-2 mb-3">
            <a href="login" class="btn btn-primary btn-lg"><i class="fa-solid fa-rocket me-1"></i> Try It Now — No Sign Up</a>
            <a href="#features" class="btn btn-outline-secondary btn-lg"><i class="fa-solid fa-play me-1"></i> See How It Works</a>
        </div>
        <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center gap-2 gap-sm-3 flex-wrap small text-muted">
            <span><i class="fa-solid fa-circle-check" style="color: var(--success);"></i> Instant guest access</span>
            <span><i class="fa-solid fa-circle-check" style="color: var(--success);"></i> No account needed to explore</span>
            <span><i class="fa-solid fa-circle-check" style="color: var(--success);"></i> Works on any device</span>
        </div>
    </div>
    <div class="d-none d-md-block" style="flex: 1; max-width: 480px;">
        <div class="hero-mockup glass-panel">
            <div class="mockup-header">
                <div class="dot red"></div><div class="dot yellow"></div><div class="dot green"></div>
                <span class="text-muted ms-auto" style="font-size: 0.7rem;">Dashboard</span>
            </div>
            <div class="mockup-stats-row">
                <div class="mockup-stat-card">
                    <div class="mockup-stat-num" style="color: var(--success);">₱12,450</div>
                    <div class="mockup-stat-label">Revenue</div>
                </div>
                <div class="mockup-stat-card">
                    <div class="mockup-stat-num" style="color: var(--primary);">48</div>
                    <div class="mockup-stat-label">Sales Today</div>
                </div>
            </div>
            <div class="mockup-chart-bars">
                <div class="mockup-bar" style="height: 40%"></div>
                <div class="mockup-bar" style="height: 65%"></div>
                <div class="mockup-bar" style="height: 50%"></div>
                <div class="mockup-bar" style="height: 85%"></div>
                <div class="mockup-bar" style="height: 60%"></div>
                <div class="mockup-bar" style="height: 75%"></div>
                <div class="mockup-bar" style="height: 45%"></div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="py-5" id="how-it-works">
    <div class="container text-center" style="max-width: 900px;">
        <h2 class="mb-1">Up and Running in 3 Steps</h2>
        <p class="text-muted mb-4">No complex setup. No training required.</p>
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="step-number">1</div>
                <h5 class="fw-semibold">Add Your Inventory</h5>
                <p class="text-muted small">Enter your raw materials, ingredients, or products with costs and quantities.</p>
            </div>
            <div class="col-12 col-md-4">
                <div class="step-number">2</div>
                <h5 class="fw-semibold">Configure Products</h5>
                <p class="text-muted small">Create sellable products with pricing, tax rates, and ingredient recipes.</p>
            </div>
            <div class="col-12 col-md-4">
                <div class="step-number">3</div>
                <h5 class="fw-semibold">Start Selling</h5>
                <p class="text-muted small">Use the POS to record sales. Stock auto-deducts and reports update instantly.</p>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section id="features" class="py-5">
    <div class="container text-center" style="max-width: 1000px;">
        <h2 class="mb-1">Everything Your Business Needs</h2>
        <p class="text-muted mb-4">Powerful tools in one seamless, mobile-friendly experience.</p>
        <div class="row g-3">
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(99,102,241,0.1); color: var(--primary);"><i class="fa-solid fa-boxes-stacked"></i></div>
                    <h5 class="fw-semibold">Smart Inventory</h5>
                    <p class="text-muted small mb-0">Track ingredients, raw materials, and supplies with automatic stock deduction when sales are made.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(236,72,153,0.1); color: var(--accent);"><i class="fa-solid fa-cash-register"></i></div>
                    <h5 class="fw-semibold">Point of Sale</h5>
                    <p class="text-muted small mb-0">Fast, touch-friendly POS with search, categories, discounts, and instant receipt generation.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(16,185,129,0.1); color: var(--success);"><i class="fa-solid fa-chart-pie"></i></div>
                    <h5 class="fw-semibold">Business Reports</h5>
                    <p class="text-muted small mb-0">Sales summaries, profit & loss, top products, payment breakdowns — edit or void sales with PIN protection.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(245,158,11,0.1); color: var(--warning);"><i class="fa-solid fa-bell"></i></div>
                    <h5 class="fw-semibold">Low Stock Alerts</h5>
                    <p class="text-muted small mb-0">Get notified instantly when ingredients run low so you never miss a sale.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(99,102,241,0.1); color: var(--primary);"><i class="fa-solid fa-receipt"></i></div>
                    <h5 class="fw-semibold">Receipt Printing</h5>
                    <p class="text-muted small mb-0">Generate professional receipts after every sale — print or share digitally.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(236,72,153,0.1); color: var(--accent);"><i class="fa-solid fa-palette"></i></div>
                    <h5 class="fw-semibold">Themes & Color Schemes</h5>
                    <p class="text-muted small mb-0">Dark & light modes plus 6 accent color schemes — each account gets their own personalized look.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(239,68,68,0.1); color: var(--danger);"><i class="fa-solid fa-shield-halved"></i></div>
                    <h5 class="fw-semibold">PIN Security</h5>
                    <p class="text-muted small mb-0">Protect sensitive actions like adding products, editing stock, and voiding sales with a 4-digit PIN.</p>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="glass-panel text-start h-100">
                    <div class="feature-icon" style="background: rgba(16,185,129,0.1); color: var(--success);"><i class="fa-solid fa-sliders"></i></div>
                    <h5 class="fw-semibold">Flexible Products</h5>
                    <p class="text-muted small mb-0">Products with ingredient recipes or simple stock counts — toggle per product to fit any business model.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PRICING -->
<section id="pricing" class="py-5">
    <div class="container text-center" style="max-width: 800px;">
        <h2 class="mb-1">Simple, Transparent Pricing</h2>
        <p class="text-muted mb-4">Try the full app instantly with <strong style="color: var(--success);">Guest Mode</strong> — no sign-up needed. Subscribe when you're ready.</p>
        <div class="row g-4">
            <div class="col-12 col-sm-6">
                <div class="glass-panel h-100 text-start">
                    <h6 class="text-uppercase small fw-bold" style="letter-spacing: 0.1em; color: var(--text-secondary);">Monthly</h6>
                    <div class="fs-1 fw-bold mb-2" style="color: var(--text-primary); -webkit-text-fill-color: unset; background: none;">₱199<small class="fs-6 fw-normal text-muted">/mo</small></div>
                    <ul class="list-unstyled mb-3">
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Full Inventory Management</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Unlimited Products & Sales</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Point of Sale System</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Basic Reports & Analytics</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Receipt Generation</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Dark/Light Mode & Color Schemes</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>PIN Security</li>
                    </ul>
                    <a href="contact" class="btn btn-outline-secondary w-100">Subscribe Monthly</a>
                </div>
            </div>
            <div class="col-12 col-sm-6">
                <div class="glass-panel h-100 text-start position-relative" style="border-color: var(--primary);">
                    <div class="popular-badge">Best Value</div>
                    <h6 class="text-uppercase small fw-bold mt-2" style="letter-spacing: 0.1em; color: var(--text-secondary);">Annual</h6>
                    <div class="fs-1 fw-bold mb-1" style="color: var(--text-primary); -webkit-text-fill-color: unset; background: none;">₱1,990<small class="fs-6 fw-normal text-muted">/yr</small></div>
                    <div class="small fw-semibold mb-2" style="color: var(--success);">Save ₱398 (2 months free!)</div>
                    <ul class="list-unstyled mb-3">
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Everything in Monthly</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Advanced Reports & CSV Export</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Dashboard Customization</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Sale Edit & Void with PIN</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Priority Support</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Multi-device Sync</li>
                        <li class="mb-2 small"><i class="fa-solid fa-check me-2" style="color: var(--success);"></i>Onboarding Wizard</li>
                    </ul>
                    <a href="contact" class="btn btn-primary w-100">Get Best Value</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-5" id="faq">
    <div class="container" style="max-width: 800px;">
        <h2 class="text-center mb-4">Frequently Asked Questions</h2>
        <div class="accordion" id="faqAccordion">
            @for (int i = 0; i < faqs.Count; i++)
            {
                var faq = faqs[i];
                var collapseId = $"faq-{i}";
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(faq.Open ? "" : "collapsed")" type="button" @onclick="() => faq.Open = !faq.Open">
                            @faq.Question
                        </button>
                    </h2>
                    @if (faq.Open)
                    {
                        <div class="accordion-collapse collapse show">
                            <div class="accordion-body text-muted">@faq.Answer</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5">
    <div class="container" style="max-width: 600px;">
        <div class="glass-panel text-center p-4 p-md-5" style="background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(236,72,153,0.08)); border: 1px solid rgba(99,102,241,0.2);">
            <h2>Ready to streamline your business?</h2>
            <p class="text-muted">Explore the full app instantly in Guest Mode — no sign-up required. Your data stays on your device until you subscribe.</p>
            <a href="login" class="btn btn-primary btn-lg mt-3"><i class="fa-solid fa-user-secret me-1"></i> Try Guest Mode</a>

            @if (showInstallSection && !isStandalone)
            {
                <hr class="my-4" style="border-color: rgba(99,102,241,0.2);">
                @if (canInstallNative)
                {
                    <button class="btn btn-outline-primary mt-2" @onclick="InstallApp"><i class="fa-solid fa-download me-1"></i> Install App</button>
                }
                else if (isIos)
                {
                    <div class="mt-2">
                        <p class="text-muted small mb-2"><i class="fa-solid fa-mobile-screen-button me-1"></i> Install on your iPhone or iPad:</p>
                        <p class="small mb-0">Tap <i class="fa-solid fa-arrow-up-from-bracket" style="color: var(--primary);"></i> <strong>Share</strong>, then <strong>Add to Home Screen</strong></p>
                    </div>
                }
            }
        </div>
    </div>
</section>

@code {
    private bool showInstallSection = false;
    private bool canInstallNative = false;
    private bool isIos = false;
    private bool isStandalone = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                isStandalone = await JSRuntime.InvokeAsync<bool>("pwaInstall.isStandalone");
                if (!isStandalone)
                {
                    canInstallNative = await JSRuntime.InvokeAsync<bool>("pwaInstall.canInstall");
                    isIos = await JSRuntime.InvokeAsync<bool>("pwaInstall.isIos");
                    showInstallSection = canInstallNative || isIos;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task InstallApp()
    {
        await JSRuntime.InvokeAsync<bool>("pwaInstall.prompt");
        canInstallNative = false;
        showInstallSection = isIos;
        StateHasChanged();
    }

    private class FaqItem { public string Question { get; set; } = ""; public string Answer { get; set; } = ""; public bool Open { get; set; } }
    
    private List<FaqItem> faqs = new()
    {
        new() { Question = "How can I try the app?", Answer = "You can explore the full app instantly using Guest Mode — no sign-up required. Your data is stored locally on your device until you subscribe." },
        new() { Question = "Can I use this on my phone?", Answer = "Absolutely. InventoryPlus is a mobile-first web app that works beautifully on phones, tablets, and desktops." },
        new() { Question = "How does stock deduction work?", Answer = "When you make a sale through the POS, ingredient stocks are automatically reduced based on your product recipes. No manual tracking needed." },
        new() { Question = "Can I customize my dashboard?", Answer = "Yes! You can toggle dashboard widgets on/off in Settings to show only the reports that matter to your business." },
        new() { Question = "What payment methods are supported?", Answer = "The POS supports Cash and GCash payment tracking. We're working on adding more payment methods." },
        new() { Question = "Is my data secure?", Answer = "Yes. We use Supabase for authentication and data storage with row-level security, HTTPS encryption, and secure token management." }
    };
}
