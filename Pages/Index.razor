@page "/"
@layout InventoryPlus.Layout.LandingLayout
@inject SettingsService AppSettings
@inject IJSRuntime JSRuntime
@attribute [AllowAnonymous]

<PageTitle>@AppSettings.CompanyName - Smart Inventory & POS for Small Businesses</PageTitle>

<!-- HERO -->
<section class="hero" style="padding-top:60px;padding-bottom:60px;">
    <div>
        <div class="hero-eyebrow">
            <span class="hero-eyebrow-dot"></span>
            Now free for every Filipino business
        </div>
        <h1>
            The counter,<br/>
            <span class="hl">operating.</span>
        </h1>
        <p class="hero-desc">POS, inventory, and reports for sari-sari stores, carinderias, and barbershops — free to start. Upgrade to <strong>Pro</strong> for POS mode, PIN security, full historical reports, and more.</p>
        <div class="hero-ctas">
            <a href="register" class="hero-cta-primary">Create your store · free <i class="fa-solid fa-arrow-right"></i></a>
            <a href="#features" class="hero-cta-secondary">See Pro features</a>
        </div>
        <div class="hero-checks">
            <span class="hero-check"><i class="fa-solid fa-check"></i> Free to start</span>
            <span class="hero-check"><i class="fa-solid fa-check"></i> Works offline</span>
            <span class="hero-check"><i class="fa-solid fa-check"></i> No card required</span>
        </div>
    </div>
    <div>
        <div class="hero-mockup">
            <div class="mockup-topbar">
                <span class="mockup-badge">Live</span>
                <span class="mockup-badge-gray">Counter</span>
                <span class="mockup-time">14:42:08</span>
            </div>
            <div class="mockup-revenue">₱8,420</div>
            <div style="display:flex;gap:8px;margin-bottom:12px;">
                <span class="mockup-badge" style="font-family:'Space Mono',monospace;">↑ 18% vs yesterday</span>
                <span class="mockup-badge-gray" style="font-family:'Space Mono',monospace;">42 sales today</span>
            </div>
            <div class="mockup-stats-row">
                <div class="mockup-mini-stat"><span class="mockup-mini-val">42</span><span class="mockup-mini-label">Sales</span></div>
                <div class="mockup-mini-stat"><span class="mockup-mini-val">₱200</span><span class="mockup-mini-label">Avg</span></div>
                <div class="mockup-mini-stat"><span class="mockup-mini-val">12</span><span class="mockup-mini-label">Low stock</span></div>
            </div>
            <div class="mockup-chart">
                <div class="mockup-bar" style="height:35%"></div>
                <div class="mockup-bar" style="height:55%"></div>
                <div class="mockup-bar" style="height:42%"></div>
                <div class="mockup-bar" style="height:70%"></div>
                <div class="mockup-bar" style="height:60%"></div>
                <div class="mockup-bar accent" style="height:88%"></div>
                <div class="mockup-bar" style="height:65%"></div>
            </div>
            <div class="mockup-sale-row">
                <div>
                    <div class="mockup-sale-label">Sale closed · 14:42</div>
                    <div class="mockup-sale-val">10 items · GCash · #1284</div>
                </div>
                <span class="mockup-badge" style="font-family:'Space Mono',monospace;">✓ PAID</span>
            </div>
        </div>
        <div style="margin-top:10px;font-size:10px;color:var(--land-fg3);text-align:center;letter-spacing:.05em;text-transform:uppercase;">What you get</div>
        <div style="margin-top:6px;text-align:center;">
            <span style="font-size:22px;font-weight:700;color:var(--land-fg);letter-spacing:-1px;display:block;">Free</span>
            <span style="font-size:13px;color:var(--land-fg2);">for the daily counter</span>
        </div>
    </div>
</section>

<style>
    @@media(max-width:900px){ .hero > div:last-child > .hero-mockup { display:none; } }
</style>

<!-- FEATURES -->
<section class="land-section" id="features">
    <div class="land-section-label">What's included</div>
    <h2>Everything your store needs</h2>
    <p class="sub">Powerful tools in one seamless, mobile-friendly experience.</p>
    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-card-icon fi-dark"><i class="fa-solid fa-boxes-stacked"></i></div>
            <h4>Smart Inventory</h4>
            <p>Auto-deduct ingredients when sales are made. Track stock in real time.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card-icon fi-lime"><i class="fa-solid fa-cash-register"></i></div>
            <h4>Point of Sale <span class="badge badge-lime">Pro</span></h4>
            <p>Dedicated counter-mode POS with search, categories, discounts, and receipts.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card-icon fi-gray"><i class="fa-solid fa-chart-pie"></i></div>
            <h4>Business Reports</h4>
            <p>Current month reports are free. Unlock full historical analytics with <strong>Pro</strong>.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card-icon fi-dark"><i class="fa-solid fa-bell"></i></div>
            <h4>Low Stock Alerts</h4>
            <p>Get notified instantly when ingredients run low.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card-icon fi-lime"><i class="fa-solid fa-receipt"></i></div>
            <h4>Receipt Printing</h4>
            <p>Generate professional receipts — print or share digitally.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card-icon fi-gray"><i class="fa-solid fa-shield-halved"></i></div>
            <h4>PIN Security <span class="badge badge-lime">Pro</span></h4>
            <p>Protect sensitive actions like voiding sales with a 4-digit PIN.</p>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="land-section" id="how-it-works" style="padding-top:0;">
    <div class="land-section-label">How it works</div>
    <h2>Up and running in 3 steps</h2>
    <p class="sub">No complex setup. No training required.</p>
    <div class="steps-grid">
        <div>
            <div class="step-num">1</div>
            <div class="step-title">Add Your Inventory</div>
            <div class="step-desc">Enter raw materials, ingredients, or products with costs and quantities.</div>
        </div>
        <div>
            <div class="step-num">2</div>
            <div class="step-title">Configure Products</div>
            <div class="step-desc">Create sellable products with pricing, tax rates, and ingredient recipes.</div>
        </div>
        <div>
            <div class="step-num">3</div>
            <div class="step-title">Start Selling</div>
            <div class="step-desc">Use the POS to record sales. Stock auto-deducts and reports update instantly.</div>
        </div>
    </div>
</section>

<!-- PRICING -->
<section class="land-section" id="pricing" style="padding-top:0;">
    <div class="land-section-label">Pricing</div>
    <h2>Start free, upgrade when ready.</h2>
    <p class="sub">No commitment. Upgrade to Pro when your business grows.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;max-width:740px;margin:0 auto;">
        <!-- Free Plan -->
        <div class="pricing-card" style="background:var(--land-card);color:var(--land-fg);border:1px solid var(--land-border);">
            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--land-fg3);margin-bottom:10px;">Free</div>
            <div class="pricing-price" style="color:var(--land-fg);">₱0<small> / forever</small></div>
            <div class="pricing-features">
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Inventory Management</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Unlimited Products</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Record Sales</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Current Month Reports</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Receipt Generation</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Low Stock Alerts</div>
                <div class="pricing-feature" style="color:var(--land-fg2);"><i class="fa-solid fa-check" style="color:var(--land-fg);"></i> Dark & Light Mode</div>
            </div>
            <a href="register" class="pricing-cta" style="background:var(--land-fg);color:var(--land-bg);">Get started · free</a>
        </div>
        <!-- Pro Plan -->
        <div class="pricing-card">
            <div class="pricing-badge">Pro</div>
            <div class="pricing-price">Pro<small> / monthly</small></div>
            <div class="pricing-features">
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> Everything in Free</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> POS Counter Mode</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> PIN Security</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> Full Historical Reports</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> Advanced Analytics + CSV</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> Dashboard Customization</div>
                <div class="pricing-feature"><i class="fa-solid fa-check"></i> Future Pro Features</div>
            </div>
            <a href="register" class="pricing-cta">Start free, upgrade later →</a>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="land-section" style="padding-top:0;">
    <div class="cta-section">
        <h2>Ready to streamline your business?</h2>
        <p>Create a free account in seconds. No strings attached.</p>
        <a href="register" class="pricing-cta" style="max-width:280px;display:inline-flex;align-items:center;gap:6px;justify-content:center;">
            <i class="fa-solid fa-store"></i> Create your store · free
        </a>

        @if (showInstallSection && !isStandalone)
        {
            <hr style="border-color:rgba(200,240,0,.2);margin:20px 0;">
            @if (canInstallNative)
            {
                <button class="btn btn-ghost" @onclick="InstallApp"><i class="fa-solid fa-download"></i> Install App</button>
            }
            else if (isIos)
            {
                <p style="font-size:12px;opacity:.6;margin-top:10px;"><i class="fa-solid fa-mobile-screen-button"></i> Tap Share → Add to Home Screen</p>
            }
        }
    </div>
</section>

@code {
    private bool showInstallSection = false;
    private bool canInstallNative = false;
    private bool isIos = false;
    private bool isStandalone = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                isStandalone = await JSRuntime.InvokeAsync<bool>("pwaInstall.isStandalone");
                if (!isStandalone)
                {
                    canInstallNative = await JSRuntime.InvokeAsync<bool>("pwaInstall.canInstall");
                    isIos = await JSRuntime.InvokeAsync<bool>("pwaInstall.isIos");
                    showInstallSection = canInstallNative || isIos;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task InstallApp()
    {
        await JSRuntime.InvokeAsync<bool>("pwaInstall.prompt");
        canInstallNative = false;
        showInstallSection = isIos;
        StateHasChanged();
    }

    private class FaqItem { public string Question { get; set; } = ""; public string Answer { get; set; } = ""; public bool Open { get; set; } }
    
    private List<FaqItem> faqs = new()
    {
        new() { Question = "How can I try the app?", Answer = "Simply create a free account — no credit card required. You'll get full access to all features immediately." },
        new() { Question = "Can I use this on my phone?", Answer = "Absolutely. Negosyo360 is a mobile-first web app that works beautifully on phones, tablets, and desktops." },
        new() { Question = "How does stock deduction work?", Answer = "When you make a sale through the POS, ingredient stocks are automatically reduced based on your product recipes. No manual tracking needed." },
        new() { Question = "Can I customize my dashboard?", Answer = "Yes! You can toggle dashboard widgets on/off in Settings to show only the reports that matter to your business." },
        new() { Question = "What payment methods are supported?", Answer = "The POS supports Cash and GCash payment tracking. We're working on adding more payment methods." },
        new() { Question = "Is my data secure?", Answer = "Yes. We use Supabase for authentication and data storage with row-level security, HTTPS encryption, and secure token management." }
    };
}
