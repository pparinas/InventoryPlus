@page "/"
@layout InventoryPlus.Layout.LandingLayout
@attribute [AllowAnonymous]

<PageTitle>@Settings.CompanyName - Smart Inventory Management</PageTitle>

<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">Manage Your Inventory With <span class="text-gradient">Precision</span></h1>
        <p class="hero-subtitle">The modern, beautiful path to managing products, real-time analytics, and low stock alerts. Run your business without the friction.</p>
        <div class="hero-actions">
            <a href="/register" class="btn btn-primary btn-lg">Get Started Free</a>
            <a href="#features" class="btn btn-secondary btn-lg">Explore Features</a>
        </div>
    </div>
    <div class="hero-image">
        <!-- Floating mockups or abstract shapes -->
        <div class="glass-panel mockup-panel">
            <div class="mockup-header">
                <div class="dot red"></div><div class="dot yellow"></div><div class="dot green"></div>
            </div>
            <div class="mockup-body">
                <div class="mockup-chart"></div>
                <div class="mockup-stats">
                    <div class="m-stat"></div>
                    <div class="m-stat"></div>
                    <div class="m-stat" style="width: 50%"></div>
                </div>
                <div class="mockup-stats" style="margin-top: 1rem">
                    <div class="m-stat" style="background: rgba(99, 102, 241, 0.2)"></div>
                    <div class="m-stat" style="background: rgba(39, 201, 63, 0.2)"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="features-section">
    <div class="section-title">
        <h2>Everything you need</h2>
        <p class="text-muted text-lg mt-2">Powerful tools integrated into one seamless experience.</p>
    </div>
    
    <div class="features-grid">
        <div class="feature-card glass-panel">
            <div class="feature-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <h3>Smart Inventory</h3>
            <p>Track ingredients and products in real time with automatic stock deduction upon sales.</p>
        </div>
        <div class="feature-card glass-panel">
            <div class="feature-icon"><i class="fa-solid fa-cash-register"></i></div>
            <h3>Point of Sale</h3>
            <p>A fast, intuitive POS system right in your browser. Complete orders seamlessly.</p>
        </div>
        <div class="feature-card glass-panel">
            <div class="feature-icon"><i class="fa-solid fa-chart-pie"></i></div>
            <h3>Deep Analytics</h3>
            <p>Understand your profit margins, top selling items, and revenue growth effortlessly.</p>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="glass-panel cta-panel">
        <h2>Ready to upgrade your business?</h2>
        <p>Join thousands of businesses managing their workflow with @Settings.CompanyName.</p>
        <a href="/register" class="btn btn-primary btn-lg mt-4">Create Your Account</a>
    </div>
</section>
