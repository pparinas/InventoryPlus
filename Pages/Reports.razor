@page "/reports"

<PageTitle>Reports | @AppSettings.CompanyName</PageTitle>


<div class="page-header">
    <div>
        <h1>Reports</h1>
        <p class="text-muted">Analyze sales performance and inventory valuation.</p>
    </div>
</div>

<div class="report-filter-bar">
    @foreach (var f in new[] { "All", "Daily", "Weekly", "Monthly", "Yearly" })
    {
        <button class="report-filter-btn @(selectedFilter == f ? "active" : "")" @onclick="() => { selectedFilter = f; salesPage = 1; }">@f</button>
    }
</div>

<div class="grid grid-cols-3 mb-4">
    <div class="glass-panel">
        <div class="flex items-center gap-3">
            <div class="stat-icon stat-warning" style="width: 50px; height: 50px">
                <i class="fa-solid fa-boxes-packing"></i>
            </div>
            <div>
                <h3>₱@InventoryValue.ToString("0.00")</h3>
                <p class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">Inventory Value (Cost)</p>
            </div>
        </div>
    </div>
    
    <div class="glass-panel">
        <div class="flex items-center gap-3">
            <div class="stat-icon stat-success" style="width: 50px; height: 50px">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div>
                <h3>@FilteredSales.Count()</h3>
                <p class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">Total Sales (@selectedFilter)</p>
            </div>
        </div>
    </div>
    
    <div class="glass-panel">
        <div class="flex items-center gap-3">
            <div class="stat-icon stat-accent" style="width: 50px; height: 50px">
                <i class="fa-solid fa-money-bill-trend-up"></i>
            </div>
            <div>
                <h3>@AverageProfitMargin.ToString("0.0")%</h3>
                <p class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">Avg Margin (@selectedFilter)</p>
            </div>
        </div>
    </div>
</div>

<div class="glass-panel">
    <h2 class="mb-4">Sales History - @selectedFilter</h2>
    
    @if (FilteredSales.Any())
    {
        <div class="table-responsive table-view">
        <table>
            <thead>
                <tr>
                    <th>Report ID</th>
                    <th>Date</th>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Method</th>
                    <th>Amount</th>
                    <th>Profit</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in FilteredSales.OrderByDescending(s => s.Date).Skip((salesPage - 1) * PageSize).Take(PageSize))
                {
                    <tr>
                        <td class="text-muted" style="font-family: monospace; font-size: 0.85rem">
                            @sale.Guid.ToString().Substring(0, 8)
                        </td>
                        <td>@sale.Date.ToString("g")</td>
                        <td><strong>@sale.ProductName</strong></td>
                        <td>@sale.QuantitySold</td>
                        <td>
                            <span class="badge @(sale.PaymentMethod == "GCash" ? "badge-primary" : "badge-secondary")">
                                @sale.PaymentMethod
                            </span>
                        </td>
                        <td class="text-primary">₱@sale.TotalAmount.ToString("0.00")</td>
                        <td class="text-success">
                            ₱@sale.ProfitAmount.ToString("0.00")
                        </td>
                        <td class="text-muted" style="font-size: 0.85rem">
                            @sale.Note
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <div class="card-view">
            @foreach (var sale in FilteredSales.OrderByDescending(s => s.Date).Skip((salesPage - 1) * PageSize).Take(PageSize))
            {
                <div class="stock-card">
                    <div class="stock-card-header">
                        <div>
                            <span class="stock-card-name">@sale.ProductName</span>
                            <div class="text-muted" style="font-size: 0.72rem; font-family: monospace;">ID: @sale.Guid.ToString().Substring(0, 8)</div>
                        </div>
                        <span class="badge @(sale.PaymentMethod == "GCash" ? "badge-primary" : "badge-secondary")">@sale.PaymentMethod</span>
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row">
                            <span class="stock-card-label">Date</span>
                            <span>@sale.Date.ToString("g")</span>
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Qty</span>
                            <span>@sale.QuantitySold</span>
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Amount</span>
                            <span class="text-primary font-bold">₱@sale.TotalAmount.ToString("0.00")</span>
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Profit</span>
                            <span class="text-success">₱@sale.ProfitAmount.ToString("0.00")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(sale.Note))
                        {
                            <div class="stock-card-row" style="align-items: flex-start;">
                                <span class="stock-card-label" style="flex-shrink: 0;">Note</span>
                                <span class="text-muted" style="font-size: 0.8rem; text-align: right;">@sale.Note</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
        <PaginationBar Page="salesPage" PageSize="PageSize" TotalItems="FilteredSales.Count()" OnPageChange="SetSalesPage" />
    }
    else
    {
        <div class="text-center text-muted" style="padding: 3rem">
            <i class="fa-solid fa-receipt fa-4x mb-4 text-primary" style="opacity: 0.3"></i>
            <p>No sales history for the selected period.</p>
        </div>
    }
</div>

<div class="glass-panel" style="margin-top: 1.5rem;">
    <div class="flex justify-between items-center mb-1" style="flex-wrap: wrap; gap: 0.75rem;">
        <div>
            <h2>Stock Inventory Summary</h2>
            <p class="text-muted" style="font-size: 0.85rem;">Filter by date added — leave blank to show all.</p>
        </div>
        <div class="flex items-center gap-2">
            <input type="date" @bind="stockDateFilter" @bind:format="yyyy-MM-dd"
                   style="padding: 0.4rem 0.75rem; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--text-primary); font-size: 0.875rem;" />
            @if (stockDateFilter.HasValue)
            {
                <button class="btn btn-sm btn-secondary" @onclick="() => { stockDateFilter = null; stockPage = 1; }" title="Clear filter">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            }
        </div>
    </div>
    <div class="mb-4"></div>

    @if (FilteredStockItems.Any())
    {
        @* Desktop table *@
        <div class="table-responsive table-view">
        <table>
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Type</th>
                    <th>Stock</th>
                    <th>Cost / Unit</th>
                    <th>Total Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in FilteredStockItems.OrderByDescending(i => i.Stock * i.CostPerUnit).Skip((stockPage - 1) * PageSize).Take(PageSize))
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td><span class="badge @(item.Type == "Ingredient" ? "badge-primary" : "badge-secondary")">@item.Type</span></td>
                        <td>
                            @if (item.Stock < 5 && item.Type == "Ingredient")
                            {
                                <span class="text-warning font-bold">@item.Stock @item.Unit <small>(Low)</small></span>
                            }
                            else
                            {
                                <span>@item.Stock @item.Unit</span>
                            }
                        </td>
                        <td>₱@item.CostPerUnit.ToString("0.00")</td>
                        <td class="text-primary font-bold">₱@((item.Stock * item.CostPerUnit).ToString("0.00"))</td>
                    </tr>
                }
                <tr style="border-top: 2px solid var(--border); font-weight: 600;">
                    <td colspan="4" class="text-right">Total (@FilteredStockItems.Count()) items</td>
                    <td class="text-success">₱@FilteredStockItems.Sum(i => i.Stock * i.CostPerUnit).ToString("0.00")</td>
                </tr>
            </tbody>
        </table>
        </div>
        @* Mobile cards *@
        <div class="card-view">
            @foreach (var item in FilteredStockItems.OrderByDescending(i => i.Stock * i.CostPerUnit).Skip((stockPage - 1) * PageSize).Take(PageSize))
            {
                <div class="stock-card">
                    <div class="stock-card-header">
                        <span class="stock-card-name">@item.Name</span>
                        <span class="badge @(item.Type == "Ingredient" ? "badge-primary" : "badge-secondary")">@item.Type</span>
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row">
                            <span class="stock-card-label">Stock</span>
                            @if (item.Stock < 5 && item.Type == "Ingredient")
                            {
                                <span class="text-warning font-bold">@item.Stock @item.Unit <small>(Low)</small></span>
                            }
                            else
                            {
                                <span>@item.Stock @item.Unit</span>
                            }
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Cost / Unit</span>
                            <span>₱@item.CostPerUnit.ToString("0.00")</span>
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Total Value</span>
                            <span class="text-primary font-bold">₱@((item.Stock * item.CostPerUnit).ToString("0.00"))</span>
                        </div>
                    </div>
                </div>
            }
            <div class="stock-card" style="border-color: var(--primary);">
                <div class="stock-card-body" style="padding: 0.75rem 1rem;">
                    <div class="stock-card-row">
                        <span style="font-weight: 600;">Total Value (@FilteredStockItems.Count() items)</span>
                        <span class="text-success font-bold">₱@FilteredStockItems.Sum(i => i.Stock * i.CostPerUnit).ToString("0.00")</span>
                    </div>
                </div>
            </div>
        </div>
        <PaginationBar Page="stockPage" PageSize="PageSize" TotalItems="FilteredStockItems.Count()" OnPageChange="SetStockPage" />
    }
    else
    {
        <div class="text-center text-muted" style="padding: 3rem">
            <i class="fa-solid fa-boxes-stacked fa-4x mb-4 text-primary" style="opacity: 0.3"></i>
            <p>@(stockDateFilter.HasValue ? $"No stock added on {stockDateFilter.Value:MMM dd, yyyy}." : "No stock items found.")</p>
        </div>
    }
</div>

