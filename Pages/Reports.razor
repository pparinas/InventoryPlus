@page "/reports"

<PageTitle>Reports | @AppSettings.CompanyName</PageTitle>

@if (AppSettings.IsGuestMode)
{
<div class="page-header">
    <div>
        <h1>Reports</h1>
        <p class="text-muted">Analyze sales, inventory, and profitability.</p>
    </div>
</div>
<div class="guest-locked-page">
    <div class="glass-panel text-center p-5">
        <div style="font-size: 4rem; color: var(--text-muted); margin-bottom: 1rem;"><i class="fa-solid fa-lock"></i></div>
        <h2>Reports are a Pro Feature</h2>
        <p class="text-muted mb-3">Sign in to unlock detailed sales analytics, profit & loss reports, inventory valuation, and CSV exports.</p>
        <div class="row g-3 mb-4" style="max-width: 600px; margin: 0 auto;">
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-chart-line"></i> Sales Summary</h3>
                    <div style="height: 60px;"></div>
                </div>
            </div>
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-trophy"></i> Top Products</h3>
                    <div style="height: 60px;"></div>
                </div>
            </div>
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-credit-card"></i> Payment Methods</h3>
                    <div style="height: 60px;"></div>
                </div>
            </div>
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-money-bill-trend-up"></i> Profit & Loss</h3>
                    <div style="height: 60px;"></div>
                </div>
            </div>
        </div>
        <a href="login" class="btn btn-primary btn-lg"><i class="fa-solid fa-right-to-bracket"></i> Sign In to Unlock</a>
    </div>
</div>
}
else
{

<div class="page-header">
    <div>
        <h1>Reports</h1>
        <p class="text-muted">Analyze sales, inventory, and profitability.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" @onclick="ExportCsv"><i class="fa-solid fa-file-csv"></i><span class="d-none d-sm-inline"> Export CSV</span></button>
    </div>
</div>

<div class="report-filter-bar">
    @foreach (var f in new[] { "All", "Daily", "Weekly", "Monthly", "Yearly" })
    {
        <button class="report-filter-btn @(selectedFilter == f ? "active" : "")" @onclick="() => { selectedFilter = f; salesPage = 1; }">@f</button>
    }
</div>

@* ── Summary Stats ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="glass-panel stat-card">
        <div class="stat-icon stat-success"><i class="fa-solid fa-chart-line"></i></div>
        <div class="stat-content"><h3>₱@AppSettings.FormatCurrency(FilteredRevenue)</h3><p>Revenue</p></div>
    </div>
    </div>
    <div class="col-6 col-lg-3">
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-accent"><i class="fa-solid fa-money-bill-trend-up"></i></div>
        <div class="stat-content"><h3>₱@AppSettings.FormatCurrency(FilteredProfit)</h3><p>Profit</p></div>
    </div>
    </div>
    <div class="col-6 col-lg-3">
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-primary"><i class="fa-solid fa-receipt"></i></div>
        <div class="stat-content"><h3>@FilteredSales.Count()</h3><p>Transactions</p></div>
    </div>
    </div>
    <div class="col-6 col-lg-3">
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-warning"><i class="fa-solid fa-boxes-packing"></i></div>
        <div class="stat-content"><h3>₱@AppSettings.FormatCurrency(InventoryValue)</h3><p>Inventory Value</p></div>
    </div>
    </div>
</div>

@* ── 1. Sales Summary ── *@
@if (AppSettings.ShowReportSalesSummary)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("sales")'>
        <h2><i class="fa-solid fa-receipt text-primary"></i> Sales Summary</h2>
        <i class="fa-solid @(openSections.Contains("sales") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("sales"))
    {
        @if (FilteredSales.Any())
        {
            <div class="table-responsive table-view mt-3">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>ID</th><th>Date</th><th>Product</th><th>Qty</th><th>Method</th><th>Amount</th><th>Profit</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var sale in FilteredSales.OrderByDescending(s => s.Date).Skip((salesPage - 1) * PageSize).Take(PageSize))
                    {
                        <tr style="@(sale.IsVoided ? "opacity: 0.5; text-decoration: line-through;" : "")">
                            <td class="text-muted" style="font-family:monospace;font-size:0.85rem">@sale.Guid.ToString()[..8]</td>
                            <td>@sale.Date.ToString("MMM dd, h:mm tt")</td>
                            <td><strong>@sale.ProductName</strong></td>
                            <td>@sale.QuantitySold</td>
                            <td><span class="badge @(sale.PaymentMethod == "GCash" ? "bg-primary-subtle" : "bg-secondary")">@sale.PaymentMethod</span></td>
                            <td style="color: var(--primary)">₱@AppSettings.FormatCurrency(sale.TotalAmount)</td>
                            <td class="text-success">₱@AppSettings.FormatCurrency(sale.ProfitAmount)</td>
                            <td class="text-end">
                                @if (!sale.IsVoided)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => PrintSaleReceipt(sale)" title="Print Receipt"><i class="fa-solid fa-print"></i></button>
                                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => StartEditSale(sale)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => StartVoidSale(sale)" title="Void"><i class="fa-solid fa-ban"></i></button>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle">Voided</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view mt-3">
                @foreach (var sale in FilteredSales.OrderByDescending(s => s.Date).Skip((salesPage - 1) * PageSize).Take(PageSize))
                {
                    <div class="stock-card" style="@(sale.IsVoided ? "opacity: 0.5;" : "")">
                        <div class="stock-card-header">
                            <div>
                                <span class="stock-card-name">@sale.ProductName</span>
                                <div class="text-muted" style="font-size:0.72rem;font-family:monospace">@sale.Guid.ToString()[..8]</div>
                            </div>
                            @if (sale.IsVoided)
                            {
                                <span class="badge bg-danger-subtle">Voided</span>
                            }
                            else
                            {
                                <span class="badge @(sale.PaymentMethod == "GCash" ? "bg-primary-subtle" : "bg-secondary")">@sale.PaymentMethod</span>
                            }
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Date</span><span>@sale.Date.ToString("MMM dd, h:mm tt")</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Qty</span><span>@sale.QuantitySold</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Amount</span><span class="fw-bold" style="color: var(--primary)">₱@AppSettings.FormatCurrency(sale.TotalAmount)</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Profit</span><span class="text-success">₱@AppSettings.FormatCurrency(sale.ProfitAmount)</span></div>
                        </div>
                        @if (!sale.IsVoided)
                        {
                            <div class="stock-card-actions">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => PrintSaleReceipt(sale)"><i class="fa-solid fa-print"></i> Receipt</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditSale(sale)"><i class="fa-solid fa-pen"></i> Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => StartVoidSale(sale)"><i class="fa-solid fa-ban"></i> Void</button>
                            </div>
                        }
                    </div>
                }
            </div>
            <PaginationBar Page="salesPage" PageSize="PageSize" TotalItems="FilteredSales.Count()" OnPageChange="SetSalesPage" />
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-receipt" Title="No sales" Message="No transactions for the selected period." />
        }
    }
</div>
}

@* ── 2. Top Products ── *@
@if (AppSettings.ShowReportTopProducts)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("top")'>
        <h2><i class="fa-solid fa-trophy text-warning"></i> Top Products</h2>
        <i class="fa-solid @(openSections.Contains("top") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("top"))
    {
        @if (TopProductsReport.Any())
        {
            <div class="top-products-list mt-3">
                @{ var topMaxQty = TopProductsReport.First().TotalQty; }
                @foreach (var tp in TopProductsReport)
                {
                    var barPct = topMaxQty > 0 ? ((double)tp.TotalQty / topMaxQty * 100) : 0;
                    <div class="top-product-row">
                        <span class="top-product-name">@tp.Name</span>
                        <div class="top-product-bar-track">
                            <div class="top-product-bar" style="width:@barPct.ToString("0")%"></div>
                        </div>
                        <span class="top-product-count">@tp.TotalQty sold &middot; ₱@AppSettings.FormatCurrency(tp.TotalRevenue)</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-trophy" Title="No data" Message="Top products will appear after sales." />
        }
    }
</div>
}

@* ── 3. Payment Methods ── *@
@if (AppSettings.ShowReportPaymentMethods)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("payment")'>
        <h2><i class="fa-solid fa-credit-card text-accent"></i> Payment Methods</h2>
        <i class="fa-solid @(openSections.Contains("payment") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("payment"))
    {
        @if (PaymentMethodsReport.Any())
        {
            <div class="payment-breakdown mt-3">
                @{ var totalPay = PaymentMethodsReport.Values.Sum(); }
                @foreach (var pm in PaymentMethodsReport)
                {
                    var pct = totalPay > 0 ? (pm.Value / totalPay * 100) : 0;
                    <div class="payment-row">
                        <div class="payment-label"><span>@pm.Key</span></div>
                        <div class="payment-bar-track"><div class="payment-bar" style="width:@pct.ToString("0")%"></div></div>
                        <span class="payment-amount">₱@AppSettings.FormatCurrency(pm.Value) (@pct.ToString("0")%)</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-credit-card" Title="No data" Message="Payment method breakdown will appear after sales." />
        }
    }
</div>
}

@* ── 4. Profit & Loss ── *@
@if (AppSettings.ShowReportProfitLoss)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("pnl")'>
        <h2><i class="fa-solid fa-scale-balanced text-success"></i> Profit & Loss</h2>
        <i class="fa-solid @(openSections.Contains("pnl") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("pnl"))
    {
        <div class="pnl-grid mt-3">
            <div class="pnl-item">
                <span class="pnl-label">Gross Revenue</span>
                <span class="pnl-value">₱@AppSettings.FormatCurrency(FilteredRevenue)</span>
            </div>
            <div class="pnl-item">
                <span class="pnl-label">Tax Collected</span>
                <span class="pnl-value">₱@AppSettings.FormatCurrency(FilteredTax)</span>
            </div>
            <div class="pnl-item">
                <span class="pnl-label">Cost of Goods Sold</span>
                <span class="pnl-value text-warning">₱@AppSettings.FormatCurrency(FilteredCOGS)</span>
            </div>
            @if (AppSettings.ShowOpexTab)
            {
            <div class="pnl-item">
                <span class="pnl-label">Operating Expenses (OPEX)</span>
                <span class="pnl-value text-warning">₱@AppSettings.FormatCurrency(FilteredOpexTotal)</span>
            </div>
            }
            <div class="pnl-item pnl-total">
                <span class="pnl-label">Net Profit @(AppSettings.ShowOpexTab ? "(after OPEX)" : "")</span>
                <span class="pnl-value @(NetProfitAfterOpex >= 0 ? "text-success" : "text-danger")">₱@AppSettings.FormatCurrency(NetProfitAfterOpex)</span>
            </div>
            <div class="pnl-item">
                <span class="pnl-label">Avg Profit Margin</span>
                <span class="pnl-value">@AverageProfitMargin.ToString("N1")%</span>
            </div>
        </div>
    }
</div>
}

@* ── 5. Inventory Valuation ── *@
@if (AppSettings.ShowReportInventoryValuation)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("inv")'>
        <h2><i class="fa-solid fa-boxes-packing text-warning"></i> Inventory Valuation</h2>
        <i class="fa-solid @(openSections.Contains("inv") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("inv"))
    {
        <div class="d-flex align-items-center gap-2 mt-3 mb-3">
            <input type="date" @bind="stockDateFilter" @bind:format="yyyy-MM-dd"
                   class="form-control" style="width:auto" />
            @if (stockDateFilter.HasValue)
            {
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => { stockDateFilter = null; stockPage = 1; }"><i class="fa-solid fa-xmark"></i></button>
            }
        </div>
        @if (FilteredStockItems.Any())
        {
            <div class="table-responsive table-view">
            <table class="table table-hover mb-0">
                <thead><tr><th>Item</th><th>Type</th><th>Stock</th><th>Cost/Unit</th><th>Value</th></tr></thead>
                <tbody>
                    @foreach (var item in FilteredStockItems.OrderByDescending(i => i.Stock * i.CostPerUnit).Skip((stockPage - 1) * PageSize).Take(PageSize))
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td><span class="badge @(item.Type == "Ingredient" ? "bg-primary-subtle" : "bg-secondary")">@item.Type</span></td>
                            <td>
                                @if (item.Stock < 5) { <span class="text-warning fw-bold">@item.Stock @item.Unit</span> }
                                else { <span>@item.Stock @item.Unit</span> }
                            </td>
                            <td>₱@AppSettings.FormatCurrency(item.CostPerUnit)</td>
                            <td class="fw-bold" style="color: var(--primary)">₱@AppSettings.FormatCurrency(item.Stock * item.CostPerUnit)</td>
                        </tr>
                    }
                    <tr style="border-top:2px solid var(--border);font-weight:600">
                        <td colspan="4" class="text-end">Total (@FilteredStockItems.Count() items)</td>
                        <td class="text-success">₱@AppSettings.FormatCurrency(FilteredStockItems.Sum(i => i.Stock * i.CostPerUnit))</td>
                    </tr>
                </tbody>
            </table>
            </div>
            <div class="card-view">
                @foreach (var item in FilteredStockItems.OrderByDescending(i => i.Stock * i.CostPerUnit).Skip((stockPage - 1) * PageSize).Take(PageSize))
                {
                    <div class="stock-card">
                        <div class="stock-card-header">
                            <span class="stock-card-name">@item.Name</span>
                            <span class="badge @(item.Type == "Ingredient" ? "bg-primary-subtle" : "bg-secondary")">@item.Type</span>
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Stock</span><span>@item.Stock @item.Unit</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Value</span><span class="fw-bold" style="color: var(--primary)">₱@AppSettings.FormatCurrency(item.Stock * item.CostPerUnit)</span></div>
                        </div>
                    </div>
                }
            </div>
            <PaginationBar Page="stockPage" PageSize="PageSize" TotalItems="FilteredStockItems.Count()" OnPageChange="SetStockPage" />
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-boxes-stacked" Title="No items" Message="@(stockDateFilter.HasValue ? "No stock from this date." : "No inventory items.")" />
        }
    }
</div>
}

@* ── 6. Stock Movement ── *@
@if (AppSettings.ShowReportStockMovement)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("movement")'>
        <h2><i class="fa-solid fa-arrows-rotate text-primary"></i> Stock Movement</h2>
        <i class="fa-solid @(openSections.Contains("movement") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("movement"))
    {
        @if (StockMovement.Any())
        {
            <div class="table-responsive table-view mt-3">
            <table class="table table-hover mb-0">
                <thead><tr><th>Product</th><th>Units Sold</th><th>Revenue</th><th>Avg Price</th></tr></thead>
                <tbody>
                    @foreach (var sm in StockMovement)
                    {
                        <tr>
                            <td><strong>@sm.Name</strong></td>
                            <td>@sm.UnitsSold</td>
                            <td style="color: var(--primary)">₱@AppSettings.FormatCurrency(sm.Revenue)</td>
                            <td>₱@AppSettings.FormatCurrency(sm.AvgPrice)</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view mt-3">
                @foreach (var sm in StockMovement)
                {
                    <div class="stock-card">
                        <div class="stock-card-header">
                            <span class="stock-card-name">@sm.Name</span>
                            <span style="color: var(--primary)" class="fw-bold">₱@AppSettings.FormatCurrency(sm.Revenue)</span>
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Units Sold</span><span>@sm.UnitsSold</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Avg Price</span><span>₱@AppSettings.FormatCurrency(sm.AvgPrice)</span></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-arrows-rotate" Title="No movement" Message="Stock movement data will appear after sales." />
        }
    }
</div>
}

@* ── 7. OPEX Summary ── *@
@if (AppSettings.ShowOpexTab)
{
<div class="glass-panel report-section mb-4">
    <div class="report-section-header" @onclick='() => ToggleSection("opex")'>
        <h2><i class="fa-solid fa-file-invoice-dollar text-warning"></i> Operating Expenses (OPEX)</h2>
        <i class="fa-solid @(openSections.Contains("opex") ? "fa-chevron-up" : "fa-chevron-down")"></i>
    </div>
    @if (openSections.Contains("opex"))
    {
        @if (OpexByCategory.Any())
        {
            <div class="row g-3 mt-3 mb-3">
                <div class="col-6 col-lg-4">
                    <div class="glass-panel stat-card" style="padding: 0.75rem;">
                        <div class="stat-content text-center"><h3>₱@AppSettings.FormatCurrency(FilteredOpexTotal)</h3><p>Total OPEX</p></div>
                    </div>
                </div>
                <div class="col-6 col-lg-4">
                    <div class="glass-panel stat-card" style="padding: 0.75rem;">
                        <div class="stat-content text-center"><h3>@FilteredOpex.Count()</h3><p>Entries</p></div>
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="glass-panel stat-card" style="padding: 0.75rem;">
                        <div class="stat-content text-center"><h3>@OpexByCategory.Count</h3><p>Categories</p></div>
                    </div>
                </div>
            </div>

            <div class="payment-breakdown">
                @{ var totalOpex = OpexByCategory.Values.Sum(); }
                @foreach (var cat in OpexByCategory.OrderByDescending(c => c.Value))
                {
                    var pct = totalOpex > 0 ? (cat.Value / totalOpex * 100) : 0;
                    <div class="payment-row">
                        <div class="payment-label"><span>@cat.Key</span></div>
                        <div class="payment-bar-track"><div class="payment-bar" style="width:@pct.ToString("0")%; background: var(--warning);"></div></div>
                        <span class="payment-amount">₱@AppSettings.FormatCurrency(cat.Value) (@pct.ToString("0")%)</span>
                    </div>
                }
            </div>

            <div class="table-responsive table-view mt-3">
            <table class="table table-hover mb-0">
                <thead><tr><th>Name</th><th>Category</th><th>Amount</th><th>Date</th></tr></thead>
                <tbody>
                    @foreach (var item in FilteredOpex.OrderByDescending(o => o.Date).Take(10))
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td><span class="badge bg-primary-subtle">@item.Category</span></td>
                            <td class="fw-bold" style="color: var(--warning)">₱@AppSettings.FormatCurrency(item.Amount)</td>
                            <td>@item.Date.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view mt-3">
                @foreach (var item in FilteredOpex.OrderByDescending(o => o.Date).Take(10))
                {
                    <div class="stock-card">
                        <div class="stock-card-header">
                            <span class="stock-card-name">@item.Name</span>
                            <span class="badge bg-primary-subtle">@item.Category</span>
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Amount</span><span class="fw-bold" style="color: var(--warning)">₱@AppSettings.FormatCurrency(item.Amount)</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Date</span><span>@item.Date.ToString("MMM dd, yyyy")</span></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-file-invoice-dollar" Title="No expenses" Message="Operating expenses will show here once added." />
        }
    }
</div>
}

@* ── Edit Sale Modal ── *@
<AppModal IsOpen="showEditSaleModal" IsOpenChanged="@((v) => { showEditSaleModal = v; })" Size="Large">
    <Header>
        <h5 class="modal-title">Edit Sale</h5>
    </Header>
    <Content>
        @if (editingSale != null)
        {
            <div class="mb-3">
                <label class="form-label">Product</label>
                <input type="text" class="form-control" value="@editingSale.ProductName" readonly />
            </div>
            <div class="row g-3">
                <div class="col-6">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control" @bind="editQty" min="1" />
                </div>
                <div class="col-6">
                    <label class="form-label">Payment Method</label>
                    <select class="form-select" @bind="editPaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="GCash">GCash</option>
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-6">
                    <label class="form-label">Discount Type</label>
                    <select class="form-select" @bind="editDiscountType">
                        <option value="None">None</option>
                        <option value="Percentage">% Off</option>
                        <option value="Fixed">₱ Fixed</option>
                    </select>
                </div>
                <div class="col-6">
                    @if (editDiscountType != "None")
                    {
                        <label class="form-label">Discount Amount</label>
                        <input type="number" class="form-control" step="0.01" @bind="editDiscountAmount" />
                    }
                </div>
            </div>
        }
    </Content>
    <Footer>
        <button class="btn btn-outline-secondary" @onclick="() => showEditSaleModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveEditSale">Save Changes</button>
    </Footer>
</AppModal>

@* ── Receipt Modal ── *@
@if (receiptSale != null)
{
    <Receipt IsVisible="showReceipt" BusinessName="@AppSettings.CompanyName" SaleDate="@receiptSale.Date"
             CustomerName="@receiptSale.CustomerName"
             Items="@(new List<Receipt.ReceiptItem> { new() { Name = receiptSale.ProductName, Quantity = receiptSale.QuantitySold, UnitPrice = (receiptSale.TotalAmount - receiptSale.TaxAmount) / receiptSale.QuantitySold } })"
             Subtotal="@(receiptSale.TotalAmount - receiptSale.TaxAmount)" TaxTotal="@receiptSale.TaxAmount" Total="@receiptSale.TotalAmount"
             PaymentMethod="@receiptSale.PaymentMethod" DiscountAmount="@receiptSale.DiscountAmount" DiscountType="@receiptSale.DiscountType"
             OnClose="() => { showReceipt = false; receiptSale = null; }" />
}

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showVoidConfirm"
    Title="Void Sale"
    Message="@($"Are you sure you want to void this sale? Stock will be restored.")"
    Icon="fa-solid fa-ban"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmVoidSale"
    OnCancel="() => showVoidConfirm = false" />

<InventoryPlus.Components.PinPrompt
    IsVisible="showPinPrompt"
    IsVisibleChanged="@((v) => showPinPrompt = v)"
    OnVerified="OnPinVerified" />

} @* end else (non-guest) *@