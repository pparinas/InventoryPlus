@page "/expenses"

<PageTitle>OPEX | @AppSettings.CompanyName</PageTitle>

<div class="section-gap fade-in">
    <div class="page-header">
        <div>
            <h1>OPEX</h1>
            <p>Track operating expenses.</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i> Add Expense</button>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:9px">
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-red"><i class="fa-solid fa-peso-sign"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">₱@AppSettings.FormatCurrency(TotalExpenses)</div>
                <div class="stat-card-label">Total Expenses</div>
            </div>
        </div>
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-amber"><i class="fa-solid fa-rotate"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">₱@AppSettings.FormatCurrency(FilteredItems.Where(o => o.IsRecurring).Sum(o => o.Amount))</div>
                <div class="stat-card-label">Recurring</div>
            </div>
        </div>
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-lime"><i class="fa-solid fa-receipt"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">₱@AppSettings.FormatCurrency(FilteredItems.Where(o => !o.IsRecurring).Sum(o => o.Amount))</div>
                <div class="stat-card-label">One-time</div>
            </div>
        </div>
    </div>

    <div class="filter-bar">
        <input class="form-control search-input" placeholder="Search expenses…" @bind="searchTerm" @bind:event="oninput" @bind:after="() => currentPage = 1" />
        <select class="form-control" style="width:auto" @bind="categoryFilter" @bind:after="() => currentPage = 1">
            <option value="All">All Categories</option>
            @foreach (var cat in Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>

    @if (FilteredItems.Any())
    {
    <div class="card" style="overflow:hidden">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Recurring</th>
                        <th>Amount</th>
                        <th style="text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredItems.Skip((currentPage - 1) * PageSize).Take(PageSize))
                    {
                        <tr>
                            <td style="font-weight:600">
                                @item.Name
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    <div style="font-size:10px;color:var(--fg3)">@item.Note</div>
                                }
                            </td>
                            <td><span class="tag">@item.Category</span></td>
                            <td style="font-size:11px;color:var(--fg3)">@item.Date.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (item.IsRecurring)
                                {
                                    <span class="badge badge-amber"><i class="fa-solid fa-rotate"></i> @item.Recurrence</span>
                                }
                                else
                                {
                                    <span class="badge badge-gray">One-time</span>
                                }
                            </td>
                            <td class="mono text-red fw-700">₱@AppSettings.FormatCurrency(item.Amount)</td>
                            <td>
                                <div style="display:flex;gap:4px;justify-content:flex-end">
                                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => OpenEditModal(item)"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-danger btn-sm btn-icon" @onclick="() => StartDelete(item)"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <PaginationBar Page="currentPage" PageSize="PageSize" TotalItems="FilteredItems.Count()" OnPageChange="SetPage" />
    }
    else
    {
        <InventoryPlus.Components.EmptyState Icon="fa-solid fa-file-invoice-dollar" Title="No expenses" Message="Add your first operating expense to start tracking." />
    }
</div>

<AppModal IsOpen="showModal" IsOpenChanged="@((v) => { showModal = v; })" Size="Large">
    <Header>
        <h5>@(isEditing ? "Edit Expense" : "New Expense")</h5>
    </Header>
    <Content>
        <div class="form-group">
            <label class="form-label">Name</label>
            <input class="form-control" @bind="editingItem.Name" placeholder="e.g. Monthly Rent" />
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-control" @bind="editingItem.Category">
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Amount (₱)</label>
                <input class="form-control" type="number" step="0.01" @bind="editingItem.Amount" placeholder="0.00" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Date</label>
                <input class="form-control" type="date" @bind="editingItem.Date" @bind:format="yyyy-MM-dd" />
            </div>
            <div class="form-group">
                <label class="form-label">Recurring</label>
                <div style="display:flex;gap:5px;margin-bottom:5px">
                    <button class="btn @(editingItem.IsRecurring ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => editingItem.IsRecurring = true">Yes</button>
                    <button class="btn @(!editingItem.IsRecurring ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => editingItem.IsRecurring = false">None</button>
                </div>
                @if (editingItem.IsRecurring)
                {
                <select class="form-control" @bind="editingItem.Recurrence">
                    <option value="Weekly">Weekly</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Yearly">Yearly</option>
                </select>
                }
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Note</label>
            <textarea class="form-control" rows="2" @bind="editingItem.Note" placeholder="Additional details…"></textarea>
        </div>
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="() => showModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveExpense">Save Expense</button>
    </Footer>
</AppModal>

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Expense"
    Message="Are you sure you want to delete this expense?"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmDelete"
    OnCancel="() => showDeleteConfirm = false" />

<InventoryPlus.Components.PinPrompt
    IsVisible="showPinPrompt"
    IsVisibleChanged="@((v) => showPinPrompt = v)"
    OnVerified="OnPinVerified" />
