@page "/expenses"

<PageTitle>OPEX | @AppSettings.CompanyName</PageTitle>

@if (AppSettings.IsGuestMode)
{
<div class="page-header">
    <div>
        <h1>Operating Expenses</h1>
        <p class="text-muted">Track and manage your business operating expenses.</p>
    </div>
</div>
<div class="guest-locked-page">
    <div class="glass-panel text-center p-5">
        <div style="font-size: 4rem; color: var(--text-muted); margin-bottom: 1rem;"><i class="fa-solid fa-lock"></i></div>
        <h2>OPEX Tracking is a Pro Feature</h2>
        <p class="text-muted mb-3">Sign in to log rent, utilities, salaries, and other recurring expenses. Track spending by category and calculate true profit margins.</p>
        <div class="row g-3 mb-4" style="max-width: 500px; margin: 0 auto;">
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-file-invoice-dollar"></i> Expenses</h3>
                    <div style="height: 50px;"></div>
                </div>
            </div>
            <div class="col-6">
                <div class="glass-panel p-3 locked-widget" style="position: relative;">
                    <div class="locked-widget-overlay"><i class="fa-solid fa-lock"></i></div>
                    <h3 class="text-sm text-muted mb-1"><i class="fa-solid fa-rotate"></i> Recurring</h3>
                    <div style="height: 50px;"></div>
                </div>
            </div>
        </div>
        <a href="login" class="btn btn-primary btn-lg"><i class="fa-solid fa-right-to-bracket"></i> Sign In to Unlock</a>
    </div>
</div>
}
else
{

<div class="page-header">
    <div>
        <h1>Operating Expenses</h1>
        <p class="text-muted">Track and manage your business operating expenses.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i><span class="d-none d-sm-inline"> Add Expense</span></button>
    </div>
</div>

@* ── Summary ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="glass-panel stat-card">
            <div class="stat-icon stat-warning"><i class="fa-solid fa-file-invoice-dollar"></i></div>
            <div class="stat-content"><h3>₱@AppSettings.FormatCurrency(TotalExpenses)</h3><p>Total Expenses</p></div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-panel stat-card">
            <div class="stat-icon stat-primary"><i class="fa-solid fa-list"></i></div>
            <div class="stat-content"><h3>@FilteredItems.Count()</h3><p>Entries</p></div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-panel stat-card">
            <div class="stat-icon stat-accent"><i class="fa-solid fa-rotate"></i></div>
            <div class="stat-content"><h3>@FilteredItems.Count(o => o.IsRecurring)</h3><p>Recurring</p></div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-panel stat-card">
            <div class="stat-icon stat-success"><i class="fa-solid fa-tags"></i></div>
            <div class="stat-content"><h3>@FilteredItems.Select(o => o.Category).Distinct().Count()</h3><p>Categories</p></div>
        </div>
    </div>
</div>

@* ── Filters ── *@
<div class="glass-panel mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <div class="flex-grow-1" style="min-width: 200px;">
            <div class="input-group">
                <span class="input-group-text"><i class="fa-solid fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search expenses..." @bind="searchTerm" @bind:event="oninput" @bind:after="() => currentPage = 1" />
            </div>
        </div>
        <select class="form-select" style="width: auto; min-width: 150px;" @bind="categoryFilter" @bind:after="() => currentPage = 1">
            <option value="All">All Categories</option>
            @foreach (var cat in Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
</div>

@* ── Table View ── *@
@if (FilteredItems.Any())
{
    <div class="glass-panel">
        <div class="table-responsive table-view">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Recurring</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredItems.Skip((currentPage - 1) * PageSize).Take(PageSize))
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    <div class="text-muted small">@item.Note</div>
                                }
                            </td>
                            <td><span class="badge bg-primary-subtle">@item.Category</span></td>
                            <td class="fw-bold" style="color: var(--warning);">₱@AppSettings.FormatCurrency(item.Amount)</td>
                            <td>@item.Date.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (item.IsRecurring)
                                {
                                    <span class="badge bg-accent-subtle"><i class="fa-solid fa-rotate me-1"></i>@item.Recurrence</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEditModal(item)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => StartDelete(item)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Card View (Mobile) ── *@
        <div class="card-view">
            @foreach (var item in FilteredItems.Skip((currentPage - 1) * PageSize).Take(PageSize))
            {
                <div class="stock-card">
                    <div class="stock-card-header">
                        <div>
                            <span class="stock-card-name">@item.Name</span>
                            @if (!string.IsNullOrEmpty(item.Note))
                            {
                                <div class="text-muted" style="font-size: 0.75rem;">@item.Note</div>
                            }
                        </div>
                        <span class="badge bg-primary-subtle">@item.Category</span>
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row"><span class="stock-card-label">Amount</span><span class="fw-bold" style="color: var(--warning)">₱@AppSettings.FormatCurrency(item.Amount)</span></div>
                        <div class="stock-card-row"><span class="stock-card-label">Date</span><span>@item.Date.ToString("MMM dd, yyyy")</span></div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Recurring</span>
                            <span>
                                @if (item.IsRecurring)
                                {
                                    <span class="badge bg-accent-subtle">@item.Recurrence</span>
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </span>
                        </div>
                    </div>
                    <div class="stock-card-actions">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEditModal(item)"><i class="fa-solid fa-pen"></i> Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => StartDelete(item)"><i class="fa-solid fa-trash"></i> Delete</button>
                    </div>
                </div>
            }
        </div>

        <PaginationBar Page="currentPage" PageSize="PageSize" TotalItems="FilteredItems.Count()" OnPageChange="SetPage" />
    </div>
}
else
{
    <InventoryPlus.Components.EmptyState Icon="fa-solid fa-file-invoice-dollar" Title="No expenses" Message="Add your first operating expense to start tracking." />
}

@* ── Add/Edit Modal ── *@
<AppModal IsOpen="showModal" IsOpenChanged="@((v) => { showModal = v; })" Size="Large">
    <Header>
        <h5 class="modal-title">@(isEditing ? "Edit Expense" : "Add Expense")</h5>
    </Header>
    <Content>
        <div class="mb-3">
            <label class="form-label">Expense Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" @bind="editingItem.Name" placeholder="e.g. Monthly Rent" />
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label class="form-label">Category</label>
                <select class="form-select" @bind="editingItem.Category">
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-6">
                <label class="form-label">Amount (₱) <span class="text-danger">*</span></label>
                <input type="number" class="form-control" step="0.01" @bind="editingItem.Amount" />
            </div>
        </div>
        <div class="row g-3 mt-1">
            <div class="col-6">
                <label class="form-label">Date</label>
                <input type="date" class="form-control" @bind="editingItem.Date" @bind:format="yyyy-MM-dd" />
            </div>
            <div class="col-6">
                <label class="form-label">Note</label>
                <input type="text" class="form-control" @bind="editingItem.Note" placeholder="Optional note" />
            </div>
        </div>
        <div class="mt-3">
            <label class="toggle-row"><input type="checkbox" @bind="editingItem.IsRecurring" /><span>Recurring Expense</span></label>
        </div>
        @if (editingItem.IsRecurring)
        {
            <div class="mt-2">
                <label class="form-label">Recurrence</label>
                <select class="form-select" @bind="editingItem.Recurrence">
                    <option value="Daily">Daily</option>
                    <option value="Weekly">Weekly</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Yearly">Yearly</option>
                </select>
            </div>
        }
    </Content>
    <Footer>
        <button class="btn btn-outline-secondary" @onclick="() => showModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveExpense">@(isEditing ? "Save Changes" : "Add Expense")</button>
    </Footer>
</AppModal>

@* ── Delete Confirm ── *@
<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Expense"
    Message="Are you sure you want to delete this expense?"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmDelete"
    OnCancel="() => showDeleteConfirm = false" />

@* ── PIN Prompt ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showPinPrompt"
    IsVisibleChanged="@((v) => showPinPrompt = v)"
    OnVerified="OnPinVerified" />

} @* end else (non-guest) *@
