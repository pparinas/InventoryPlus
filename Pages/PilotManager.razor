@page "/pilot"
@layout InventoryPlus.Layout.MainLayout

<PageTitle>Pilot Mode | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-tower-broadcast me-2" style="color: var(--primary);"></i>Pilot Mode</h1>
        <p class="text-muted">Let operators use your POS. Monitor every transaction in real time.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="glass-panel text-center p-4">
        <i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i>
        <p class="text-muted">Loading...</p>
    </div>
}
else
{
    @* ── Active Session / Create Session ── *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-6">
            <div class="glass-panel">
                @if (CurrentActiveSession != null)
                {
                    <h2 class="mb-1"><i class="fa-solid fa-circle text-success me-2" style="font-size: 0.6rem; vertical-align: middle;"></i>Active Session</h2>
                    <p class="text-muted text-sm mb-3">An operator can join with this code.</p>

                    <div class="text-center p-3 mb-3 rounded-3" style="background: var(--bg-surface); border: 2px dashed var(--primary);">
                        <div class="text-muted small mb-1">Access Code</div>
                        <div style="font-size: 2.5rem; font-weight: 700; letter-spacing: 0.3rem; color: var(--primary); font-family: monospace;">
                            @CurrentActiveSession.AccessCode
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2 mb-3">
                        <div class="d-flex justify-content-between py-1" style="border-bottom: 1px solid var(--border);">
                            <span class="text-muted small">Operator</span>
                            <span class="small fw-semibold">@(string.IsNullOrEmpty(CurrentActiveSession.OperatorName) ? "Waiting..." : CurrentActiveSession.OperatorName)</span>
                        </div>
                        <div class="d-flex justify-content-between py-1" style="border-bottom: 1px solid var(--border);">
                            <span class="text-muted small">Started</span>
                            <span class="small">@CurrentActiveSession.StartedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</span>
                        </div>
                        <div class="d-flex justify-content-between py-1" style="border-bottom: 1px solid var(--border);">
                            <span class="text-muted small">Expires</span>
                            <span class="small">@CurrentActiveSession.ExpiresAt.ToLocalTime().ToString("MMM dd, h:mm tt")</span>
                        </div>
                    </div>

                    <button class="btn btn-danger w-100" @onclick="() => StartEndSession(CurrentActiveSession)">
                        <i class="fa-solid fa-power-off me-1"></i> End Session
                    </button>
                }
                else
                {
                    <h2 class="mb-1">Create Pilot Session</h2>
                    <p class="text-muted text-sm mb-3">Generate an access code for your operator.</p>

                    <div class="mb-3">
                        <label class="form-label">Session Duration</label>
                        <select class="form-select" @bind="expiryHours">
                            <option value="1">1 Hour</option>
                            <option value="4">4 Hours</option>
                            <option value="8">8 Hours (Work Shift)</option>
                            <option value="12">12 Hours</option>
                            <option value="24">24 Hours</option>
                            <option value="72">3 Days</option>
                            <option value="168">1 Week</option>
                        </select>
                    </div>

                    <button class="btn btn-primary w-100" @onclick="GenerateCode" disabled="@isCreating">
                        @if (isCreating)
                        {
                            <i class="fa-solid fa-spinner fa-spin me-1"></i> <span>Creating...</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-key me-1"></i> <span>Generate Access Code</span>
                        }
                    </button>
                }
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="glass-panel">
                <h2 class="mb-1">How It Works</h2>
                <p class="text-muted text-sm mb-3">Share your POS with operators securely.</p>

                <div class="d-flex flex-column gap-3">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 32px; height: 32px; background: var(--primary); color: white; font-size: 0.8rem; font-weight: 600;">1</div>
                        <div>
                            <div class="fw-semibold">Generate an Access Code</div>
                            <div class="text-muted small">Create a 6-digit code with your preferred duration.</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 32px; height: 32px; background: var(--primary); color: white; font-size: 0.8rem; font-weight: 600;">2</div>
                        <div>
                            <div class="fw-semibold">Share with Operator</div>
                            <div class="text-muted small">They enter the code on the login page via "Join as Operator".</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 32px; height: 32px; background: var(--primary); color: white; font-size: 0.8rem; font-weight: 600;">3</div>
                        <div>
                            <div class="fw-semibold">They Use POS & Products</div>
                            <div class="text-muted small">Operators can only access the Point of Sale and view products.</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 32px; height: 32px; background: var(--primary); color: white; font-size: 0.8rem; font-weight: 600;">4</div>
                        <div>
                            <div class="fw-semibold">You Monitor Everything</div>
                            <div class="text-muted small">Every sale is logged here in real time. End the session anytime.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Activity Log ── *@
    <div class="glass-panel mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="mb-0">Activity Log</h2>
                <p class="text-muted text-sm mb-0">Real-time operator activity.</p>
            </div>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshActivity" disabled="@isRefreshing">
                <i class="fa-solid @(isRefreshing ? "fa-spinner fa-spin" : "fa-arrows-rotate")"></i><span class="d-none d-sm-inline ms-1">Refresh</span>
            </button>
        </div>

        <div class="d-flex gap-2 mb-3 flex-wrap">
            @foreach (var f in new[] { "All", "sale", "void", "session_start", "session_end" })
            {
                var label = f == "All" ? "All" : f == "sale" ? "Sales" : f == "void" ? "Voids" : f == "session_start" ? "Joins" : "Leaves";
                <button class="report-filter-btn @(activityFilter == f ? "active" : "")" @onclick="() => activityFilter = f">@label</button>
            }
        </div>

        @if (FilteredActivity.Any())
        {
            <div class="d-flex flex-column gap-2" style="max-height: 400px; overflow-y: auto;">
                @foreach (var log in FilteredActivity.Take(50))
                {
                    var icon = log.Action switch
                    {
                        "sale" => "fa-solid fa-cart-shopping text-success",
                        "void" => "fa-solid fa-ban text-danger",
                        "session_start" => "fa-solid fa-right-to-bracket text-primary",
                        "session_end" => "fa-solid fa-right-from-bracket text-muted",
                        _ => "fa-solid fa-circle-info text-muted"
                    };
                    <div class="d-flex align-items-start gap-3 p-2 rounded-2" style="background: var(--bg-surface); border: 1px solid var(--border);">
                        <i class="@icon mt-1" style="width: 20px; text-align: center;"></i>
                        <div class="flex-grow-1">
                            <div class="fw-semibold small">@log.OperatorName</div>
                            <div class="small">@log.Detail</div>
                        </div>
                        <span class="text-muted small flex-shrink-0">@log.Timestamp.ToLocalTime().ToString("h:mm tt")</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-clipboard-list" Title="No activity" Message="Operator activity will appear here once they start." />
        }
    </div>

    @* ── Past Sessions ── *@
    @if (PastSessions.Any())
    {
    <div class="glass-panel mb-4">
        <h2 class="mb-1">Session History</h2>
        <p class="text-muted text-sm mb-3">Previous pilot sessions.</p>

        <div class="table-responsive table-view">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Operator</th><th>Code</th><th>Started</th><th>Ended</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in PastSessions.Take(20))
                    {
                        <tr>
                            <td>@(string.IsNullOrEmpty(s.OperatorName) ? "—" : s.OperatorName)</td>
                            <td><code>@s.AccessCode</code></td>
                            <td>@s.StartedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                            <td>@(s.EndedAt?.ToLocalTime().ToString("MMM dd, h:mm tt") ?? "—")</td>
                            <td>
                                @if (s.IsExpired && s.Status == "active")
                                {
                                    <span class="badge bg-warning-subtle">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ended</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-view">
            @foreach (var s in PastSessions.Take(20))
            {
                <div class="stock-card">
                    <div class="stock-card-header">
                        <span class="stock-card-name">@(string.IsNullOrEmpty(s.OperatorName) ? "No operator" : s.OperatorName)</span>
                        @if (s.IsExpired && s.Status == "active")
                        {
                            <span class="badge bg-warning-subtle">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ended</span>
                        }
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row"><span class="stock-card-label">Code</span><code>@s.AccessCode</code></div>
                        <div class="stock-card-row"><span class="stock-card-label">Started</span><span>@s.StartedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</span></div>
                        <div class="stock-card-row"><span class="stock-card-label">Ended</span><span>@(s.EndedAt?.ToLocalTime().ToString("MMM dd, h:mm tt") ?? "—")</span></div>
                    </div>
                </div>
            }
        </div>
    </div>
    }
}

@* ── End Session Confirm ── *@
<InventoryPlus.Components.ConfirmDialog
    IsVisible="showEndConfirm"
    Title="End Pilot Session"
    Message="Are you sure you want to end this session? The operator will be disconnected."
    Icon="fa-solid fa-power-off"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmEndSession"
    OnCancel="() => showEndConfirm = false" />
