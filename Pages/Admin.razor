@page "/admin"

<PageTitle>Admin Dashboard | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1>Admin Dashboard</h1>
        <p class="text-muted">Manage system users and subscription statuses.</p>
    </div>
</div>

<div class="d-flex flex-column gap-4">
    <!-- User Management Table -->
    <div class="glass-panel">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Account Management</h2>
            <div class="text-sm text-muted">Total Accounts: @Users.Count</div>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-4"><span class="spinner"></span> Loading accounts...</div>
        }
        else
        {
        <div class="table-responsive table-view">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Email Address</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created Date</th>
                    <th>Subscription Expiry</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Users.Skip((_page - 1) * PageSize).Take(PageSize))
                {
                    var isExpired = user.SubscriptionExpiresAt.HasValue && user.SubscriptionExpiresAt.Value < DateTime.UtcNow;
                    <tr style="@(!user.IsActive || isExpired ? "opacity: 0.6" : "")">
                        <td><strong>@user.Email</strong></td>
                        <td>
                            <span class="badge @(user.IsAdmin ? "bg-primary-subtle" : "bg-secondary")">
                                @(user.IsAdmin ? "Admin" : "User")
                            </span>
                        </td>
                        <td>
                            @if (!user.IsActive)
                            {
                                <span class="badge bg-danger-subtle">Deactivated</span>
                            }
                            else if (isExpired)
                            {
                                <span class="badge bg-danger-subtle">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle">Active</span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (user.SubscriptionExpiresAt.HasValue)
                            {
                                <span class="@(isExpired ? "text-danger" : "")">@user.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")</span>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditUser(user)">
                                <i class="fa-solid fa-user-pen"></i> Manage
                            </button>
                            <button class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-success") ms-2" @onclick="() => ToggleUserStatusAsync(user)">
                                <i class="fa-solid @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                @(user.IsActive ? " Deactivate" : " Activate")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <div class="card-view">
            @foreach (var user in Users.Skip((_page - 1) * PageSize).Take(PageSize))
            {
                var isExpiredCard = user.SubscriptionExpiresAt.HasValue && user.SubscriptionExpiresAt.Value < DateTime.UtcNow;
                <div class="stock-card" style="@(!user.IsActive || isExpiredCard ? "opacity: 0.7" : "")">
                    <div class="stock-card-header">
                        <span class="stock-card-name">@user.Email</span>
                        <span class="badge @(user.IsAdmin ? "bg-primary-subtle" : "bg-secondary")">@(user.IsAdmin ? "Admin" : "User")</span>
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row">
                            <span class="stock-card-label">Status</span>
                            @if (!user.IsActive)
                            {
                                <span class="badge bg-danger-subtle">Deactivated</span>
                            }
                            else if (isExpiredCard)
                            {
                                <span class="badge bg-danger-subtle">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle">Active</span>
                            }
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Created</span>
                            <span>@user.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="stock-card-row">
                            <span class="stock-card-label">Subscription</span>
                            @if (user.SubscriptionExpiresAt.HasValue)
                            {
                                <span class="@(isExpiredCard ? "text-danger" : "")">@user.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")</span>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </div>
                    </div>
                    <div class="stock-card-actions">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditUser(user)"><i class="fa-solid fa-user-pen"></i> Manage</button>
                        <button class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-success")" @onclick="() => ToggleUserStatusAsync(user)">
                            <i class="fa-solid @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                            @(user.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </div>
                </div>
            }
        </div>
        <PaginationBar Page="_page" PageSize="PageSize" TotalItems="Users.Count" OnPageChange="SetPage" />
        }
    </div>

    <!-- Invite Link Generator -->
    <div class="glass-panel">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2>Registration Invite</h2>
                <p class="text-muted text-sm">Generate a one-time registration link valid for 10 minutes.</p>
            </div>
            <button class="btn btn-primary" @onclick="GenerateInviteLink" disabled="@isGeneratingInvite">
                @if (isGeneratingInvite)
                {
                    <span class="spinner"></span> <span>Generating...</span>
                }
                else
                {
                    <i class="fa-solid fa-link me-1"></i> <span>Generate Link</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(generatedInviteUrl))
        {
            <div class="alert @(inviteExpired ? "alert-danger" : "alert-success") d-flex flex-column gap-2">
                @if (inviteExpired)
                {
                    <div><i class="fa-solid fa-clock"></i> <strong>Link expired.</strong> Generate a new one.</div>
                }
                else
                {
                    <div><i class="fa-solid fa-circle-check"></i> <strong>Invite link ready!</strong> Share this with the new user. It can only be used once.</div>
                    <div class="d-flex align-items-center gap-2">
                        <input type="text" class="form-control form-control-sm" value="@generatedInviteUrl" readonly style="font-family: monospace; font-size: 0.8rem;" />
                        <button class="btn btn-sm btn-outline-secondary flex-shrink-0" @onclick="CopyInviteLink" title="Copy link">
                            <i class="fa-solid @(inviteCopied ? "fa-check" : "fa-copy")"></i>
                        </button>
                    </div>
                    <div class="small text-muted">
                        <i class="fa-solid fa-stopwatch me-1"></i> Expires: <strong>@inviteExpiresAt?.ToString("hh:mm:ss tt")</strong>
                        @if (inviteTimeRemaining.HasValue)
                        {
                            <span class="ms-2">(@inviteTimeRemaining.Value.Minutes min @inviteTimeRemaining.Value.Seconds sec remaining)</span>
                        }
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(inviteError))
        {
            <div class="alert alert-danger">@inviteError</div>
        }
    </div>

    <!-- Invite History -->
    <div class="glass-panel">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2>Invite History</h2>
                <p class="text-muted text-sm">All generated invite links and their usage status.</p>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadInviteHistory" disabled="@isLoadingHistory">
                <i class="fa-solid @(isLoadingHistory ? "fa-spinner fa-spin" : "fa-arrows-rotate")"></i> Refresh
            </button>
        </div>

        @if (inviteHistory.Any())
        {
            <div class="table-responsive table-view">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Token</th><th>Created</th><th>Expires</th><th>Status</th><th>Used By</th></tr>
                </thead>
                <tbody>
                    @foreach (var inv in inviteHistory)
                    {
                        var expired = inv.ExpiresAt < DateTime.UtcNow;
                        <tr style="@(inv.IsUsed || expired ? "opacity: 0.6" : "")">
                            <td><code style="font-size: 0.78rem;">@inv.Token[..Math.Min(12, inv.Token.Length)]...</code></td>
                            <td>@inv.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                            <td>@inv.ExpiresAt.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                            <td>
                                @if (inv.IsUsed)
                                {
                                    <span class="badge bg-success-subtle">Used</span>
                                }
                                else if (expired)
                                {
                                    <span class="badge bg-danger-subtle">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary-subtle">Active</span>
                                }
                            </td>
                            <td>@(string.IsNullOrEmpty(inv.UsedByEmail) ? "—" : inv.UsedByEmail)</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view">
                @foreach (var inv in inviteHistory)
                {
                    var expiredCard = inv.ExpiresAt < DateTime.UtcNow;
                    <div class="stock-card" style="@(inv.IsUsed || expiredCard ? "opacity: 0.7" : "")">
                        <div class="stock-card-header">
                            <code style="font-size: 0.75rem;">@inv.Token[..Math.Min(12, inv.Token.Length)]...</code>
                            @if (inv.IsUsed)
                            {
                                <span class="badge bg-success-subtle">Used</span>
                            }
                            else if (expiredCard)
                            {
                                <span class="badge bg-danger-subtle">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-primary-subtle">Active</span>
                            }
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Created</span><span>@inv.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Expires</span><span>@inv.ExpiresAt.ToLocalTime().ToString("MMM dd, h:mm tt")</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Used By</span><span>@(string.IsNullOrEmpty(inv.UsedByEmail) ? "—" : inv.UsedByEmail)</span></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted text-center py-3">No invite links generated yet.</p>
        }
    </div>

    <!-- System Status -->
    <div class="glass-panel">
        <div class="mb-4">
            <h2>System Status</h2>
            <p class="text-muted text-sm">Real-time system health and configuration.</p>
        </div>
        
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle"></i> All services are online (Supabase, Database, Hosting).
        </div>
        
        <div class="row g-3 mt-3">
            <div class="col-12 col-md-4">
            <div class="stat-mini">
                <span class="text-muted" style="font-size: 0.75rem">Total Products</span>
                <div class="fw-bold">@AppSettings.CompanyName System</div>
            </div>
            </div>
            <div class="col-12 col-md-4">
            <div class="stat-mini">
                <span class="text-muted" style="font-size: 0.75rem">Auth Provider</span>
                <div class="fw-bold">Supabase</div>
            </div>
            </div>
            <div class="col-12 col-md-4">
            <div class="stat-mini">
                <span class="text-muted" style="font-size: 0.75rem">Currency</span>
                <div class="fw-bold">₱ (Philippine Peso)</div>
            </div>
            </div>
        </div>
    </div>
</div>

<AppModal IsOpen="showEditModal" IsOpenChanged="@((v) => { showEditModal = v; })" Size="Large">
    <Header>
        <h5 class="modal-title">Manage Account</h5>
    </Header>
    <Content>
                <p class="text-muted mb-4"><strong>@selectedUser.Email</strong></p>

                <div class="mb-3">
                    <label class="form-label">Current Subscription Expiry</label>
                    <div class="mt-1">
                        @if (selectedUser.SubscriptionExpiresAt.HasValue)
                        {
                            var expired = selectedUser.SubscriptionExpiresAt.Value < DateTime.UtcNow;
                            <span class="badge @(expired ? "bg-danger-subtle" : "bg-success-subtle")">
                                @selectedUser.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")
                                @(expired ? " (Expired)" : "")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">No subscription set</span>
                        }
                    </div>
                </div>

                <div class="mb-3 mt-4">
                    <label class="form-label">Renewal Plan</label>
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn @(selectedPlan == "1month" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => selectedPlan = "1month"'>
                            1 Month
                        </button>
                        <button class="btn @(selectedPlan == "1year" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => selectedPlan = "1year"'>
                            1 Year
                        </button>
                    </div>
                    <button class="btn btn-outline-secondary mt-2" @onclick="ApplyPlan">
                        <i class="fa-solid fa-calendar-plus"></i> Apply Plan
                    </button>
                    @if (selectedUser.SubscriptionExpiresAt.HasValue)
                    {
                        <p class="text-muted text-xs mt-1">New expiry: <strong>@selectedUser.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")</strong></p>
                    }
                </div>

                <div class="row g-3 mt-3">
                    <div class="col-6">
                        <label class="form-label">User Role</label>
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <input type="checkbox" class="form-check-input" id="isAdmin" @bind="selectedUser.IsAdmin" />
                            <label for="isAdmin">Administrator</label>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Account Status</label>
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <input type="checkbox" class="form-check-input" id="isActive" @bind="selectedUser.IsActive" />
                            <label for="isActive">Account is Active</label>
                        </div>
                    </div>
                </div>
    </Content>
    <Footer>
                <button class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveUserAsync" disabled="@isSaving">
                    @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> }
                    Save Changes
                </button>
    </Footer>
</AppModal>
