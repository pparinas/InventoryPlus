@page "/admin"

<PageTitle>Admin Dashboard | @AppSettings.CompanyName</PageTitle>

<div class="section-gap fade-in">
    <div class="page-header">
        <div>
            <h1>Admin</h1>
            <p>Manage users and invite tokens.</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary" @onclick="GenerateInviteLink" disabled="@isGeneratingInvite"><i class="fa-solid fa-user-plus"></i> Invite User</button>
        </div>
    </div>

    @* ── Users ── *@
    <div class="card card-p">
        <div class="card-title"><i class="fa-solid fa-users"></i> Users</div>

        @if (isLoading)
        {
            <div style="text-align:center;padding:20px;color:var(--fg3)"><i class="fa-solid fa-spinner fa-spin"></i> Loading accounts...</div>
        }
        else
        {
        <div style="display:flex;flex-direction:column;gap:7px">
            @foreach (var user in Users.Skip((_page - 1) * PageSize).Take(PageSize))
            {
                <div class="admin-user-card" style="@(!user.IsActive ? "opacity:0.6" : "")">
                    <div style="width:34px;height:34px;border-radius:50%;background:@(user.IsAdmin ? "var(--lime)" : "var(--bg4)");display:flex;align-items:center;justify-content:center;color:@(user.IsAdmin ? "#0a0a0a" : "var(--fg2)");font-size:11px;font-weight:700;flex-shrink:0;font-family:'Space Mono',monospace">
                        @(user.Email.Length >= 2 ? user.Email[..2].ToUpper() : "??")
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-weight:700;font-size:12px">@user.Email</div>
                        <div style="font-size:10px;color:var(--fg3)">Created @user.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div style="display:flex;gap:5px;align-items:center">
                        @if (user.IsAdmin)
                        {
                            <span class="badge badge-lime">Admin</span>
                        }
                        <span class="badge @(user.IsActive ? "badge-green" : "badge-red")">@(user.IsActive ? "Active" : "Inactive")</span>
                        <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => EditUser(user)"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            }
        </div>
        <PaginationBar Page="_page" PageSize="PageSize" TotalItems="Users.Count" OnPageChange="SetPage" />
        }
    </div>

    @* ── Invite Token Generator ── *@
    <div class="card card-p">
        <div class="card-title"><i class="fa-solid fa-ticket"></i> Invite Tokens</div>

        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
            <select class="form-control" @bind="inviteExpiryHours" style="width:auto;font-size:11px">
                <option value="1">1 hour</option>
                <option value="6">6 hours</option>
                <option value="12">12 hours</option>
                <option value="24">24 hours</option>
                <option value="48">48 hours</option>
                <option value="72">72 hours</option>
            </select>
            <button class="btn btn-primary btn-sm" @onclick="GenerateInviteLink" disabled="@isGeneratingInvite">
                @if (isGeneratingInvite)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i> <text>Generating...</text>
                }
                else
                {
                    <i class="fa-solid fa-ticket"></i> <text>Generate</text>
                }
            </button>
            <button class="btn btn-ghost btn-sm btn-icon" @onclick="LoadInviteHistory" disabled="@isLoadingHistory" title="Refresh">
                <i class="fa-solid @(isLoadingHistory ? "fa-spinner fa-spin" : "fa-arrows-rotate")"></i>
            </button>
        </div>

        @if (!string.IsNullOrEmpty(generatedInviteUrl))
        {
            <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:10px">
                @if (inviteExpired)
                {
                    <div style="font-size:11px;color:var(--red)"><i class="fa-solid fa-clock"></i> Link expired. Generate a new one.</div>
                }
                else
                {
                    <div style="font-size:11px;color:var(--green);margin-bottom:6px"><i class="fa-solid fa-circle-check"></i> Invite link ready! Share with the new user (one-time use).</div>
                    <div style="display:flex;align-items:center;gap:5px">
                        <input class="form-control" value="@generatedInviteUrl" readonly style="font-family:'Space Mono',monospace;font-size:10px" />
                        <button class="btn btn-ghost btn-sm btn-icon" @onclick="CopyInviteLink" title="Copy">
                            <i class="fa-solid @(inviteCopied ? "fa-check" : "fa-copy")"></i>
                        </button>
                    </div>
                    <div style="font-size:10px;color:var(--fg3);margin-top:5px">
                        <i class="fa-solid fa-stopwatch"></i> Expires: <strong>@inviteExpiresAt?.ToString("MMM dd, hh:mm tt")</strong>
                        @if (inviteTimeRemaining.HasValue)
                        {
                            @if (inviteTimeRemaining.Value.TotalHours >= 1)
                            {
                                <span> (@((int)inviteTimeRemaining.Value.TotalHours)h @inviteTimeRemaining.Value.Minutes min remaining)</span>
                            }
                            else
                            {
                                <span> (@inviteTimeRemaining.Value.Minutes min @inviteTimeRemaining.Value.Seconds sec remaining)</span>
                            }
                        }
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(inviteError))
        {
            <div style="background:var(--red);color:#fff;border-radius:var(--radius-sm);padding:8px 12px;font-size:11px;margin-bottom:10px">@inviteError</div>
        }

        @if (inviteHistory.Any())
        {
            <div class="table-wrap">
                <table>
                    <thead><tr><th>Token</th><th>Created</th><th>Expires</th><th>Status</th><th>Used By</th></tr></thead>
                    <tbody>
                        @foreach (var inv in inviteHistory)
                        {
                            var expired = inv.ExpiresAt < DateTime.UtcNow;
                            <tr style="@(inv.IsUsed || expired ? "opacity:0.6" : "")">
                                <td class="mono" style="font-size:10px;color:var(--fg3)">@inv.Token[..Math.Min(12, inv.Token.Length)]…</td>
                                <td style="font-size:10px;color:var(--fg3)">@inv.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                                <td style="font-size:10px;color:var(--fg3)">@inv.ExpiresAt.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                                <td>
                                    @if (inv.IsUsed)
                                    {
                                        <span class="badge badge-green">Used</span>
                                    }
                                    else if (expired)
                                    {
                                        <span class="badge badge-red">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-lime">Active</span>
                                    }
                                </td>
                                <td style="font-size:11px">@(string.IsNullOrEmpty(inv.UsedByEmail) ? "—" : inv.UsedByEmail)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state" style="padding:24px">
                <i class="fa-solid fa-ticket" style="font-size:22px;opacity:.25"></i>
                <h4>No invite tokens</h4>
                <p>Generate a token to invite new users</p>
            </div>
        }
    </div>

    @* ── System Status ── *@
    <div class="card card-p">
        <div class="card-title"><i class="fa-solid fa-server"></i> System Status</div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 12px;font-size:11px;color:var(--green);margin-bottom:10px">
            <i class="fa-solid fa-check-circle"></i> All services are online (Supabase, Database, Hosting).
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:9px">
            <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                <div class="stat-card-icon si-lime"><i class="fa-solid fa-building"></i></div>
                <div>
                    <div class="stat-card-value" style="font-size:12px">@AppSettings.CompanyName</div>
                    <div class="stat-card-label">System</div>
                </div>
            </div>
            <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                <div class="stat-card-icon si-green"><i class="fa-solid fa-shield-halved"></i></div>
                <div>
                    <div class="stat-card-value" style="font-size:12px">Supabase</div>
                    <div class="stat-card-label">Auth Provider</div>
                </div>
            </div>
            <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                <div class="stat-card-icon si-amber"><i class="fa-solid fa-peso-sign"></i></div>
                <div>
                    <div class="stat-card-value" style="font-size:12px">₱ PHP</div>
                    <div class="stat-card-label">Currency</div>
                </div>
            </div>
        </div>
    </div>
</div>

<AppModal IsOpen="showEditModal" IsOpenChanged="@((v) => { showEditModal = v; })" Size="Large">
    <Header>
        <h5>Manage Account</h5>
    </Header>
    <Content>
        <p style="color:var(--fg2);margin-bottom:12px"><strong>@selectedUser.Email</strong></p>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">User Role</label>
                <div style="display:flex;gap:5px">
                    <button class="btn @(selectedUser.IsAdmin ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => selectedUser.IsAdmin = true">Admin</button>
                    <button class="btn @(!selectedUser.IsAdmin ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => selectedUser.IsAdmin = false">User</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Account Status</label>
                <div style="display:flex;gap:5px">
                    <button class="btn @(selectedUser.IsActive ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => selectedUser.IsActive = true">Active</button>
                    <button class="btn @(!selectedUser.IsActive ? "btn-danger" : "btn-ghost") btn-sm" style="flex:1;justify-content:center" @onclick="() => selectedUser.IsActive = false">Inactive</button>
                </div>
            </div>
        </div>
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveUserAsync" disabled="@isSaving">
            @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> }
            Save Changes
        </button>
    </Footer>
</AppModal>
