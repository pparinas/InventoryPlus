@page "/admin"


<PageTitle>Admin Dashboard | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1>Admin Dashboard</h1>
        <p class="text-muted">Manage system users and subscription statuses.</p>
    </div>
</div>

<div class="grid grid-cols-1 gap-6">
    <!-- User Management Table -->
    <div class="glass-panel">
        <div class="flex justify-between items-center mb-4">
            <h2>Account Management</h2>
            <div class="text-sm text-muted">Total Accounts: @Users.Count</div>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-4"><span class="spinner"></span> Loading accounts...</div>
        }
        else
        {
        <table>
            <thead>
                <tr>
                    <th>Email Address</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created Date</th>
                    <th>Subscription Expiry</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Users)
                {
                    var isExpired = user.SubscriptionExpiresAt.HasValue && user.SubscriptionExpiresAt.Value < DateTime.UtcNow;
                    <tr style="@(!user.IsActive || isExpired ? "opacity: 0.6" : "")">
                        <td><strong>@user.Email</strong></td>
                        <td>
                            <span class="badge @(user.IsAdmin ? "badge-primary" : "badge-secondary")">
                                @(user.IsAdmin ? "Admin" : "User")
                            </span>
                        </td>
                        <td>
                            @if (!user.IsActive)
                            {
                                <span class="badge badge-danger">Deactivated</span>
                            }
                            else if (isExpired)
                            {
                                <span class="badge badge-danger">Expired</span>
                            }
                            else
                            {
                                <span class="badge badge-success">Active</span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (user.SubscriptionExpiresAt.HasValue)
                            {
                                <span class="@(isExpired ? "text-danger" : "")">@user.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")</span>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-secondary" @onclick="() => EditUser(user)">
                                <i class="fa-solid fa-user-pen"></i> Manage
                            </button>
                            <button class="btn btn-sm @(user.IsActive ? "btn-danger" : "btn-success") ml-2" @onclick="() => ToggleUserStatusAsync(user)">
                                <i class="fa-solid @(user.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                @(user.IsActive ? " Deactivate" : " Activate")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
    </div>

    <!-- System Status -->
    <div class="glass-panel">
        <div class="mb-4">
            <h2>System Status</h2>
            <p class="text-muted text-sm">Real-time system health and configuration.</p>
        </div>
        
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle"></i> All services are online (Supabase, Database, Hosting).
        </div>
        
        <div class="grid grid-cols-3 gap-4 mt-4">
            <div class="stat-mini">
                <span class="text-muted text-xs">Total Products</span>
                <div class="font-bold">@AppSettings.CompanyName System</div>
            </div>
            <div class="stat-mini">
                <span class="text-muted text-xs">Auth Provider</span>
                <div class="font-bold">Supabase</div>
            </div>
            <div class="stat-mini">
                <span class="text-muted text-xs">Currency</span>
                <div class="font-bold">₱ (Philippine Peso)</div>
            </div>
        </div>
    </div>
</div>

@if (showEditModal)
{
    <div class="modal-overlay">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Manage Account</h3>
                <button class="btn-close" @onclick="CloseModal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-4"><strong>@selectedUser.Email</strong></p>

                <div class="form-group">
                    <label>Current Subscription Expiry</label>
                    <div class="mt-1">
                        @if (selectedUser.SubscriptionExpiresAt.HasValue)
                        {
                            var expired = selectedUser.SubscriptionExpiresAt.Value < DateTime.UtcNow;
                            <span class="badge @(expired ? "badge-danger" : "badge-success")">
                                @selectedUser.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")
                                @(expired ? " (Expired)" : "")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">No subscription set</span>
                        }
                    </div>
                </div>

                <div class="form-group mt-4">
                    <label>Renewal Plan</label>
                    <div class="flex gap-2 mt-2">
                        <button class="btn @(selectedPlan == "1month" ? "btn-primary" : "btn-secondary")" @onclick='() => selectedPlan = "1month"'>
                            1 Month
                        </button>
                        <button class="btn @(selectedPlan == "1year" ? "btn-primary" : "btn-secondary")" @onclick='() => selectedPlan = "1year"'>
                            1 Year
                        </button>
                    </div>
                    <button class="btn btn-secondary mt-2" @onclick="ApplyPlan">
                        <i class="fa-solid fa-calendar-plus"></i> Apply Plan
                    </button>
                    @if (selectedUser.SubscriptionExpiresAt.HasValue)
                    {
                        <p class="text-muted text-xs mt-1">New expiry: <strong>@selectedUser.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")</strong></p>
                    }
                </div>

                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div class="form-group">
                        <label>User Role</label>
                        <div class="flex items-center gap-2 mt-2">
                            <input type="checkbox" id="isAdmin" @bind="selectedUser.IsAdmin" />
                            <label for="isAdmin">Administrator</label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Account Status</label>
                        <div class="flex items-center gap-2 mt-2">
                            <input type="checkbox" id="isActive" @bind="selectedUser.IsActive" />
                            <label for="isActive">Account is Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveUserAsync" disabled="@isSaving">
                    @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> }
                    Save Changes
                </button>
            </div>
        </div>
    </div>
}
