@page "/register"
@layout InventoryPlus.Layout.AuthLayout
@attribute [AllowAnonymous]


<div class="auth-wrap" @onkeydown="HandleKeyDown">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="mark"><span>N</span></div>
            <h2>Create Account</h2>
            <p>Join @AppSettings.CompanyName — it's free!</p>
        </div>

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success">@SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="mb-3">
            <label for="username" class="form-label small fw-medium text-muted">Display Name</label>
            <input id="username" type="text" @bind="Username" class="form-control" placeholder="Your name or business name" />
        </div>

        <div class="mb-3">
            <label for="email" class="form-label small fw-medium text-muted">Email</label>
            <input id="email" type="email" @bind="Email" class="form-control" placeholder="you@example.com" />
        </div>

        <div class="mb-3">
            <label for="password" class="form-label small fw-medium text-muted">Password</label>
            <input id="password" type="password" @bind="Password" class="form-control" placeholder="Min 6 characters" />
            @if (!string.IsNullOrEmpty(Password) && Password.Length < 6)
            {
                <small class="text-danger">Password must be at least 6 characters</small>
            }
        </div>

        <div class="mb-3">
            <label for="confirmPassword" class="form-label small fw-medium text-muted">Confirm Password</label>
            <input id="confirmPassword" type="password" @bind="ConfirmPassword" class="form-control" placeholder="Repeat your password" />
            @if (!string.IsNullOrEmpty(ConfirmPassword) && Password != ConfirmPassword)
            {
                <small class="text-danger">Passwords do not match</small>
            }
        </div>

        <button @onclick="HandleRegister" class="btn btn-primary w-100" disabled="@(IsLoading || !string.IsNullOrEmpty(SuccessMessage))">
            @if (IsLoading)
            {
                <span class="spinner"></span> <span>Creating account...</span>
            }
            else
            {
                <i class="fa-solid fa-user-plus me-1"></i> <span>Create Account</span>
            }
        </button>

        <div class="text-center mt-3" style="font-size:12px;color:var(--fg3);">
            <p>Already have an account? <a href="login" class="auth-link">Sign in</a></p>
        </div>
    </div>
</div>

