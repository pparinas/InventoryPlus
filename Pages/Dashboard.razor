@page "/dashboard"

<PageTitle>Dashboard | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="text-muted">Welcome back! Here's your inventory overview.</p>
    </div>
    <div class="flex gap-2">
        <button class="btn btn-secondary" @onclick="Refresh"><i class="fa-solid fa-rotate-right"></i> Refresh</button>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("sales")'><i class="fa-solid fa-plus"></i> New Sale</button>
    </div>
</div>

<div class="grid grid-cols-4 mb-4">
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-primary">
            <i class="fa-solid fa-boxes-stacked"></i>
        </div>
        <div class="stat-content">
            <h3>@Inventory.Products.Count</h3>
            <p>Products</p>
        </div>
    </div>
    
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-success">
            <i class="fa-solid fa-wallet"></i>
        </div>
        <div class="stat-content">
            <h3>₱@TotalRevenue.ToString("0.00")</h3>
            <p>Revenue</p>
        </div>
    </div>
    
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-accent">
            <i class="fa-solid fa-chart-pie"></i>
        </div>
        <div class="stat-content">
            <h3>₱@TotalProfit.ToString("0.00")</h3>
            <p>Profit</p>
        </div>
    </div>
    
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div class="stat-content">
            <h3>@LowStockIngredients.Count</h3>
            <p>Low Stock</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-2">
    <!-- Top Selling Products -->
    <div class="glass-panel">
        <div class="flex justify-between items-center mb-4">
            <h2>Recent Sales</h2>
            <button class="btn btn-sm btn-secondary" @onclick='() => Nav.NavigateTo("reports")'>View All</button>
        </div>
        @if (RecentSales.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Total</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in RecentSales)
                    {
                        <tr>
                            <td>@sale.ProductName</td>
                            <td>@sale.QuantitySold</td>
                            <td class="text-success">₱@sale.TotalAmount.ToString("0.00")</td>
                            <td class="text-muted">@sale.Date.ToShortTimeString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center text-muted mt-4 mb-4">
                <i class="fa-solid fa-receipt fa-3x mb-2" style="opacity: 0.2"></i>
                <p>No sales recorded yet.</p>
            </div>
        }
    </div>

    <!-- Low Stock Alerts -->
    <div class="glass-panel">
        <div class="flex justify-between items-center mb-4">
            <h2>Low Stock Ingredients</h2>
            <button class="btn btn-sm btn-secondary" @onclick='() => Nav.NavigateTo("ingredients")'>Manage</button>
        </div>
        
        @if (LowStockIngredients.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Ingredient</th>
                        <th>Current Stock</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ing in LowStockIngredients)
                    {
                        <tr>
                            <td>@ing.Name</td>
                            <td>@ing.Stock @ing.Unit</td>
                            <td>
                                @if(ing.Stock <= 0) {
                                    <span class="badge badge-danger">Out of Stock</span>
                                } else {
                                    <span class="badge badge-warning">Low</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center text-muted mt-4 mb-4">
                <i class="fa-solid fa-check-circle fa-3x mb-2 text-success" style="opacity: 0.5"></i>
                <p>All ingredients are well-stocked.</p>
            </div>
        }
    </div>
</div>

