@page "/dashboard"

<PageTitle>Dashboard | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="text-muted">Welcome back! Here's your business overview.</p>
    </div>
    <div class="flex gap-2 flex-wrap">
        <select class="form-control" style="width:auto;display:inline-block" @bind="timeRange" @bind:after="Refresh">
            <option value="today">Today</option>
            <option value="7d">Last 7 Days</option>
            <option value="30d">Last 30 Days</option>
            <option value="all">All Time</option>
        </select>
        <button class="btn btn-secondary" @onclick="Refresh"><i class="fa-solid fa-rotate-right"></i><span class="hide-mobile"> Refresh</span></button>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("sales")'><i class="fa-solid fa-plus"></i><span class="hide-mobile"> New Sale</span></button>
    </div>
</div>

@* ── Today's Snapshot ── *@
@if (AppSettings.ShowTodaySnapshot)
{
<div class="grid grid-cols-4 mb-4">
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-primary"><i class="fa-solid fa-boxes-stacked"></i></div>
        <div class="stat-content"><h3>@Inventory.ActiveProducts.Count()</h3><p>Products</p></div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-success"><i class="fa-solid fa-wallet"></i></div>
        <div class="stat-content"><h3>₱@FilteredRevenue.ToString("N2")</h3><p>Revenue</p></div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-accent"><i class="fa-solid fa-chart-pie"></i></div>
        <div class="stat-content"><h3>₱@FilteredProfit.ToString("N2")</h3><p>Profit</p></div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon stat-warning"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div class="stat-content"><h3>@LowStockIngredients.Count</h3><p>Low Stock</p></div>
    </div>
</div>
}

<div class="grid grid-cols-2 mb-4">
    @* ── Revenue Chart (CSS bar chart) ── *@
    @if (AppSettings.ShowRevenueChart)
    {
    <div class="glass-panel">
        <h2 class="mb-4"><i class="fa-solid fa-chart-bar text-primary"></i> Revenue Trend</h2>
        @if (DailyRevenue.Any())
        {
            <div class="dashboard-chart">
                @{ var maxRev = DailyRevenue.Max(d => d.Value); }
                @foreach (var day in DailyRevenue)
                {
                    var pct = maxRev > 0 ? (day.Value / maxRev * 100) : 0;
                    <div class="chart-bar-group">
                        <div class="chart-bar" style="height:@pct.ToString("0")%;" title="₱@day.Value.ToString("N2")"></div>
                        <span class="chart-label">@day.Key</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-chart-bar" Title="No revenue data" Message="Sales data will appear here." />
        }
    </div>
    }

    @* ── Top Products ── *@
    @if (AppSettings.ShowTopProducts)
    {
    <div class="glass-panel">
        <h2 class="mb-4"><i class="fa-solid fa-trophy text-warning"></i> Top Products</h2>
        @if (TopProducts.Any())
        {
            <div class="top-products-list">
                @{ var topMax = TopProducts.First().Value; }
                @foreach (var tp in TopProducts)
                {
                    var barPct = topMax > 0 ? ((double)tp.Value / topMax * 100) : 0;
                    <div class="top-product-row">
                        <span class="top-product-name">@tp.Key</span>
                        <div class="top-product-bar-track">
                            <div class="top-product-bar" style="width:@barPct.ToString("0")%"></div>
                        </div>
                        <span class="top-product-count">@tp.Value sold</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-trophy" Title="No sales yet" Message="Top products will appear after your first sale." />
        }
    </div>
    }
</div>

<div class="grid grid-cols-2 mb-4">
    @* ── Payment Breakdown ── *@
    @if (AppSettings.ShowPaymentBreakdown)
    {
    <div class="glass-panel">
        <h2 class="mb-4"><i class="fa-solid fa-credit-card text-accent"></i> Payment Methods</h2>
        @if (PaymentBreakdown.Any())
        {
            <div class="payment-breakdown">
                @{ var totalPay = PaymentBreakdown.Values.Sum(); }
                @foreach (var pm in PaymentBreakdown)
                {
                    var pct = totalPay > 0 ? (pm.Value / totalPay * 100) : 0;
                    <div class="payment-row">
                        <div class="payment-label">
                            <i class="@GetPaymentIcon(pm.Key)"></i>
                            <span>@pm.Key</span>
                        </div>
                        <div class="payment-bar-track">
                            <div class="payment-bar" style="width:@pct.ToString("0")%"></div>
                        </div>
                        <span class="payment-amount">₱@pm.Value.ToString("N2") (@pct.ToString("0")%)</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-credit-card" Title="No payments yet" Message="Payment breakdown will appear here." />
        }
    </div>
    }

    @* ── Profit Trend ── *@
    @if (AppSettings.ShowProfitTrend)
    {
    <div class="glass-panel">
        <h2 class="mb-4"><i class="fa-solid fa-arrow-trend-up text-success"></i> Profit Trend</h2>
        @if (DailyProfit.Any())
        {
            <div class="dashboard-chart">
                @{ var maxProf = DailyProfit.Max(d => Math.Abs(d.Value)); if (maxProf == 0) maxProf = 1; }
                @foreach (var day in DailyProfit)
                {
                    var pct = maxProf > 0 ? (Math.Abs(day.Value) / maxProf * 100) : 0;
                    var barClass = day.Value >= 0 ? "chart-bar" : "chart-bar chart-bar-negative";
                    <div class="chart-bar-group">
                        <div class="@barClass" style="height:@pct.ToString("0")%;" title="₱@day.Value.ToString("N2")"></div>
                        <span class="chart-label">@day.Key</span>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-arrow-trend-up" Title="No profit data" Message="Profit trend will appear after sales." />
        }
    </div>
    }
</div>

<div class="grid grid-cols-2 mb-4">
    @* ── Recent Sales ── *@
    @if (AppSettings.ShowRecentSales)
    {
    <div class="glass-panel">
        <div class="flex justify-between items-center mb-4">
            <h2><i class="fa-solid fa-receipt text-primary"></i> Recent Sales</h2>
            <button class="btn btn-sm btn-secondary" @onclick='() => Nav.NavigateTo("reports")'>View All</button>
        </div>
        @if (RecentSales.Any())
        {
            <div class="table-responsive table-view">
            <table>
                <thead><tr><th>Product</th><th>Qty</th><th>Total</th><th>Time</th></tr></thead>
                <tbody>
                    @foreach (var sale in RecentSales)
                    {
                        <tr>
                            <td>@sale.ProductName</td>
                            <td>@sale.QuantitySold</td>
                            <td class="text-success">₱@sale.TotalAmount.ToString("N2")</td>
                            <td class="text-muted">@sale.Date.ToString("MMM dd h:mm tt")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view">
                @foreach (var sale in RecentSales)
                {
                    <div class="stock-card">
                        <div class="stock-card-header">
                            <span class="stock-card-name">@sale.ProductName</span>
                            <span class="text-success font-bold">₱@sale.TotalAmount.ToString("N2")</span>
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Qty</span><span>@sale.QuantitySold</span></div>
                            <div class="stock-card-row"><span class="stock-card-label">Time</span><span class="text-muted">@sale.Date.ToString("h:mm tt")</span></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-receipt" Title="No sales yet" Message="Sales will appear here after your first transaction." />
        }
    </div>
    }

    @* ── Low Stock ── *@
    @if (AppSettings.ShowLowStock)
    {
    <div class="glass-panel">
        <div class="flex justify-between items-center mb-4">
            <h2><i class="fa-solid fa-triangle-exclamation text-warning"></i> Low Stock Alerts</h2>
            <button class="btn btn-sm btn-secondary" @onclick='() => Nav.NavigateTo("stocks")'>Manage</button>
        </div>
        @if (LowStockIngredients.Any())
        {
            <div class="table-responsive table-view">
            <table>
                <thead><tr><th>Item</th><th>Stock</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var ing in LowStockIngredients)
                    {
                        <tr>
                            <td>@ing.Name</td>
                            <td>@ing.Stock @ing.Unit</td>
                            <td>
                                @if(ing.Stock <= 0) { <span class="badge badge-danger">Out</span> }
                                else { <span class="badge badge-warning">Low</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
            <div class="card-view">
                @foreach (var ing in LowStockIngredients)
                {
                    <div class="stock-card">
                        <div class="stock-card-header">
                            <span class="stock-card-name">@ing.Name</span>
                            @if (ing.Stock <= 0) { <span class="badge badge-danger">Out</span> }
                            else { <span class="badge badge-warning">Low</span> }
                        </div>
                        <div class="stock-card-body">
                            <div class="stock-card-row"><span class="stock-card-label">Stock</span><span>@ing.Stock @ing.Unit</span></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <InventoryPlus.Components.EmptyState Icon="fa-solid fa-check-circle" Title="All stocked" Message="No low stock items!" />
        }
    </div>
    }
</div>

@* ── Quick Actions ── *@
@if (AppSettings.ShowQuickActions)
{
<div class="glass-panel mb-4">
    <h2 class="mb-4"><i class="fa-solid fa-bolt text-warning"></i> Quick Actions</h2>
    <div class="quick-actions-grid">
        <button class="quick-action-btn" @onclick='() => Nav.NavigateTo("sales")'>
            <i class="fa-solid fa-cart-shopping"></i><span>New Sale</span>
        </button>
        <button class="quick-action-btn" @onclick='() => Nav.NavigateTo("products")'>
            <i class="fa-solid fa-plus-circle"></i><span>Add Product</span>
        </button>
        <button class="quick-action-btn" @onclick='() => Nav.NavigateTo("stocks")'>
            <i class="fa-solid fa-boxes-stacked"></i><span>Restock</span>
        </button>
        <button class="quick-action-btn" @onclick='() => Nav.NavigateTo("reports")'>
            <i class="fa-solid fa-file-lines"></i><span>Reports</span>
        </button>
        <button class="quick-action-btn" @onclick='() => Nav.NavigateTo("settings")'>
            <i class="fa-solid fa-gear"></i><span>Settings</span>
        </button>
    </div>
</div>
}