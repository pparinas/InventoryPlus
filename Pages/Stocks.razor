@page "/stocks"
<PageTitle>Stocks | @AppSettings.CompanyName</PageTitle>

@if (Inventory.IsLoading)
{
    <div class="card card-p" style="padding:3rem">
        <i class="fa-solid fa-spinner fa-spin fa-2x" style="color:var(--fg3)"></i>
        <p style="color:var(--fg3);margin-top:1rem">Loading stock data...</p>
    </div>
}
else
{

<div class="section-gap fade-in">
    <div class="page-header">
        <div>
            <h1>Inventory</h1>
            <p>Manage your raw materials and shop necessities.</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i> Add Item</button>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:9px">
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-lime"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">@Inventory.ActiveIngredients.Count()</div>
                <div class="stat-card-label">Total Items</div>
            </div>
        </div>
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-green"><i class="fa-solid fa-peso-sign"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">₱@AppSettings.FormatCurrency(Inventory.ActiveIngredients.Sum(i => i.Stock * i.CostPerUnit))</div>
                <div class="stat-card-label">Total Value</div>
            </div>
        </div>
        <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:10px">
            <div class="stat-card-icon si-amber"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div>
                <div class="stat-card-value" style="font-size:16px">@Inventory.ActiveIngredients.Count(i => i.Stock <= i.LowStockThreshold)</div>
                <div class="stat-card-label">Low Stock</div>
            </div>
        </div>
    </div>

    <div class="filter-bar">
        <input class="form-control search-input" placeholder="Search stocks…" @bind="searchQuery" @bind:event="oninput" />
        <div class="pill-group">
            <button class="pill @(typeFilter == "All" ? "active" : "")" @onclick='() => typeFilter = "All"'>All</button>
            <button class="pill @(typeFilter == "Ingredient" ? "active" : "")" @onclick='() => typeFilter = "Ingredient"'>Ingredient</button>
            <button class="pill @(typeFilter == "Necessity" ? "active" : "")" @onclick='() => typeFilter = "Necessity"'>Necessity</button>
        </div>
    </div>

    <div class="card" style="overflow:hidden">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Type</th>
                        <th>Stock</th>
                        <th>Cost/Unit</th>
                        <th>Total Value</th>
                        <th style="text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredItems.Skip((_page - 1) * PageSize).Take(PageSize))
                    {
                        <tr>
                            <td style="font-weight:600">@item.Name</td>
                            <td><span class="badge @(item.Type == "Ingredient" ? "badge-lime" : "badge-gray")">@item.Type</span></td>
                            <td class="@(item.Stock <= item.LowStockThreshold ? "text-amber fw-700" : "")">
                                <span class="mono">@item.Stock @item.Unit</span>
                                @if (item.Stock <= item.LowStockThreshold)
                                {
                                    <span class="badge badge-amber" style="margin-left:5px">Low</span>
                                }
                            </td>
                            <td class="mono" style="color:var(--fg2);font-size:11px">₱@AppSettings.FormatCurrency(item.CostPerUnit)/@item.Unit</td>
                            <td class="mono text-lime" style="font-weight:700">₱@AppSettings.FormatCurrency(item.Stock * item.CostPerUnit)</td>
                            <td>
                                <div style="display:flex;gap:4px;justify-content:flex-end">
                                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-danger btn-sm btn-icon" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!FilteredItems.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;color:var(--fg3);padding:3rem">No stock items found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <PaginationBar Page="_page" PageSize="PageSize" TotalItems="FilteredItems.Count()" OnPageChange="SetPage" />
</div>

}

<AppModal IsOpen="showModal" IsOpenChanged="@((v) => { showModal = v; })" Size="Large">
    <Header>
        <h5>@(isEditing ? "Edit Stock Item" : "New Stock Item")</h5>
    </Header>
    <Content>
        <div class="form-group">
            <label class="form-label">Item Name</label>
            <input class="form-control" @bind="currentIngredient.Name" placeholder="e.g. Coffee Beans" />
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Unit Category</label>
                <select class="form-control" value="@_selectedUnitCategory" @onchange="OnUnitCategoryChanged">
                    @foreach (var cat in InventoryPlus.Services.UnitConverter.AllCategories)
                    {
                        <option value="@cat">@InventoryPlus.Services.UnitConverter.CategoryLabel(cat)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Unit</label>
                @if (_selectedUnitCategory == InventoryPlus.Services.UnitCategory.Custom)
                {
                    <input class="form-control" @bind="currentIngredient.Unit" placeholder="e.g. bar, slab" />
                }
                else
                {
                    <select class="form-control" @bind="currentIngredient.Unit">
                        @foreach (var u in InventoryPlus.Services.UnitConverter.GetUnitsForCategory(_selectedUnitCategory))
                        {
                            <option value="@u">@u</option>
                        }
                    </select>
                }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Type</label>
                <select class="form-control" @bind="currentIngredient.Type">
                    <option value="Ingredient">Ingredient</option>
                    <option value="Necessity">Necessity</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Low Stock Alert</label>
                <input class="form-control" type="number" step="0.1" @bind="currentIngredient.LowStockThreshold" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Current Stock</label>
                <input class="form-control" type="number" step="0.1" @bind="currentIngredient.Stock" />
            </div>
            <div class="form-group">
                <label class="form-label">Cost per Unit (₱)</label>
                <input class="form-control" type="number" step="0.01" @bind="currentIngredient.CostPerUnit" />
            </div>
        </div>

        @if (isEditing && _originalUnit != currentIngredient.Unit && currentIngredient.Stock > 0)
        {
            <div style="background:var(--amber);color:#000;border-radius:var(--radius-sm);padding:8px 12px;margin-top:8px;font-size:11px">
                <i class="fa-solid fa-triangle-exclamation"></i>
                Unit changed from <strong>@_originalUnit</strong> to <strong>@currentIngredient.Unit</strong>.
                Make sure your stock quantity (@currentIngredient.Stock) is correct for the new unit.
            </div>
        }
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
        <button class="btn btn-primary" @onclick="Save">Save Item</button>
    </Footer>
</AppModal>

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Stock Item"
    Message="@($"Are you sure you want to delete \"{deleteTarget?.Name}\"? This cannot be undone.")"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ExecuteDelete"
    OnCancel="() => showDeleteConfirm = false" />

<InventoryPlus.Components.PinPrompt
    IsVisible="showPinPrompt"
    IsVisibleChanged="@((v) => showPinPrompt = v)"
    OnVerified="OnPinVerified" />
