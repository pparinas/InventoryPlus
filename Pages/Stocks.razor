@page "/stocks"
<PageTitle>Stocks | @AppSettings.CompanyName</PageTitle>

@if (Inventory.IsLoading)
{
    <div class="glass-panel text-center" style="padding: 3rem">
        <i class="fa-solid fa-spinner fa-spin fa-2x text-muted"></i>
        <p class="text-muted mt-4">Loading stock data...</p>
    </div>
}
else
{

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <h1>Stocks</h1>
        <p class="text-muted mb-0">Manage your raw materials and shop necessities.</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i><span class="d-none d-sm-inline"> Add Stock Item</span></button>
</div>

<div class="glass-panel mb-4" style="padding:0.75rem 1rem">
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <div class="flex-grow-1" style="min-width:180px">
            <input type="text" class="form-control" placeholder="Search stocks..." @bind="searchQuery" @bind:event="oninput" />
        </div>
        <select class="form-select" style="width:auto" @bind="typeFilter">
            <option value="All">All Types</option>
            <option value="Ingredient">Ingredients</option>
            <option value="Necessity">Necessities</option>
        </select>
        <select class="form-select" style="width:auto" @bind="sortBy">
            <option value="name">Name</option>
            <option value="stock">Stock (Low first)</option>
            <option value="value">Value (High first)</option>
        </select>
    </div>
</div>

<div class="glass-panel">

    @* Desktop table *@
    <div class="table-responsive table-view">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Item Name</th>
                <th>Type</th>
                <th>Current Stock</th>
                <th>Cost/Unit</th>
                <th>Total Value</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in FilteredItems.Skip((_page - 1) * PageSize).Take(PageSize))
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td>
                        <span class="badge @(item.Type == "Ingredient" ? "bg-primary-subtle" : "bg-secondary")">
                            @item.Type
                        </span>
                    </td>
                    <td>
                        @if (item.Stock < 5 && item.Type == "Ingredient")
                        {
                            <span class="text-warning fw-bold">@item.Stock @item.Unit (Low)</span>
                        }
                        else
                        {
                            <span>@item.Stock @item.Unit</span>
                        }
                    </td>
                    <td>₱@item.CostPerUnit.ToString("N2")</td>
                    <td style="color: var(--primary)">₱@((item.Stock * item.CostPerUnit).ToString("N2"))</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            }
            @if (!FilteredItems.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted" style="padding: 3rem">No stock items found.</td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    @* Mobile card list *@
    <div class="card-view">
        @if (!FilteredItems.Any())
        {
            <p class="text-center text-muted" style="padding: 2rem 0">No stock items found.</p>
        }
        @foreach (var item in FilteredItems.Skip((_page - 1) * PageSize).Take(PageSize))
        {
            <div class="stock-card">
                <div class="stock-card-header">
                    <span class="stock-card-name">@item.Name</span>
                    <span class="badge @(item.Type == "Ingredient" ? "bg-primary-subtle" : "bg-secondary")">@item.Type</span>
                </div>
                <div class="stock-card-body">
                    <div class="stock-card-row">
                        <span class="stock-card-label">Stock</span>
                        @if (item.Stock < 5 && item.Type == "Ingredient")
                        {
                            <span class="text-warning fw-bold">@item.Stock @item.Unit <small>(Low)</small></span>
                        }
                        else
                        {
                            <span>@item.Stock @item.Unit</span>
                        }
                    </div>
                    <div class="stock-card-row">
                        <span class="stock-card-label">Cost / Unit</span>
                        <span>₱@item.CostPerUnit.ToString("N2")</span>
                    </div>
                    <div class="stock-card-row">
                        <span class="stock-card-label">Total Value</span>
                        <span class="fw-bold" style="color: var(--primary)">₱@((item.Stock * item.CostPerUnit).ToString("N2"))</span>
                    </div>
                </div>
                <div class="stock-card-actions">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i> Edit</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i> Delete</button>
                </div>
            </div>
        }
    </div>

    <PaginationBar Page="_page" PageSize="PageSize" TotalItems="FilteredItems.Count()" OnPageChange="SetPage" />

</div>

@if (showModal)
{
    <div class="modal-overlay">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(isEditing ? "Edit Stock Item" : "New Stock Item")</h3>
                <button class="btn-close" @onclick="CloseModal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Item Name</label>
                    <input type="text" class="form-control" @bind="currentIngredient.Name" placeholder="e.g. Coffee Beans" />
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label">Unit</label>
                        <input type="text" class="form-control" @bind="currentIngredient.Unit" placeholder="e.g. kg, pcs" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Item Type</label>
                        <select class="form-select" @bind="currentIngredient.Type">
                            <option value="Ingredient">Ingredient (for products)</option>
                            <option value="Necessity">Necessity (shop utility)</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-6">
                        <label class="form-label">Current Stock</label>
                        <input type="number" class="form-control" step="0.1" @bind="currentIngredient.Stock" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Cost per Unit (₱)</label>
                        <input type="number" class="form-control" step="0.01" @bind="currentIngredient.CostPerUnit" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save">Save Item</button>
            </div>
        </div>
    </div>
}
}

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Stock Item"
    Message="@($"Are you sure you want to delete \"{deleteTarget?.Name}\"? This cannot be undone.")"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ExecuteDelete"
    OnCancel="() => showDeleteConfirm = false" />
