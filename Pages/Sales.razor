@page "/sales"

<PageTitle>Point of Sale | @AppSettings.CompanyName</PageTitle>

<div class="page-header">
    <div>
        <h1>Point of Sale</h1>
        <p class="text-muted">Record new sales and manage checkout.</p>
    </div>
</div>

<div class="grid grid-cols-2">
    <!-- Product Grid -->
    <div>
        <h3 class="mb-4">Select Products</h3>
        <div class="grid grid-cols-2 gap-3">
            @foreach (var prod in Inventory.Products)
            {
                bool isAvailable = prod.AvailableCount > 0;
                <div class="glass-card @(isAvailable ? "cursor-pointer" : "")" 
                     style="@(isAvailable ? "" : "opacity: 0.5"); padding: 0.75rem;"
                     @onclick="() => { if (isAvailable) AddToCart(prod); }">
                    <div class="flex items-center gap-3 mb-2">
                        @if (!string.IsNullOrEmpty(prod.ImageUrl))
                        {
                            <img src="@prod.ImageUrl" style="width: 50px; height: 50px; border-radius: 8px; object-fit: cover;" />
                        }
                        else
                        {
                            <div style="width: 50px; height: 50px; border-radius: 8px; background: var(--bg-surface); display: flex; align-items: center; justify-content: center; border: 1px solid var(--border)">
                                <i class="fa-solid fa-image text-muted"></i>
                            </div>
                        }
                        <div class="flex-1">
                            <div class="flex justify-between items-start">
                                <strong style="font-size: 0.95rem">@prod.Name</strong>
                                <span class="text-success">₱@prod.SellingPrice.ToString("0.00")</span>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem">
                                Available: @prod.AvailableCount
                                @if(!isAvailable) { <span class="text-danger ml-2">• Out of Stock</span> }
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if(!Inventory.Products.Any())
            {
                <div class="glass-card text-center" style="grid-column: span 2; padding: 2rem;">
                    <p class="text-muted">No products available. Add products first.</p>
                </div>
            }
        </div>
    </div>

    <!-- Cart -->
    <div class="glass-panel" style="position: sticky; top: 2rem;">
        <h3 class="mb-4">Current Sale</h3>
        
        <div style="min-height: 150px; max-height: 300px; overflow-y: auto; margin-bottom: 1rem">
            @foreach (var item in Cart)
            {
                <div class="flex justify-between items-center mb-3">
                    <div class="flex items-center gap-2">
                         @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                        {
                            <img src="@item.Product.ImageUrl" style="width: 32px; height: 32px; border-radius: 4px; object-fit: cover;" />
                        }
                        <div>
                            <strong style="font-size: 0.9rem">@item.Product.Name</strong>
                            <div class="text-muted" style="font-size: 0.8rem">
                                ₱@item.Product.SellingPrice.ToString("0.00") x @item.Quantity
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <strong class="text-success mr-4" style="font-size: 0.9rem">₱@((item.Product.SellingPrice * item.Quantity).ToString("0.00"))</strong>
                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveFromCart(item)"><i class="fa-solid fa-minus"></i></button>
                    </div>
                </div>
            }
            @if(Cart.Count == 0)
            {
                <p class="text-center text-muted m-4">Cart is empty.</p>
            }
        </div>

        <div style="border-top: 1px solid var(--border); padding-top: 1rem;">
            <div class="form-group mb-4">
                <label>Sale Note</label>
                <textarea @bind="saleNote" placeholder="Add a note to this sale..." rows="2" style="font-size: 0.9rem;"></textarea>
            </div>

            <div class="form-group mb-4">
                <label>Payment Method</label>
                <div class="flex gap-2">
                    <button class="btn @(paymentMethod == "Cash" ? "btn-primary" : "btn-secondary") w-full" @onclick='() => paymentMethod = "Cash"'>
                        <i class="fa-solid fa-money-bill-wave"></i> Cash
                    </button>
                    <button class="btn @(paymentMethod == "GCash" ? "btn-primary" : "btn-secondary") w-full" @onclick='() => paymentMethod = "GCash"'>
                        <i class="fa-solid fa-mobile-screen-button"></i> 
                        <span style="font-weight: 700; margin-left: 4px;">G</span>Cash
                    </button>
                </div>
            </div>

            <div class="flex justify-between mb-2 text-muted" style="font-size: 0.9rem">
                <span>Subtotal</span>
                <span>₱@Subtotal.ToString("0.00")</span>
            </div>
            <div class="flex justify-between mb-2 text-muted" style="font-size: 0.9rem">
                <span>Tax</span>
                <span>₱@TaxTotal.ToString("0.00")</span>
            </div>
            <div class="flex justify-between text-success mt-2 mb-4" style="font-size: 1.5rem">
                <strong>Total</strong>
                <strong>₱@Total.ToString("0.00")</strong>
            </div>
            
            <button class="btn btn-primary w-full" style="padding: 1rem; font-size: 1.1rem" disabled="@(!Cart.Any())" @onclick="CompleteSale">
                <i class="fa-solid fa-check"></i> Complete Sale (@paymentMethod)
            </button>
        </div>
    </div>
</div>

@if (showSuccessModal)
{
    <div class="modal-overlay">
        <div class="modal-content" style="max-width: 400px; text-align: center">
            <div class="modal-body" style="padding: 3rem 2rem">
                <div class="text-success mb-4" style="font-size: 4rem">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <h2 class="mb-2">Sale Completed!</h2>
                <p class="text-muted mb-4">Processed via @paymentMethod. Inventory has been updated.</p>
                <button class="btn btn-primary w-full" @onclick="() => showSuccessModal = false">New Sale</button>
            </div>
        </div>
    </div>
}

