@page "/sales"

<PageTitle>Point of Sale | @AppSettings.CompanyName</PageTitle>

@if (AppSettings.IsPosMode)
{
    @* ── POS Mode: Mini daily report banner ── *@
    <div class="page-header" style="margin-bottom: 0.5rem;">
        <div>
            <h1><i class="fa-solid fa-cash-register me-2" style="color: var(--primary);"></i>POS Mode</h1>
            <p class="text-muted mb-0">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-outline-danger btn-sm" @onclick="RequestExitPosMode">
                <i class="fa-solid fa-arrow-right-from-bracket"></i><span class="d-none d-sm-inline"> Exit POS</span>
            </button>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1>Point of Sale</h1>
            <p class="text-muted">Select products and complete sales.</p>
        </div>
    </div>
}

@if (!AppSettings.IsPosMode || AppSettings.PosActiveView == "pos")
{
<div class="pos-layout">
    <!-- Product Grid Side -->
    <div class="pos-products">
        <div class="filter-bar">
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="flex-grow-1" style="min-width:180px">
                    <input type="text" class="form-control" @bind="searchQuery" @bind:event="oninput" placeholder="Search products..." />
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="pos-category-btn @(selectedCategory == "All" ? "active" : "")" @onclick='() => selectedCategory = "All"'>All</button>
                    @foreach (var cat in Categories)
                    {
                        <button class="pos-category-btn @(selectedCategory == cat ? "active" : "")" @onclick="() => selectedCategory = cat">@cat</button>
                    }
                </div>
            </div>
        </div>

        @if (!FilteredProducts.Any())
        {
            <EmptyState Icon="fa-solid fa-store" Title="No products available" 
                        Message="@(string.IsNullOrEmpty(searchQuery) ? "Add products first to start selling." : "No products match your search.")"
                        ActionText="Go to Products" ActionIcon="fa-solid fa-arrow-right" 
                        OnAction="@(() => Nav.NavigateTo("products"))" />
        }
        else
        {
            <div class="pos-product-grid">
                @foreach (var prod in FilteredProducts)
                {
                    bool isAvailable = prod.AvailableCount > 0;
                    var cartItem = Cart.FirstOrDefault(c => c.Product.Guid == prod.Guid);
                    <div class="pos-product-card @(isAvailable ? "" : "disabled") @(cartItem != null ? "in-cart" : "")"
                         @onclick="() => { if (isAvailable) AddToCart(prod); }">
                        @if (!string.IsNullOrEmpty(prod.ImageUrl))
                        {
                            <img src="@prod.ImageUrl" class="pos-product-img" alt="@prod.Name" />
                        }
                        else
                        {
                            <div class="pos-product-img-placeholder"><i class="fa-solid fa-image"></i></div>
                        }
                        <div class="pos-product-info">
                            <div class="pos-product-name">@prod.Name</div>
                            <div class="pos-product-price">₱@AppSettings.FormatPrice(prod.SellingPrice)</div>
                            <div class="pos-product-stock text-muted">
                                @if (!isAvailable)
                                {
                                    <span class="text-danger">Out of stock</span>
                                }
                                else
                                {
                                    <span>@prod.AvailableCount avail.</span>
                                }
                            </div>
                        </div>
                        @if (cartItem != null)
                        {
                            <div class="pos-product-qty-badge">@cartItem.Quantity</div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- Cart Side (desktop) -->
    <div class="pos-cart-panel glass-panel">
        <h3 style="margin-bottom: 0.5rem;"><i class="fa-solid fa-cart-shopping"></i> Current Sale</h3>
        
        <!-- Customer name -->
        <div style="margin-bottom: 0.75rem;">
            <input type="text" class="form-control" @bind="customerName" placeholder="Customer name (optional)" />
        </div>

        <!-- Cart items -->
        <div class="pos-cart-items">
            @if (!Cart.Any())
            {
                <div class="pos-cart-empty">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <p>Tap a product to add it</p>
                </div>
            }
            else
            {
                @foreach (var item in Cart)
                {
                    <div class="pos-cart-item">
                        <div class="pos-cart-item-info">
                            <strong>@item.Product.Name</strong>
                            <span class="text-muted" style="font-size: 0.8rem;">₱@AppSettings.FormatPrice(item.Product.SellingPrice) ea</span>
                        </div>
                        <div class="pos-cart-item-controls">
                            <button class="pos-qty-btn" @onclick="() => DecreaseQty(item)"><i class="fa-solid fa-minus"></i></button>
                            <input type="number" min="1" max="@item.Product.AvailableCount" value="@item.Quantity" 
                                   @onchange="(e) => SetQty(item, e)" class="pos-qty-input" />
                            <button class="pos-qty-btn" @onclick="() => IncreaseQty(item)"><i class="fa-solid fa-plus"></i></button>
                        </div>
                        <div class="pos-cart-item-total">₱@AppSettings.FormatPrice(item.Product.SellingPrice * item.Quantity)</div>
                        <button class="pos-cart-remove" @onclick="() => RemoveFromCart(item)"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                }
            }
        </div>

        <!-- Discount -->
        <div class="pos-discount-section">
            <label class="form-label" style="font-size: 0.8rem; margin-bottom: 0.25rem;">Discount</label>
            <div class="d-flex gap-2">
                <select class="form-select" @bind="discountType" style="flex: 0 0 120px;">
                    <option value="None">None</option>
                    <option value="Percentage">% Off</option>
                    <option value="Fixed">₱ Fixed</option>
                </select>
                @if (discountType != "None")
                {
                    <input type="number" class="form-control" step="0.01" @bind="discountAmount" placeholder="@(discountType == "Percentage" ? "e.g. 10" : "e.g. 50")" />
                }
            </div>
        </div>

        <!-- Sale note -->
        <div class="mb-2">
            <textarea @bind="saleNote" placeholder="Sale note (optional)" rows="1" class="form-control"></textarea>
        </div>

        <!-- Payment -->
        <div class="pos-payment-section">
            <div class="d-flex gap-2">
                <button class="btn @(paymentMethod == "Cash" ? "btn-primary" : "btn-outline-secondary") w-100 btn-sm" @onclick='() => paymentMethod = "Cash"'>
                    <i class="fa-solid fa-money-bill-wave"></i> Cash
                </button>
                <button class="btn @(paymentMethod == "GCash" ? "btn-primary" : "btn-outline-secondary") w-100 btn-sm" @onclick='() => paymentMethod = "GCash"'>
                    <i class="fa-solid fa-mobile-screen-button"></i> GCash
                </button>
            </div>
        </div>

        <!-- Totals -->
        <div class="pos-totals">
            <div class="pos-total-row"><span>Subtotal</span><span>₱@AppSettings.FormatPrice(Subtotal)</span></div>
            <div class="pos-total-row"><span>Tax</span><span>₱@AppSettings.FormatPrice(TaxTotal)</span></div>
            @if (DiscountDisplay > 0)
            {
                <div class="pos-total-row text-danger"><span>Discount</span><span>-₱@DiscountDisplay.ToString("0.00")</span></div>
            }
            <div class="pos-total-row pos-grand-total"><strong>Total</strong><strong>₱@AppSettings.FormatPrice(Total)</strong></div>
        </div>

        <div class="d-flex gap-2">
            @if (Cart.Any())
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearCart" style="flex: 0 0 auto;"><i class="fa-solid fa-trash"></i></button>
            }
            <button class="btn btn-primary w-100" style="padding: 0.75rem; font-size: 1rem;" disabled="@(!Cart.Any() || isProcessing)" @onclick="CompleteSale">
                @if (isProcessing)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i>
                }
                else
                {
                    <i class="fa-solid fa-check"></i>
                }
                Complete Sale
            </button>
        </div>
    </div>
</div>

<!-- Mobile floating cart button -->
<div class="pos-mobile-cart-btn" @onclick="() => showMobileCart = true">
    <i class="fa-solid fa-cart-shopping"></i>
    @if (Cart.Any())
    {
        <span class="pos-mobile-cart-badge">@Cart.Sum(c => c.Quantity)</span>
    }
</div>

<!-- Mobile cart bottom sheet -->
<AppOffCanvas IsOpen="showMobileCart" IsOpenChanged="@((v) => showMobileCart = v)" Placement="Bottom">
    <Header>
        <h5 class="offcanvas-title"><i class="fa-solid fa-cart-shopping"></i> Cart (@Cart.Sum(c => c.Quantity) items)</h5>
    </Header>
    <Content>
        <div class="mb-2">
            <input type="text" class="form-control" @bind="customerName" placeholder="Customer name (optional)" />
        </div>

        <div class="pos-cart-items" style="max-height: 35vh; overflow-y: auto;">
            @foreach (var item in Cart)
            {
                <div class="pos-cart-item">
                    <div class="pos-cart-item-info">
                        <strong>@item.Product.Name</strong>
                        <span class="text-muted" style="font-size: 0.8rem;">₱@AppSettings.FormatPrice(item.Product.SellingPrice)</span>
                    </div>
                    <div class="pos-cart-item-controls">
                        <button class="pos-qty-btn" @onclick="() => DecreaseQty(item)"><i class="fa-solid fa-minus"></i></button>
                        <span style="min-width: 24px; text-align: center;">@item.Quantity</span>
                        <button class="pos-qty-btn" @onclick="() => IncreaseQty(item)"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    <button class="pos-cart-remove" @onclick="() => RemoveFromCart(item)"><i class="fa-solid fa-xmark"></i></button>
                </div>
            }
        </div>

        <div class="pos-discount-section">
            <div class="d-flex gap-2">
                <select class="form-select" @bind="discountType">
                    <option value="None">No Discount</option>
                    <option value="Percentage">% Off</option>
                    <option value="Fixed">₱ Fixed</option>
                </select>
                @if (discountType != "None")
                {
                    <input type="number" class="form-control" step="0.01" @bind="discountAmount" placeholder="Amount" style="width: 80px;" />
                }
            </div>
        </div>

        <div class="d-flex gap-2 mb-2">
            <button class="btn @(paymentMethod == "Cash" ? "btn-primary" : "btn-outline-secondary") w-100 btn-sm" @onclick='() => paymentMethod = "Cash"'>
                <i class="fa-solid fa-money-bill-wave"></i> Cash
            </button>
            <button class="btn @(paymentMethod == "GCash" ? "btn-primary" : "btn-outline-secondary") w-100 btn-sm" @onclick='() => paymentMethod = "GCash"'>
                <i class="fa-solid fa-mobile-screen-button"></i> GCash
            </button>
        </div>

        <div class="pos-totals">
            <div class="pos-total-row"><span>Subtotal</span><span>₱@AppSettings.FormatPrice(Subtotal)</span></div>
            <div class="pos-total-row"><span>Tax</span><span>₱@AppSettings.FormatPrice(TaxTotal)</span></div>
            @if (DiscountDisplay > 0)
            {
                <div class="pos-total-row text-danger"><span>Discount</span><span>-₱@DiscountDisplay.ToString("0.00")</span></div>
            }
            <div class="pos-total-row pos-grand-total"><strong>Total</strong><strong>₱@AppSettings.FormatPrice(Total)</strong></div>
        </div>

        <button class="btn btn-primary w-100" style="padding: 0.75rem;" disabled="@(!Cart.Any() || isProcessing)" @onclick="CompleteSale">
            @if (isProcessing) { <i class="fa-solid fa-spinner fa-spin"></i> }
            <i class="fa-solid fa-check"></i> Complete Sale (₱@AppSettings.FormatPrice(Total))
        </button>
    </Content>
</AppOffCanvas>

} @* end POS view *@

<!-- Receipt -->
@if (lastSaleItems != null)
{
    <Receipt IsVisible="showReceipt" BusinessName="@AppSettings.CompanyName" SaleDate="@lastSaleDate" CustomerName="@lastCustomerName"
             Items="@lastSaleItems" Subtotal="@lastSubtotal" TaxTotal="@lastTaxTotal" Total="@lastTotal"
             PaymentMethod="@lastPaymentMethod" DiscountAmount="@lastDiscountAmount" DiscountType="@lastDiscountType"
             OnClose="() => showReceipt = false" />
}

<!-- Confirm clear cart -->
<ConfirmDialog IsVisible="showClearConfirm" Title="Clear Cart?" Message="Remove all items from the cart?"
               Icon="fa-solid fa-trash" ConfirmText="Clear All" OnConfirm="ConfirmClear" OnCancel="() => showClearConfirm = false" />

@* ── POS Mode: Sales History View ── *@
@if (AppSettings.IsPosMode && AppSettings.PosActiveView == "history")
{
<div class="glass-panel">
    <h3 style="margin-bottom: 0.75rem;"><i class="fa-solid fa-clock-rotate-left"></i> Sales Summary</h3>

    <div class="d-flex gap-2 mb-3 flex-wrap">
        @foreach (var f in new[] { "Daily", "Weekly", "Monthly" })
        {
            <button class="btn btn-sm @(historyFilter == f ? "btn-primary" : "btn-outline-secondary")" @onclick="() => { historyFilter = f; historyPage = 1; }">@f</button>
        }
    </div>

    @if (HistorySales.Any())
    {
        @* Summary stats for selected period *@
        <div class="row g-2 mb-3">
            <div class="col-4">
                <div class="text-center p-2" style="background: var(--bg-surface); border-radius: 8px;">
                    <div class="text-muted" style="font-size: 0.7rem;">Revenue</div>
                    <div class="fw-bold" style="color: var(--primary);">₱@AppSettings.FormatCurrency(HistorySales.Where(s => !s.IsVoided).Sum(s => s.TotalAmount))</div>
                </div>
            </div>
            <div class="col-4">
                <div class="text-center p-2" style="background: var(--bg-surface); border-radius: 8px;">
                    <div class="text-muted" style="font-size: 0.7rem;">Profit</div>
                    <div class="fw-bold text-success">₱@AppSettings.FormatCurrency(HistorySales.Where(s => !s.IsVoided).Sum(s => s.ProfitAmount))</div>
                </div>
            </div>
            <div class="col-4">
                <div class="text-center p-2" style="background: var(--bg-surface); border-radius: 8px;">
                    <div class="text-muted" style="font-size: 0.7rem;">Sales</div>
                    <div class="fw-bold">@HistorySales.Count()</div>
                </div>
            </div>
        </div>

        @* Sales table *@
        <div class="table-responsive table-view">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Date</th><th>Product</th><th>Qty</th><th>Method</th><th>Amount</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var sale in HistorySales.OrderByDescending(s => s.Date).Skip((historyPage - 1) * HistoryPageSize).Take(HistoryPageSize))
                {
                    <tr style="@(sale.IsVoided ? "opacity: 0.5; text-decoration: line-through;" : "")">
                        <td>@sale.Date.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                        <td><strong>@sale.ProductName</strong></td>
                        <td>@sale.QuantitySold</td>
                        <td><span class="badge @(sale.PaymentMethod == "GCash" ? "bg-primary-subtle" : "bg-secondary")">@sale.PaymentMethod</span></td>
                        <td style="color: var(--primary)">₱@AppSettings.FormatCurrency(sale.TotalAmount)</td>
                        <td class="text-end">
                            @if (!sale.IsVoided)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => PrintHistoryReceipt(sale)" title="Receipt"><i class="fa-solid fa-print"></i></button>
                                @if (sale.Date.ToLocalTime().Date == DateTime.Today)
                                {
                                    <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => StartEditSale(sale)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => StartVoidSale(sale)" title="Void"><i class="fa-solid fa-ban"></i></button>
                                }
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle">Voided</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        @* Card view for mobile *@
        <div class="card-view">
            @foreach (var sale in HistorySales.OrderByDescending(s => s.Date).Skip((historyPage - 1) * HistoryPageSize).Take(HistoryPageSize))
            {
                <div class="stock-card" style="@(sale.IsVoided ? "opacity: 0.5;" : "")">
                    <div class="stock-card-header">
                        <div>
                            <span class="stock-card-name">@sale.ProductName</span>
                            <div class="text-muted" style="font-size: 0.72rem;">@sale.Date.ToLocalTime().ToString("MMM dd, h:mm tt")</div>
                        </div>
                        @if (sale.IsVoided)
                        {
                            <span class="badge bg-danger-subtle">Voided</span>
                        }
                        else
                        {
                            <span class="badge @(sale.PaymentMethod == "GCash" ? "bg-primary-subtle" : "bg-secondary")">@sale.PaymentMethod</span>
                        }
                    </div>
                    <div class="stock-card-body">
                        <div class="stock-card-row"><span class="stock-card-label">Qty</span><span>@sale.QuantitySold</span></div>
                        <div class="stock-card-row"><span class="stock-card-label">Amount</span><span class="fw-bold" style="color: var(--primary)">₱@AppSettings.FormatCurrency(sale.TotalAmount)</span></div>
                    </div>
                    @if (!sale.IsVoided)
                    {
                        <div class="stock-card-actions">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => PrintHistoryReceipt(sale)"><i class="fa-solid fa-print"></i> Receipt</button>
                            @if (sale.Date.ToLocalTime().Date == DateTime.Today)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditSale(sale)"><i class="fa-solid fa-pen"></i> Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => StartVoidSale(sale)"><i class="fa-solid fa-ban"></i> Void</button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
        <PaginationBar Page="historyPage" PageSize="HistoryPageSize" TotalItems="HistorySales.Count()" OnPageChange="SetHistoryPage" />
    }
    else
    {
        <EmptyState Icon="fa-solid fa-receipt" Title="No sales yet" Message="Sales will appear here after you complete transactions." />
    }
</div>
}

@* ── POS Mode: PIN prompt to exit ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showExitPinPrompt"
    IsVisibleChanged="@((v) => showExitPinPrompt = v)"
    Title="Enter PIN to Exit POS Mode"
    OnVerified="OnExitPinVerified" />

@* ── POS Mode: PIN prompt for edit/void ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showActionPinPrompt"
    IsVisibleChanged="@((v) => showActionPinPrompt = v)"
    Title="Enter PIN to Continue"
    OnVerified="OnActionPinVerified" />

@* ── Edit Sale Modal ── *@
<AppModal IsOpen="showEditSaleModal" IsOpenChanged="@((v) => { showEditSaleModal = v; })" Size="Large">
    <Header>
        <h5 class="modal-title">Edit Sale</h5>
    </Header>
    <Content>
        @if (editingSale != null)
        {
            <div class="mb-3">
                <label class="form-label">Product</label>
                <input type="text" class="form-control" value="@editingSale.ProductName" readonly />
            </div>
            <div class="row g-3">
                <div class="col-6">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control" @bind="editQty" min="1" />
                </div>
                <div class="col-6">
                    <label class="form-label">Payment Method</label>
                    <select class="form-select" @bind="editPaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="GCash">GCash</option>
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-6">
                    <label class="form-label">Discount Type</label>
                    <select class="form-select" @bind="editDiscountType">
                        <option value="None">None</option>
                        <option value="Percentage">% Off</option>
                        <option value="Fixed">₱ Fixed</option>
                    </select>
                </div>
                <div class="col-6">
                    @if (editDiscountType != "None")
                    {
                        <label class="form-label">Discount Amount</label>
                        <input type="number" class="form-control" step="0.01" @bind="editDiscountAmount" />
                    }
                </div>
            </div>
        }
    </Content>
    <Footer>
        <button class="btn btn-outline-secondary" @onclick="() => showEditSaleModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveEditSale">Save Changes</button>
    </Footer>
</AppModal>

@* ── Void Sale Confirm ── *@
<InventoryPlus.Components.ConfirmDialog
    IsVisible="showVoidConfirm"
    Title="Void Sale"
    Message="Are you sure you want to void this sale? Stock will be restored."
    Icon="fa-solid fa-ban"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmVoidSale"
    OnCancel="() => showVoidConfirm = false" />

@* ── History Receipt ── *@
@if (historyReceiptSale != null)
{
    <Receipt IsVisible="showHistoryReceipt" BusinessName="@AppSettings.CompanyName" SaleDate="@historyReceiptSale.Date"
             CustomerName="@historyReceiptSale.CustomerName"
             Items="@(new List<Receipt.ReceiptItem> { new() { Name = historyReceiptSale.ProductName, Quantity = historyReceiptSale.QuantitySold, UnitPrice = (historyReceiptSale.TotalAmount - historyReceiptSale.TaxAmount) / historyReceiptSale.QuantitySold } })"
             Subtotal="@(historyReceiptSale.TotalAmount - historyReceiptSale.TaxAmount)" TaxTotal="@historyReceiptSale.TaxAmount" Total="@historyReceiptSale.TotalAmount"
             PaymentMethod="@historyReceiptSale.PaymentMethod" DiscountAmount="@historyReceiptSale.DiscountAmount" DiscountType="@historyReceiptSale.DiscountType"
             OnClose="() => { showHistoryReceipt = false; historyReceiptSale = null; }" />
}

@code {
}
