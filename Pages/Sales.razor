@page "/sales"

<PageTitle>Point of Sale | @AppSettings.CompanyName</PageTitle>

@if (AppSettings.IsPosMode)
{
    <div class="page-header" style="margin-bottom:0.5rem">
        <div>
            <h1><i class="fa-solid fa-cash-register" style="color:var(--lime);margin-right:8px"></i>POS Mode</h1>
            <p>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-danger btn-sm" @onclick="RequestExitPosMode">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Exit POS
            </button>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1>Point of Sale</h1>
            <p>Select products and complete a sale.</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary btn-sm" disabled="@(!AppSettings.IsPro)" @onclick="EnterPosMode">
                <i class="fa-solid fa-cash-register"></i> POS Mode
                @if (!AppSettings.IsPro)
                {
                    <span style="font-size:8px;font-weight:700;color:var(--amber);margin-left:4px;background:rgba(255,193,7,0.15);padding:1px 5px;border-radius:4px">PRO</span>
                }
            </button>
        </div>
    </div>
}

@if (!AppSettings.IsPosMode || AppSettings.PosActiveView == "pos")
{
<div class="section-gap fade-in">
    <div class="pos-grid">
        <div style="display:flex;flex-direction:column;gap:10px">
            <div class="filter-bar">
                <input class="form-control search-input" placeholder="Search products…" @bind="searchQuery" @bind:event="oninput" />
                <div class="pill-group">
                    <button class="pill @(selectedCategory == "All" ? "active" : "")" @onclick='() => selectedCategory = "All"'>All</button>
                    @foreach (var cat in Categories)
                    {
                        <button class="pill @(selectedCategory == cat ? "active" : "")" @onclick="() => selectedCategory = cat">@cat</button>
                    }
                </div>
            </div>

            @if (!FilteredProducts.Any())
            {
                <EmptyState Icon="fa-solid fa-store" Title="No products available"
                            Message="@(string.IsNullOrEmpty(searchQuery) ? "Add products first to start selling." : "No products match your search.")"
                            ActionText="Go to Products" ActionIcon="fa-solid fa-arrow-right"
                            OnAction="@(() => Nav.NavigateTo("products"))" />
            }
            else
            {
                <div class="pos-product-grid">
                    @foreach (var prod in FilteredProducts)
                    {
                        bool isAvailable = prod.AvailableCount > 0;
                        var cartItem = Cart.FirstOrDefault(c => c.Product.Guid == prod.Guid);
                        <div class="pos-card @(isAvailable ? "" : "disabled") @(cartItem != null ? "in-cart" : "")"
                             @onclick="() => { if (isAvailable) AddToCart(prod); }">
                            @if (cartItem != null)
                            {
                                <div class="pos-qty-badge">@cartItem.Quantity</div>
                            }
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <div class="pos-card-img"><img src="@prod.ImageUrl" style="width:100%;height:100%;object-fit:cover;border-radius:var(--radius-sm)" alt="@prod.Name" /></div>
                            }
                            else
                            {
                                <div class="pos-card-img" style="display:flex;align-items:center;justify-content:center;background:var(--bg3);border-radius:var(--radius-sm)"><i class="fa-solid fa-image" style="color:var(--fg3);font-size:18px"></i></div>
                            }
                            <div class="pos-card-name">@prod.Name</div>
                            <div class="pos-card-price">₱@AppSettings.FormatPrice(prod.SellingPrice)</div>
                            <div class="pos-card-stock">@(isAvailable ? $"{prod.AvailableCount} avail." : "Out of stock")</div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="cart-panel">
            <div class="card card-p" style="flex:none">
                <div style="display:flex;align-items:center;gap:5px;margin-bottom:10px">
                    <span style="font-size:10px;font-weight:700;color:var(--fg3);text-transform:uppercase;letter-spacing:.1em">Current Sale</span>
                    @if (Cart.Any())
                    {
                        <span class="badge badge-lime">@Cart.Sum(c => c.Quantity) items</span>
                    }
                </div>

                <div class="form-group" style="margin-bottom:8px">
                    <input class="form-control" placeholder="Customer name (optional)" @bind="customerName" />
                </div>

                <div style="max-height:240px;overflow-y:auto;display:flex;flex-direction:column;gap:5px;margin-bottom:8px">
                    @if (!Cart.Any())
                    {
                        <div style="text-align:center;padding:20px 0;color:var(--fg3)">
                            <i class="fa-solid fa-cart-shopping" style="font-size:22px;opacity:.2;display:block;margin-bottom:5px"></i>
                            <span style="font-size:11px">Tap a product to add</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Cart)
                        {
                            <div class="cart-item">
                                <div class="cart-item-name">
                                    @item.Product.Name
                                    <div style="font-size:9px;color:var(--fg3)">₱@AppSettings.FormatPrice(item.Product.SellingPrice) ea.</div>
                                </div>
                                <div class="qty-ctrl">
                                    <button class="qty-btn" @onclick="() => DecreaseQty(item)"><i class="fa-solid fa-minus"></i></button>
                                    <span class="qty-num">@item.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncreaseQty(item)"><i class="fa-solid fa-plus"></i></button>
                                </div>
                                <span style="font-family:'Space Mono',monospace;font-size:11px;color:var(--fg);font-weight:700;min-width:54px;text-align:right">₱@AppSettings.FormatPrice(item.Product.SellingPrice * item.Quantity)</span>
                                <button @onclick="() => RemoveFromCart(item)" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:10px;opacity:.6;padding:0 2px"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                        }
                    }
                </div>

                <div class="form-group" style="margin-bottom:8px">
                    <label class="form-label">Discount</label>
                    <div style="display:flex;gap:5px">
                        <select class="form-control" @bind="discountType" style="flex:0 0 100px">
                            <option value="None">None</option>
                            <option value="Percentage">% Off</option>
                            <option value="Fixed">₱ Fixed</option>
                        </select>
                        @if (discountType != "None")
                        {
                            <input class="form-control" type="number" step="0.01" @bind="discountAmount" placeholder="@(discountType == "Percentage" ? "10" : "50")" />
                        }
                    </div>
                </div>

                <div class="form-group" style="margin-bottom:8px">
                    <textarea @bind="saleNote" placeholder="Sale note (optional)" rows="1" class="form-control" style="font-size:11px"></textarea>
                </div>

                <div class="form-group" style="margin-bottom:10px">
                    <label class="form-label">Payment</label>
                    <div style="display:flex;gap:5px">
                        <button class="pay-btn @(paymentMethod == "Cash" ? "active" : "")" @onclick='() => paymentMethod = "Cash"'>Cash</button>
                        <button class="pay-btn @(paymentMethod == "GCash" ? "active" : "")" @onclick='() => paymentMethod = "GCash"'>GCash</button>
                    </div>
                </div>

                <div style="padding:8px 0;border-top:1px solid var(--border)">
                    <div class="cart-total-row"><span>Subtotal</span><span class="mono">₱@AppSettings.FormatPrice(Subtotal)</span></div>
                    <div class="cart-total-row"><span>Tax</span><span class="mono">₱@AppSettings.FormatPrice(TaxTotal)</span></div>
                    @if (DiscountDisplay > 0)
                    {
                        <div class="cart-total-row" style="color:var(--red)"><span>Discount</span><span class="mono">-₱@DiscountDisplay.ToString("0.00")</span></div>
                    }
                    <div class="cart-total-row grand"><span>Total</span><span class="mono">₱@AppSettings.FormatPrice(Total)</span></div>
                </div>

                <div style="display:flex;gap:5px;margin-top:6px">
                    @if (Cart.Any())
                    {
                        <button class="btn btn-danger btn-icon" @onclick="ClearCart" title="Clear cart"><i class="fa-solid fa-trash"></i></button>
                    }
                    <button class="btn btn-primary" style="flex:1;justify-content:center;padding:10px;font-size:13px;font-weight:700" disabled="@(!Cart.Any() || isProcessing)" @onclick="CompleteSale">
                        @if (isProcessing)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i> <text>Processing...</text>
                        }
                        else
                        {
                            <text>Complete Sale →</text>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Mobile floating cart button -->
<div class="pos-mobile-cart-btn" @onclick="() => showMobileCart = true">
    <i class="fa-solid fa-cart-shopping"></i>
    @if (Cart.Any())
    {
        <span class="pos-mobile-cart-badge">@Cart.Sum(c => c.Quantity)</span>
    }
</div>

<!-- Mobile cart modal -->
<AppModal IsOpen="showMobileCart" IsOpenChanged="@((v) => showMobileCart = v)" Size="Default">
    <Header>
        <h5><i class="fa-solid fa-cart-shopping"></i> Cart (@Cart.Sum(c => c.Quantity) items)</h5>
    </Header>
    <Content>
        <div style="margin-bottom:8px">
            <input class="form-control" @bind="customerName" placeholder="Customer name (optional)" />
        </div>

        <div style="max-height:35vh;overflow-y:auto;display:flex;flex-direction:column;gap:5px">
            @foreach (var item in Cart)
            {
                <div class="cart-item">
                    <div class="cart-item-name">
                        @item.Product.Name
                        <div style="font-size:9px;color:var(--fg3)">₱@AppSettings.FormatPrice(item.Product.SellingPrice)</div>
                    </div>
                    <div class="qty-ctrl">
                        <button class="qty-btn" @onclick="() => DecreaseQty(item)"><i class="fa-solid fa-minus"></i></button>
                        <span class="qty-num">@item.Quantity</span>
                        <button class="qty-btn" @onclick="() => IncreaseQty(item)"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    <button @onclick="() => RemoveFromCart(item)" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:10px"><i class="fa-solid fa-xmark"></i></button>
                </div>
            }
        </div>

        <div class="form-group" style="margin-top:8px">
            <div style="display:flex;gap:5px">
                <select class="form-control" @bind="discountType" style="flex:0 0 100px">
                    <option value="None">No Discount</option>
                    <option value="Percentage">% Off</option>
                    <option value="Fixed">₱ Fixed</option>
                </select>
                @if (discountType != "None")
                {
                    <input class="form-control" type="number" step="0.01" @bind="discountAmount" placeholder="Amount" style="width:80px" />
                }
            </div>
        </div>

        <div style="display:flex;gap:5px;margin-top:8px">
            <button class="pay-btn @(paymentMethod == "Cash" ? "active" : "")" style="flex:1" @onclick='() => paymentMethod = "Cash"'>
                <i class="fa-solid fa-money-bill-wave"></i> Cash
            </button>
            <button class="pay-btn @(paymentMethod == "GCash" ? "active" : "")" style="flex:1" @onclick='() => paymentMethod = "GCash"'>
                <i class="fa-solid fa-mobile-screen-button"></i> GCash
            </button>
        </div>

        <div style="padding:8px 0;border-top:1px solid var(--border);margin-top:8px">
            <div class="cart-total-row"><span>Subtotal</span><span class="mono">₱@AppSettings.FormatPrice(Subtotal)</span></div>
            <div class="cart-total-row"><span>Tax</span><span class="mono">₱@AppSettings.FormatPrice(TaxTotal)</span></div>
            @if (DiscountDisplay > 0)
            {
                <div class="cart-total-row" style="color:var(--red)"><span>Discount</span><span class="mono">-₱@DiscountDisplay.ToString("0.00")</span></div>
            }
            <div class="cart-total-row grand"><span>Total</span><span class="mono">₱@AppSettings.FormatPrice(Total)</span></div>
        </div>

        <button class="btn btn-primary" style="width:100%;padding:10px;margin-top:6px" disabled="@(!Cart.Any() || isProcessing)" @onclick="CompleteSale">
            @if (isProcessing) { <i class="fa-solid fa-spinner fa-spin"></i> }
            <i class="fa-solid fa-check"></i> Complete Sale (₱@AppSettings.FormatPrice(Total))
        </button>
    </Content>
</AppModal>

} @* end POS view *@

<!-- Receipt -->
@if (lastSaleItems != null)
{
    <Receipt IsVisible="showReceipt" BusinessName="@AppSettings.CompanyName" SaleDate="@lastSaleDate" CustomerName="@lastCustomerName"
             Items="@lastSaleItems" Subtotal="@lastSubtotal" TaxTotal="@lastTaxTotal" Total="@lastTotal"
             PaymentMethod="@lastPaymentMethod" DiscountAmount="@lastDiscountAmount" DiscountType="@lastDiscountType"
             OnClose="() => showReceipt = false" />
}

<!-- Confirm clear cart -->
<ConfirmDialog IsVisible="showClearConfirm" Title="Clear Cart?" Message="Remove all items from the cart?"
               Icon="fa-solid fa-trash" ConfirmText="Clear All" OnConfirm="ConfirmClear" OnCancel="() => showClearConfirm = false" />

@* ── POS Mode: Sales History View ── *@
@if (AppSettings.IsPosMode && AppSettings.PosActiveView == "history")
{
<div class="section-gap fade-in">
    <div class="card card-p">
        <div class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> Sales Summary</div>

        <div class="pill-group" style="margin-bottom:10px">
            @foreach (var f in new[] { "Daily", "Weekly", "Monthly" })
            {
                <button class="pill @(historyFilter == f ? "active" : "")" @onclick="() => { historyFilter = f; historyPage = 1; }">@f</button>
            }
        </div>

        @if (HistorySales.Any())
        {
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:12px">
                <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                    <div class="stat-card-icon si-lime"><i class="fa-solid fa-chart-line"></i></div>
                    <div>
                        <div class="stat-card-value" style="font-size:14px">₱@AppSettings.FormatCurrency(HistorySales.Where(s => !s.IsVoided).Sum(s => s.TotalAmount))</div>
                        <div class="stat-card-label">Revenue</div>
                    </div>
                </div>
                <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                    <div class="stat-card-icon si-green"><i class="fa-solid fa-money-bill-trend-up"></i></div>
                    <div>
                        <div class="stat-card-value" style="font-size:14px">₱@AppSettings.FormatCurrency(HistorySales.Where(s => !s.IsVoided).Sum(s => s.ProfitAmount))</div>
                        <div class="stat-card-label">Profit</div>
                    </div>
                </div>
                <div class="stat-card" style="display:flex;flex-direction:row;align-items:center;gap:8px">
                    <div class="stat-card-icon si-amber"><i class="fa-solid fa-receipt"></i></div>
                    <div>
                        <div class="stat-card-value" style="font-size:14px">@HistorySales.Count()</div>
                        <div class="stat-card-label">Sales</div>
                    </div>
                </div>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr><th>Date</th><th>Product</th><th>Qty</th><th>Method</th><th>Amount</th><th style="text-align:right">Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in HistorySales.OrderByDescending(s => s.Date).Skip((historyPage - 1) * HistoryPageSize).Take(HistoryPageSize))
                        {
                            <tr style="@(sale.IsVoided ? "opacity:0.5;text-decoration:line-through" : "")">
                                <td style="font-size:11px">@sale.Date.ToLocalTime().ToString("MMM dd, h:mm tt")</td>
                                <td style="font-weight:600">@sale.ProductName</td>
                                <td>@sale.QuantitySold</td>
                                <td><span class="badge @(sale.PaymentMethod == "GCash" ? "badge-lime" : "badge-gray")">@sale.PaymentMethod</span></td>
                                <td class="mono text-lime" style="font-weight:700">₱@AppSettings.FormatCurrency(sale.TotalAmount)</td>
                                <td>
                                    <div style="display:flex;gap:4px;justify-content:flex-end">
                                        @if (!sale.IsVoided)
                                        {
                                            <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => PrintHistoryReceipt(sale)" title="Receipt"><i class="fa-solid fa-print"></i></button>
                                            @if (sale.Date.ToLocalTime().Date == DateTime.Today)
                                            {
                                                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => StartEditSale(sale)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                                <button class="btn btn-danger btn-sm btn-icon" @onclick="() => StartVoidSale(sale)" title="Void"><i class="fa-solid fa-ban"></i></button>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge badge-red">Voided</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PaginationBar Page="historyPage" PageSize="HistoryPageSize" TotalItems="HistorySales.Count()" OnPageChange="SetHistoryPage" />
        }
        else
        {
            <EmptyState Icon="fa-solid fa-receipt" Title="No sales yet" Message="Sales will appear here after you complete transactions." />
        }
    </div>
</div>
}

@* ── POS Mode: PIN prompt to enter ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showEnterPinPrompt"
    IsVisibleChanged="@((v) => showEnterPinPrompt = v)"
    Title="Enter PIN to Enter POS Mode"
    OnVerified="OnEnterPinVerified" />

@* ── POS Mode: PIN prompt to exit ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showExitPinPrompt"
    IsVisibleChanged="@((v) => showExitPinPrompt = v)"
    Title="Enter PIN to Exit POS Mode"
    OnVerified="OnExitPinVerified" />

@* ── POS Mode: PIN prompt for edit/void ── *@
<InventoryPlus.Components.PinPrompt
    IsVisible="showActionPinPrompt"
    IsVisibleChanged="@((v) => showActionPinPrompt = v)"
    Title="Enter PIN to Continue"
    OnVerified="OnActionPinVerified" />

@* ── Edit Sale Modal ── *@
<AppModal IsOpen="showEditSaleModal" IsOpenChanged="@((v) => { showEditSaleModal = v; })" Size="Large">
    <Header>
        <h5>Edit Sale</h5>
    </Header>
    <Content>
        @if (editingSale != null)
        {
            <div class="form-group">
                <label class="form-label">Product</label>
                <input class="form-control" value="@editingSale.ProductName" readonly />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Quantity</label>
                    <input class="form-control" type="number" @bind="editQty" min="1" />
                </div>
                <div class="form-group">
                    <label class="form-label">Payment Method</label>
                    <select class="form-control" @bind="editPaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="GCash">GCash</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Discount Type</label>
                    <select class="form-control" @bind="editDiscountType">
                        <option value="None">None</option>
                        <option value="Percentage">% Off</option>
                        <option value="Fixed">₱ Fixed</option>
                    </select>
                </div>
                <div class="form-group">
                    @if (editDiscountType != "None")
                    {
                        <label class="form-label">Discount Amount</label>
                        <input class="form-control" type="number" step="0.01" @bind="editDiscountAmount" />
                    }
                </div>
            </div>
        }
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="() => showEditSaleModal = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveEditSale">Save Changes</button>
    </Footer>
</AppModal>

@* ── Void Sale Confirm ── *@
<InventoryPlus.Components.ConfirmDialog
    IsVisible="showVoidConfirm"
    Title="Void Sale"
    Message="Are you sure you want to void this sale? Stock will be restored."
    Icon="fa-solid fa-ban"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ConfirmVoidSale"
    OnCancel="() => showVoidConfirm = false" />

@* ── History Receipt ── *@
@if (historyReceiptSale != null)
{
    <Receipt IsVisible="showHistoryReceipt" BusinessName="@AppSettings.CompanyName" SaleDate="@historyReceiptSale.Date"
             CustomerName="@historyReceiptSale.CustomerName"
             Items="@(new List<Receipt.ReceiptItem> { new() { Name = historyReceiptSale.ProductName, Quantity = historyReceiptSale.QuantitySold, UnitPrice = (historyReceiptSale.TotalAmount - historyReceiptSale.TaxAmount) / historyReceiptSale.QuantitySold } })"
             Subtotal="@(historyReceiptSale.TotalAmount - historyReceiptSale.TaxAmount)" TaxTotal="@historyReceiptSale.TaxAmount" Total="@historyReceiptSale.TotalAmount"
             PaymentMethod="@historyReceiptSale.PaymentMethod" DiscountAmount="@historyReceiptSale.DiscountAmount" DiscountType="@historyReceiptSale.DiscountType"
             OnClose="() => { showHistoryReceipt = false; historyReceiptSale = null; }" />
}

@code {
}
