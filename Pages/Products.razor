@page "/products"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Products | @AppSettings.CompanyName</PageTitle>

@if (Inventory.IsLoading)
{
    <div class="card card-p" style="padding:3rem">
        <i class="fa-solid fa-spinner fa-spin fa-2x" style="color:var(--fg3)"></i>
        <p style="color:var(--fg3);margin-top:1rem">Loading products...</p>
    </div>
}
else
{

<div class="section-gap fade-in">
    <div class="page-header">
        <div>
            <h1>Products</h1>
            <p>Bundles of ingredients ready for sale.</p>
        </div>
        <div class="page-header-right">
            <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i> Add Product</button>
        </div>
    </div>

    <div class="filter-bar">
        <input class="form-control search-input" placeholder="Search products…" @bind="searchQuery" @bind:event="oninput" />
        <select class="form-control" style="width:auto" @bind="categoryFilter">
            <option value="All">All Categories</option>
            @foreach (var cat in Inventory.ActiveProducts.Select(p => string.IsNullOrEmpty(p.Category) ? "Other" : p.Category).Distinct().OrderBy(c => c))
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>

    <div class="card" style="overflow:hidden">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Cost</th>
                        <th>Margin</th>
                        <th>Stock</th>
                        <th style="text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredProducts.Skip((_page - 1) * PageSize).Take(PageSize))
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:9px">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" style="width:32px;height:32px;border-radius:var(--radius-sm);object-fit:cover;border:1px solid var(--border);flex-shrink:0" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div style="width:32px;height:32px;border-radius:var(--radius-sm);background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;border:1px solid var(--border)">
                                            <i class="fa-solid fa-image" style="color:var(--fg3)"></i>
                                        </div>
                                    }
                                    <div>
                                        <div style="font-weight:600;font-size:12px">@item.Name</div>
                                        <div style="font-size:10px;color:var(--fg3)">
                                            @if (!string.IsNullOrEmpty(item.Category))
                                            {
                                                @item.Category
                                            }
                                            else
                                            {
                                                <text>Uncategorized</text>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="mono text-lime" style="font-size:12px;font-weight:700">₱@AppSettings.FormatPrice(item.SellingPrice)</td>
                            <td class="mono text-red" style="font-size:11px">₱@AppSettings.FormatPrice(item.TotalCost)</td>
                            <td>
                                <span class="badge @(item.ProfitMargin > 0 ? "badge-green" : "badge-red")">
                                    ₱@AppSettings.FormatPrice(item.ProfitMargin) (@((item.ProfitMarginPercentage * 100).ToString("0"))%)
                                </span>
                            </td>
                            <td>
                                @if (item.AvailableCount <= 0)
                                {
                                    <span class="badge badge-red">Out</span>
                                }
                                else
                                {
                                    <span class="badge badge-green">@item.AvailableCount avail.</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex;gap:4px;justify-content:flex-end">
                                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-danger btn-sm btn-icon" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!FilteredProducts.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;color:var(--fg3);padding:3rem">No products configured yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <PaginationBar Page="_page" PageSize="PageSize" TotalItems="FilteredProducts.Count()" OnPageChange="SetPage" />
</div>

}

<AppModal IsOpen="showModal" IsOpenChanged="@((v) => { showModal = v; })" Size="ExtraLarge">
    <Header>
        <h5>@(isEditing ? "Edit Product" : "New Product")</h5>
    </Header>
    <Content>
        <div class="form-row">
            <div>
                <div class="form-group">
                    <label class="form-label">Product Name <span class="req">*</span></label>
                    <input class="form-control @(validationErrors.Contains("Name") ? "is-invalid" : "")" @bind="currentProduct.Name" placeholder="e.g. Pork BBQ" />
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <input class="form-control @(validationErrors.Contains("Category") ? "is-invalid" : "")" @bind="currentProduct.Category" placeholder="e.g. Food, Drinks" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Selling Price (₱) <span class="req">*</span></label>
                        <input class="form-control @(validationErrors.Contains("Price") ? "is-invalid" : "")" type="number" step="0.01" @bind="currentProduct.SellingPrice" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tax Rate (%)</label>
                        <input class="form-control" type="number" step="0.1" @bind="taxRatePercent" placeholder="0" />
                    </div>
                </div>

                @if (AppSettings.ShowInventoryTab)
                {
                <div class="form-group">
                    <label class="form-label">Uses Ingredients?</label>
                    <div style="display:flex;gap:5px">
                        <button class="btn @(currentProduct.HasIngredients ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center"
                                @onclick="() => currentProduct.HasIngredients = true">
                            <i class="fa-solid fa-check"></i> Yes
                        </button>
                        <button class="btn @(!currentProduct.HasIngredients ? "btn-primary" : "btn-ghost") btn-sm" style="flex:1;justify-content:center"
                                @onclick="() => currentProduct.HasIngredients = false">
                            <i class="fa-solid fa-xmark"></i> No
                        </button>
                    </div>
                </div>
                }

                @if (!currentProduct.HasIngredients)
                {
                <div class="form-group">
                    <label class="form-label">Stock Count</label>
                    <input class="form-control" type="number" step="1" @bind="currentProduct.StockCount" placeholder="0" />
                </div>
                }
            </div>
            <div>
                <div class="form-group">
                    <label class="form-label">Product Image</label>
                    @if (!string.IsNullOrEmpty(currentProduct.ImageUrl))
                    {
                        <div style="width:72px;height:72px;border-radius:var(--radius-sm);overflow:hidden;margin-bottom:7px;border:1px solid var(--border)">
                            <img src="@currentProduct.ImageUrl" style="width:100%;height:100%;object-fit:cover" />
                        </div>
                    }
                    else
                    {
                        <div style="width:72px;height:72px;background:var(--bg3);border:1px dashed var(--border2);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:7px">📷</div>
                    }
                    <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" style="font-size:11px" />
                    @if (pendingImageFile != null && !isUploading)
                    {
                        <button class="btn btn-ghost btn-sm" style="margin-top:5px" @onclick="UploadImage"><i class="fa-solid fa-upload"></i> Upload</button>
                    }
                    @if (isUploading)
                    {
                        <p style="color:var(--fg3);font-size:11px;margin-top:5px"><i class="fa-solid fa-spinner fa-spin"></i> Uploading...</p>
                    }
                </div>

                <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 13px;margin-top:8px">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--fg3);margin-bottom:7px">Summary</div>
                    <div style="display:flex;justify-content:space-between;font-size:11px;padding:4px 0;border-bottom:1px solid var(--border)">
                        <span style="color:var(--fg3)">Cost</span>
                        <span class="text-red mono fw-700">₱@AppSettings.FormatPrice(currentProduct.TotalCost)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:11px;padding:4px 0;border-bottom:1px solid var(--border)">
                        <span style="color:var(--fg3)">Selling Price</span>
                        <span class="text-lime mono fw-700">₱@AppSettings.FormatPrice(currentProduct.SellingPrice)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:11px;padding:4px 0">
                        <span style="color:var(--fg3)">Profit</span>
                        <span class="text-green mono fw-700">₱@AppSettings.FormatPrice(currentProduct.ProfitMargin) (@((currentProduct.SellingPrice > 0 ? (currentProduct.ProfitMargin / currentProduct.SellingPrice * 100) : 0).ToString("0"))%)</span>
                    </div>
                </div>

                @if (currentProduct.HasIngredients)
                {
                <div style="margin-top:12px">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--fg3);margin-bottom:7px">Required Ingredients</div>
                    <div style="display:flex;gap:5px;margin-bottom:8px">
                        <select @bind="selectedIngredientId" class="form-control" @bind:after="OnIngredientSelected" style="font-size:11px">
                            <option value="">Select…</option>
                            @foreach(var ing in Inventory.ActiveIngredients.Where(i => i.Type == "Ingredient"))
                            {
                                <option value="@ing.Guid">@ing.Name (@ing.Stock @ing.Unit)</option>
                            }
                        </select>
                        <input type="number" class="form-control" step="0.1" @bind="newQuantity" placeholder="Qty" style="width:60px;font-size:11px" />
                        @{
                            var ingCat = InventoryPlus.Services.UnitConverter.GetCategory(_selectedIngUnit);
                            var compatUnits = InventoryPlus.Services.UnitConverter.GetUnitsForCategory(ingCat);
                        }
                        @if (compatUnits.Length > 0)
                        {
                            <select class="form-control" @bind="newUsageUnit" style="width:70px;font-size:11px">
                                @foreach (var u in compatUnits)
                                {
                                    <option value="@u">@u</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control" @bind="newUsageUnit" placeholder="unit" style="width:70px;font-size:11px" />
                        }
                        <button class="btn btn-ghost btn-sm btn-icon" @onclick="AddRequirement"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    @{
                        var hint = InventoryPlus.Services.UnitConverter.ConversionHint(newUsageUnit, _selectedIngUnit);
                    }
                    @if (!string.IsNullOrEmpty(hint))
                    {
                        <div style="color:var(--fg3);font-size:10px;margin-bottom:6px"><i class="fa-solid fa-arrows-rotate"></i> @hint</div>
                    }

                    <div style="max-height:180px;overflow-y:auto">
                        @foreach(var req in currentProduct.RequiredIngredients)
                        {
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:4px">
                                <div>
                                    <div style="font-weight:600;font-size:11px">@req.Ingredient?.Name</div>
                                    <div style="font-size:10px;color:var(--fg3)">
                                        @req.QuantityRequired @req.EffectiveUsageUnit
                                        @{ var convertedCost = InventoryPlus.Services.UnitConverter.ConvertSafe(req.QuantityRequired, req.EffectiveUsageUnit, req.Ingredient?.Unit ?? "") * (req.Ingredient?.CostPerUnit ?? 0); }
                                        <span class="text-red">(₱@AppSettings.FormatPrice(convertedCost))</span>
                                        @{ var reqHint = InventoryPlus.Services.UnitConverter.ConversionHint(req.EffectiveUsageUnit, req.Ingredient?.Unit ?? ""); }
                                        @if (!string.IsNullOrEmpty(reqHint))
                                        {
                                            <span style="color:var(--fg3);margin-left:4px;font-size:9px">@reqHint</span>
                                        }
                                    </div>
                                </div>
                                <button class="btn btn-danger btn-sm btn-icon" @onclick="() => RemoveRequirement(req)"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        }
                        @if(currentProduct.RequiredIngredients.Count == 0)
                        {
                            <p style="color:var(--fg3);text-align:center;font-size:11px;padding:8px 0">No ingredients added yet.</p>
                        }
                    </div>
                </div>
                }
            </div>
        </div>
    </Content>
    <Footer>
        <button class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
        <button class="btn btn-primary" @onclick="Save">Save Product</button>
    </Footer>
</AppModal>

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Product"
    Message="@($"Are you sure you want to delete \"{deleteTarget?.Name}\"? This cannot be undone.")"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ExecuteDelete"
    OnCancel="() => showDeleteConfirm = false" />

<InventoryPlus.Components.PinPrompt
    IsVisible="showPinPrompt"
    IsVisibleChanged="@((v) => showPinPrompt = v)"
    OnVerified="OnPinVerified" />

