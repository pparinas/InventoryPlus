@page "/products"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Products | @AppSettings.CompanyName</PageTitle>

@if (Inventory.IsLoading)
{
    <div class="glass-panel text-center" style="padding: 3rem">
        <i class="fa-solid fa-spinner fa-spin fa-2x text-muted"></i>
        <p class="text-muted mt-4">Loading products...</p>
    </div>
}
else
{

<div class="page-header">
    <div>
        <h1>Products</h1>
        <p class="text-muted">Bundles of ingredients ready for sale.</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal"><i class="fa-solid fa-plus"></i><span class="d-none d-sm-inline"> Add Product</span></button>
</div>

<div class="filter-bar">
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <div class="flex-grow-1" style="min-width:180px">
            <input type="text" class="form-control" placeholder="Search products..." @bind="searchQuery" @bind:event="oninput" />
        </div>
        <select class="form-select" style="width:auto" @bind="categoryFilter">
            <option value="All">All Categories</option>
            @foreach (var cat in Inventory.ActiveProducts.Select(p => string.IsNullOrEmpty(p.Category) ? "Other" : p.Category).Distinct().OrderBy(c => c))
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
</div>

<div class="glass-panel">
    @* Desktop table *@
    <div class="table-responsive table-view">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Price</th>
                <th>Cost</th>
                <th>Profit Margin</th>
                <th>Available</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Inventory.ActiveProducts.Skip((_page - 1) * PageSize).Take(PageSize))
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border)" alt="@item.Name" />
                            }
                            else
                            {
                                <div style="width: 40px; height: 40px; border-radius: 8px; background: var(--bg-surface); display: flex; align-items: center; justify-content: center; border: 1px solid var(--border)">
                                    <i class="fa-solid fa-image text-muted"></i>
                                </div>
                            }
                            <div>
                                <strong>@item.Name</strong><br />
                                <span class="text-muted" style="font-size:0.8rem">
                                @(string.Join(", ", item.RequiredIngredients.Where(ri => ri.Ingredient != null).Select(ri => $"{ri.QuantityRequired}{ri.Ingredient!.Unit} {ri.Ingredient!.Name}")))
                                </span>
                            </div>
                        </div>
                    </td>
                    <td class="text-success">₱@item.SellingPrice.ToString("0.00")</td>
                    <td class="text-danger">₱@item.TotalCost.ToString("0.00")</td>
                    <td>
                        <span class="@(item.ProfitMargin > 0 ? "text-success" : "text-danger")">
                            ₱@item.ProfitMargin.ToString("0.00") (@((item.ProfitMarginPercentage * 100).ToString("0.0"))%)
                        </span>
                    </td>
                    <td>
                        @if (item.AvailableCount <= 0)
                        {
                            <span class="badge bg-danger-subtle">Out of Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-success-subtle">@item.AvailableCount Available</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            }
            @if (!FilteredProducts.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted" style="padding: 3rem">No products configured yet.</td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    @* Mobile card list *@
    <div class="card-view">
        @if (!FilteredProducts.Any())
        {
            <p class="text-center text-muted" style="padding: 2rem 0">No products configured yet.</p>
        }
            @foreach (var item in FilteredProducts.Skip((_page - 1) * PageSize).Take(PageSize))
        {
            <div class="stock-card">
                <div class="stock-card-header">
                    <div class="d-flex align-items-center gap-2" style="flex: 1; min-width: 0; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" style="width: 36px; height: 36px; border-radius: 6px; object-fit: cover; flex-shrink: 0;" />
                        }
                        else
                        {
                            <div style="width: 36px; height: 36px; border-radius: 6px; background: var(--bg-surface); display: flex; align-items: center; justify-content: center; border: 1px solid var(--border); flex-shrink: 0;">
                                <i class="fa-solid fa-image text-muted" style="font-size: 0.75rem;"></i>
                            </div>
                        }
                        <span class="stock-card-name">@item.Name</span>
                    </div>
                    @if (item.AvailableCount <= 0)
                    {
                        <span class="badge bg-danger-subtle">Out of Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle">@item.AvailableCount avail.</span>
                    }
                </div>
                <div class="stock-card-body">
                    <div class="stock-card-row">
                        <span class="stock-card-label">Price</span>
                        <span class="text-success">₱@item.SellingPrice.ToString("0.00")</span>
                    </div>
                    <div class="stock-card-row">
                        <span class="stock-card-label">Cost</span>
                        <span class="text-danger">₱@item.TotalCost.ToString("0.00")</span>
                    </div>
                    <div class="stock-card-row">
                        <span class="stock-card-label">Profit</span>
                        <span class="@(item.ProfitMargin > 0 ? "text-success" : "text-danger")">
                            ₱@item.ProfitMargin.ToString("0.00") (@((item.ProfitMarginPercentage * 100).ToString("0.0"))%)
                        </span>
                    </div>
                    @if (item.RequiredIngredients.Any(ri => ri.Ingredient != null))
                    {
                        <div class="stock-card-row" style="align-items: flex-start;">
                            <span class="stock-card-label" style="flex-shrink: 0;">Ingredients</span>
                            <span class="text-muted" style="font-size: 0.78rem; text-align: right;">
                                @string.Join(", ", item.RequiredIngredients.Where(ri => ri.Ingredient != null).Select(ri => $"{ri.QuantityRequired}{ri.Ingredient!.Unit} {ri.Ingredient!.Name}"))
                            </span>
                        </div>
                    }
                </div>
                <div class="stock-card-actions">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => Edit(item)"><i class="fa-solid fa-pen"></i> Edit</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(item)"><i class="fa-solid fa-trash"></i> Delete</button>
                </div>
            </div>
        }
    </div>

    <PaginationBar Page="_page" PageSize="PageSize" TotalItems="FilteredProducts.Count()" OnPageChange="SetPage" />
</div>

}

<BSModal IsOpen="showModal" IsCentered="true" Size="Size.ExtraLarge">
    <Header>
        <h5 class="modal-title">@(isEditing ? "Edit Product" : "New Product")</h5>
        <button type="button" class="btn-close" @onclick="CloseModal"></button>
    </Header>
    <Content>
                <div class="row">
                    <!-- Basic Info -->
                    <div class="col-12 col-md-6">
                        <h4>Product Details</h4>
                        <div class="mb-3">
                            <label class="form-label">Product Name</label>
                            <input type="text" class="form-control" @bind="currentProduct.Name" placeholder="e.g. Hamburger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <input type="text" class="form-control" @bind="currentProduct.Category" placeholder="e.g. Food, Beverage, Retail" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Product Image</label>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(currentProduct.ImageUrl))
                                {
                                    <img src="@currentProduct.ImageUrl" style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover;" />
                                }
                                <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" />
                            </div>
                            @if (pendingImageFile != null && !isUploading)
                            {
                                <button class="btn btn-sm btn-primary mt-2" @onclick="UploadImage">
                                    <i class="fa-solid fa-upload"></i> Upload Image
                                </button>
                            }
                            @if (isUploading)
                            {
                                <p class="text-muted text-sm mt-1"><i class="fa-solid fa-spinner fa-spin"></i> Uploading...</p>
                            }
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label">Selling Price (₱)</label>
                                <input type="number" class="form-control" step="0.01" @bind="currentProduct.SellingPrice" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Tax Rate (Decimal)</label>
                                <input type="number" class="form-control" step="0.01" @bind="currentProduct.TaxRate" placeholder="0.05 for 5%" />
                            </div>
                        </div>

                        <div class="glass-card mb-4">
                            <h5>Summary</h5>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Cost</span>
                                <span class="text-danger">₱@currentProduct.TotalCost.ToString("0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Selling Price</span>
                                <span class="text-success">₱@currentProduct.SellingPrice.ToString("0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between" style="border-top: 1px solid var(--border); padding-top: 0.5rem">
                                <strong>Profit Margin</strong>
                                <strong class="text-success">₱@currentProduct.ProfitMargin.ToString("0.00")</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Ingredients -->
                    <div class="col-12 col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4>Required Ingredients</h4>
                        </div>
                        
                        <!-- Add ingredient row -->
                        <div class="d-flex gap-2 mb-4">
                            <select @bind="selectedIngredientId" class="form-select">
                                <option value="">-- Select Ingredient --</option>
                                @foreach(var ing in Inventory.ActiveIngredients.Where(i => i.Type == "Ingredient"))
                                {
                                    <option value="@ing.Guid">@ing.Name (@ing.Stock @ing.Unit)</option>
                                }
                            </select>
                            <input type="number" class="form-control" step="0.1" @bind="newQuantity" placeholder="Qty" style="width: 80px" />
                            <button class="btn btn-outline-secondary" @onclick="AddRequirement"><i class="fa-solid fa-plus"></i></button>
                        </div>

                        <div style="max-height: 250px; overflow-y: auto;">
                            @foreach(var req in currentProduct.RequiredIngredients)
                            {
                                <div class="glass-card d-flex justify-content-between align-items-center mb-2" style="padding: 0.5rem 1rem">
                                    <div>
                                        <strong>@req.Ingredient?.Name</strong>
                                        <div class="text-muted" style="font-size:0.8rem">
                                            @req.QuantityRequired @req.Ingredient?.Unit  
                                            <span class="text-danger">(₱@((req.QuantityRequired * req.Ingredient?.CostPerUnit ?? 0).ToString("0.00")))</span>
                                        </div>
                                    </div>
                                    <button class="btn-close" style="font-size: 1rem" @onclick="() => RemoveRequirement(req)"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            }
                            @if(currentProduct.RequiredIngredients.Count == 0)
                            {
                                <p class="text-muted text-center" style="font-size: 0.9rem">No ingredients added yet.</p>
                            }
                        </div>
                    </div>
                </div>
    </Content>
    <Footer>
                <button class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save">Save Product</button>
    </Footer>
</BSModal>

<InventoryPlus.Components.ConfirmDialog
    IsVisible="showDeleteConfirm"
    Title="Delete Product"
    Message="@($"Are you sure you want to delete \"{deleteTarget?.Name}\"? This cannot be undone.")"
    Icon="fa-solid fa-trash"
    ConfirmButtonClass="btn-danger"
    OnConfirm="ExecuteDelete"
    OnCancel="() => showDeleteConfirm = false" />

