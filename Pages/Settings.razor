@page "/settings"

<PageTitle>Settings | @AppSettings.CompanyName</PageTitle>

<div class="section-gap fade-in">

<div class="page-header">
    <div>
        <h1>Settings</h1>
        <p>Manage your account and preferences.</p>
    </div>
</div>

<div class="settings-grid">
    @* ── Sidebar Nav ── *@
    <div>
        <div class="settings-nav">
            <div class="settings-nav-item @(settingsTab == "general" ? "active" : "")" @onclick='() => settingsTab = "general"'>
                <i class="fa-solid fa-sliders"></i> General
            </div>
            <div class="settings-nav-item @(settingsTab == "appearance" ? "active" : "")" @onclick='() => settingsTab = "appearance"'>
                <i class="fa-solid fa-palette"></i> Appearance
            </div>
            <div class="settings-nav-item @(settingsTab == "security" ? "active" : "")" @onclick='() => settingsTab = "security"'>
                <i class="fa-solid fa-shield-halved"></i> Security
            </div>
            <div class="settings-nav-item @(settingsTab == "widgets" ? "active" : "")" @onclick='() => settingsTab = "widgets"'>
                <i class="fa-solid fa-table-cells"></i> Widgets
            </div>
            <div class="settings-nav-item @(settingsTab == "account" ? "active" : "")" @onclick='() => settingsTab = "account"'>
                <i class="fa-solid fa-user"></i> Account
            </div>
        </div>
    </div>

    @* ── Content Area ── *@
    <div>
        @* ── GENERAL ── *@
        @if (settingsTab == "general")
        {
            <div class="card card-p">
                <div class="card-title">General</div>
                <div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Company Name</div>
                            <div class="settings-row-desc">Shown on receipts and dashboard</div>
                        </div>
                        <input class="form-control" @bind="newCompanyName" placeholder="e.g. My Cafe" style="max-width: 200px;" />
                    </div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Show Inventory Tab</div>
                            <div class="settings-row-desc">Enable stock management</div>
                        </div>
                        <div class="toggle @(showInventoryTab ? "on" : "")" @onclick="() => showInventoryTab = !showInventoryTab">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Show OPEX Tab</div>
                            <div class="settings-row-desc">Enable expenses tracking</div>
                        </div>
                        <div class="toggle @(showOpexTab ? "on" : "")" @onclick="() => showOpexTab = !showOpexTab">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Show Decimals</div>
                            <div class="settings-row-desc">Display centavo values</div>
                        </div>
                        <div class="toggle @(AppSettings.ShowDecimals ? "on" : "")" @onclick="() => AppSettings.ShowDecimals = !AppSettings.ShowDecimals">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row" style="border-bottom: none;">
                        <div>
                            <div class="settings-row-label">Welcome Wizard</div>
                            <div class="settings-row-desc">Show setup wizard for new accounts</div>
                        </div>
                        <div class="toggle @(!AppSettings.OnboardingCompleted ? "on" : "")" @onclick="ToggleOnboarding">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                </div>
                <button class="btn btn-primary btn-sm" style="margin-top: 14px;" @onclick="SaveNavPreferences"><i class="fa-solid fa-save"></i> Save</button>
            </div>
        }

        @* ── APPEARANCE ── *@
        @if (settingsTab == "appearance")
        {
            <div class="card card-p">
                <div class="card-title">Appearance</div>
                <div class="settings-row">
                    <div>
                        <div class="settings-row-label">Branding Name</div>
                        <div class="settings-row-desc">Shown in topbar and receipts</div>
                    </div>
                    <input class="form-control" @bind="newCompanyName" placeholder="e.g. My Cafe" style="max-width: 200px;" />
                </div>
                <div class="settings-row" style="flex-direction: column; align-items: flex-start; gap: 10px;">
                    <div>
                        <div class="settings-row-label">Color Scheme</div>
                        <div class="settings-row-desc">Choose your accent color</div>
                    </div>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        @foreach (var scheme in colorSchemes)
                        {
                            <div class="color-swatch @(selectedColorScheme == scheme.Key ? "active" : "")"
                                 style="background: @scheme.Value;"
                                 title="@(scheme.Key[0..1].ToUpper() + scheme.Key[1..])"
                                 @onclick="() => selectedColorScheme = scheme.Key"></div>
                        }
                    </div>
                </div>
                <div class="settings-row">
                    <div>
                        <div class="settings-row-label">Custom Logo</div>
                        <div class="settings-row-desc">Upload a logo for branding</div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        @if (!string.IsNullOrEmpty(newLogoUrl))
                        {
                            <img src="@newLogoUrl" style="width: 28px; height: 28px; border-radius: 6px; object-fit: cover; border: 1px solid var(--border);" />
                            <button class="btn btn-ghost btn-sm" @onclick="() => newLogoUrl = null"><i class="fa-solid fa-trash"></i></button>
                        }
                        <InputFile OnChange="HandleLogoUpload" class="form-control" accept="image/*" style="max-width: 160px;" />
                        @if (pendingLogoFile != null && !isUploading)
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="UploadLogo"><i class="fa-solid fa-upload"></i> Upload</button>
                        }
                        @if (isUploading)
                        {
                            <i class="fa-solid fa-spinner fa-spin" style="color: var(--fg3);"></i>
                        }
                    </div>
                </div>
                <div class="settings-row" style="border-bottom: none;">
                    <div>
                        <div class="settings-row-label">Use Logo for Branding</div>
                        <div class="settings-row-desc">Show only logo in sidebar</div>
                    </div>
                    <div class="toggle @(useLogo ? "on" : "")" @onclick="() => useLogo = !useLogo">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <button class="btn btn-primary btn-sm" style="margin-top: 14px;" @onclick="SaveSettings"><i class="fa-solid fa-save"></i> Save Appearance</button>
                @if (showSuccess) { <span style="font-size: 11px; color: var(--green); margin-left: 10px;"><i class="fa-solid fa-check"></i> Saved!</span> }
            </div>
        }

        @* ── SECURITY ── *@
        @if (settingsTab == "security")
        {
            <div class="card card-p">
                <div class="card-title">Security</div>
                <div class="settings-row">
                    <div>
                        <div class="settings-row-label">PIN Protection <span class="badge badge-lime" style="font-size: 8px; vertical-align: middle;">Pro</span></div>
                        <div class="settings-row-desc">Protect sensitive actions with a 4-digit PIN</div>
                    </div>
                    @if (AppSettings.IsPro)
                    {
                        <div class="toggle @(AppSettings.HasPin ? "on" : "")" style="pointer-events: none;">
                            <div class="toggle-knob"></div>
                        </div>
                    }
                    else
                    {
                        <span class="badge badge-gray" style="font-size: 9px;"><i class="fa-solid fa-lock"></i> Pro</span>
                    }
                </div>
                @if (AppSettings.IsPro)
                {
                    @if (AppSettings.HasPin)
                    {
                        <div style="padding: 14px 0;">
                            <div class="settings-row-desc" style="margin-bottom: 8px;">Change or remove your PIN</div>
                            <div style="display: flex; flex-direction: column; gap: 6px; max-width: 200px;">
                                <input type="password" class="form-control" maxlength="4" inputmode="numeric" @bind="currentPin" placeholder="Current PIN" />
                                <input type="password" class="form-control" maxlength="4" inputmode="numeric" @bind="newPin" placeholder="New PIN" />
                                <input type="password" class="form-control" maxlength="4" inputmode="numeric" @bind="confirmPin" placeholder="Confirm PIN" />
                            </div>
                            @if (!string.IsNullOrEmpty(pinError)) { <div style="font-size: 11px; color: var(--red); margin-top: 6px;">@pinError</div> }
                            @if (showPinSuccess) { <div style="font-size: 11px; color: var(--green); margin-top: 6px;">PIN saved!</div> }
                            <div style="display: flex; gap: 6px; margin-top: 10px;">
                                <button class="btn btn-ghost btn-sm" @onclick="SavePin"><i class="fa-solid fa-lock"></i> Change PIN</button>
                                <button class="btn btn-danger btn-sm" @onclick="RemovePin"><i class="fa-solid fa-lock-open"></i> Remove</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="padding: 14px 0;">
                            <div class="settings-row-desc" style="margin-bottom: 8px;">Create a 4-digit PIN</div>
                            <div style="display: flex; flex-direction: column; gap: 6px; max-width: 200px;">
                                <input type="password" class="form-control" maxlength="4" inputmode="numeric" @bind="newPin" placeholder="New PIN (4 digits)" />
                                <input type="password" class="form-control" maxlength="4" inputmode="numeric" @bind="confirmPin" placeholder="Confirm PIN" />
                            </div>
                            @if (!string.IsNullOrEmpty(pinError)) { <div style="font-size: 11px; color: var(--red); margin-top: 6px;">@pinError</div> }
                            @if (showPinSuccess) { <div style="font-size: 11px; color: var(--green); margin-top: 6px;">PIN saved!</div> }
                            <button class="btn btn-ghost btn-sm" style="margin-top: 10px;" @onclick="SavePin"><i class="fa-solid fa-lock"></i> Create PIN</button>
                        </div>
                    }

                    @if (AppSettings.HasPin)
                    {
                        <div style="padding: 14px 0; border-top: 1px solid var(--border);">
                            <div class="settings-row-label" style="margin-bottom: 8px;">Require PIN for</div>
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                @foreach (var scope in pinScopeOptions)
                                {
                                    var isChecked = AppSettings.PinScopes.HasFlag(scope.Value);
                                    <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--fg2); cursor: pointer;">
                                        <input type="checkbox" checked="@isChecked" @onchange="@(e => TogglePinScope(scope.Value, (bool)e.Value!))" />
                                        <i class="@scope.Icon" style="width: 16px; text-align: center; font-size: 12px; color: var(--fg3);"></i>
                                        @scope.Label
                                    </label>
                                }
                            </div>
                        </div>
                    }
                }

                <div class="settings-row">
                    <div>
                        <div class="settings-row-label">POS Mode <span class="badge badge-lime" style="font-size: 8px; vertical-align: middle;">Pro</span></div>
                        <div class="settings-row-desc">Lock into Point of Sale mode</div>
                    </div>
                    @if (AppSettings.IsPro)
                    {
                        <button class="btn @(AppSettings.IsPosMode ? "btn-danger" : "btn-ghost") btn-sm" @onclick="TogglePosMode">
                            <i class="fa-solid @(AppSettings.IsPosMode ? "fa-lock-open" : "fa-lock")"></i>
                            @(AppSettings.IsPosMode ? "Exit" : "Enter")
                        </button>
                    }
                    else
                    {
                        <span class="badge badge-gray" style="font-size: 9px;"><i class="fa-solid fa-lock"></i> Pro</span>
                    }
                </div>

                <div class="settings-row" style="border-bottom: none;">
                    <div class="settings-row-label">Change Password</div>
                    <button class="btn btn-ghost btn-sm" @onclick='() => settingsTab = "password"'><i class="fa-solid fa-key"></i> Change</button>
                </div>
            </div>
        }

        @* ── PASSWORD (sub-tab) ── *@
        @if (settingsTab == "password")
        {
            <div class="card card-p">
                <div class="card-title">Change Password</div>
                <div style="display: flex; flex-direction: column; gap: 8px; max-width: 280px;">
                    <input type="password" class="form-control" @bind="currentPassword" placeholder="Current password" />
                    <input type="password" class="form-control" @bind="newPassword" placeholder="New password (min 6 chars)" />
                    <input type="password" class="form-control" @bind="confirmPassword" placeholder="Confirm password" />
                </div>
                @if (!string.IsNullOrEmpty(passErrorMessage)) { <div style="font-size: 11px; color: var(--red); margin-top: 6px;">@passErrorMessage</div> }
                @if (showPassSuccess) { <div style="font-size: 11px; color: var(--green); margin-top: 6px;">Password updated!</div> }
                <div style="display: flex; gap: 6px; margin-top: 12px;">
                    <button class="btn btn-ghost btn-sm" @onclick='() => settingsTab = "security"'><i class="fa-solid fa-arrow-left"></i> Back</button>
                    <button class="btn btn-primary btn-sm" @onclick="HandleChangePassword" disabled="@isChangingPass">
                        @if (isChangingPass) { <i class="fa-solid fa-spinner fa-spin"></i> } else { <i class="fa-solid fa-lock"></i> } Update
                    </button>
                </div>
            </div>
        }

        @* ── WIDGETS ── *@
        @if (settingsTab == "widgets")
        {
            <div class="card card-p">
                <div class="card-title">Dashboard Widgets</div>
                <div class="settings-row">
                    <div class="settings-row-label">Today's Snapshot</div>
                    <div class="toggle @(AppSettings.ShowTodaySnapshot ? "on" : "")" @onclick="() => AppSettings.ShowTodaySnapshot = !AppSettings.ShowTodaySnapshot">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Revenue Chart</div>
                    <div class="toggle @(AppSettings.ShowRevenueChart ? "on" : "")" @onclick="() => AppSettings.ShowRevenueChart = !AppSettings.ShowRevenueChart">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Top Products</div>
                    <div class="toggle @(AppSettings.ShowTopProducts ? "on" : "")" @onclick="() => AppSettings.ShowTopProducts = !AppSettings.ShowTopProducts">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Payment Breakdown</div>
                    <div class="toggle @(AppSettings.ShowPaymentBreakdown ? "on" : "")" @onclick="() => AppSettings.ShowPaymentBreakdown = !AppSettings.ShowPaymentBreakdown">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Profit Trend</div>
                    <div class="toggle @(AppSettings.ShowProfitTrend ? "on" : "")" @onclick="() => AppSettings.ShowProfitTrend = !AppSettings.ShowProfitTrend">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Low Stock Alerts</div>
                    <div class="toggle @(AppSettings.ShowLowStock ? "on" : "")" @onclick="() => AppSettings.ShowLowStock = !AppSettings.ShowLowStock">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row">
                    <div class="settings-row-label">Recent Sales</div>
                    <div class="toggle @(AppSettings.ShowRecentSales ? "on" : "")" @onclick="() => AppSettings.ShowRecentSales = !AppSettings.ShowRecentSales">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
                <div class="settings-row" style="border-bottom: none;">
                    <div class="settings-row-label">Quick Actions</div>
                    <div class="toggle @(AppSettings.ShowQuickActions ? "on" : "")" @onclick="() => AppSettings.ShowQuickActions = !AppSettings.ShowQuickActions">
                        <div class="toggle-knob"></div>
                    </div>
                </div>

                <div style="border-top: 1px solid var(--border); margin-top: 12px; padding-top: 12px;">
                    <div class="card-title">Report Sections</div>
                    <div class="settings-row">
                        <div class="settings-row-label">Sales Summary</div>
                        <div class="toggle @(AppSettings.ShowReportSalesSummary ? "on" : "")" @onclick="() => AppSettings.ShowReportSalesSummary = !AppSettings.ShowReportSalesSummary">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div class="settings-row-label">Top Products</div>
                        <div class="toggle @(AppSettings.ShowReportTopProducts ? "on" : "")" @onclick="() => AppSettings.ShowReportTopProducts = !AppSettings.ShowReportTopProducts">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div class="settings-row-label">Payment Methods</div>
                        <div class="toggle @(AppSettings.ShowReportPaymentMethods ? "on" : "")" @onclick="() => AppSettings.ShowReportPaymentMethods = !AppSettings.ShowReportPaymentMethods">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div class="settings-row-label">Profit & Loss</div>
                        <div class="toggle @(AppSettings.ShowReportProfitLoss ? "on" : "")" @onclick="() => AppSettings.ShowReportProfitLoss = !AppSettings.ShowReportProfitLoss">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div class="settings-row-label">Inventory Valuation</div>
                        <div class="toggle @(AppSettings.ShowReportInventoryValuation ? "on" : "")" @onclick="() => AppSettings.ShowReportInventoryValuation = !AppSettings.ShowReportInventoryValuation">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                    <div class="settings-row" style="border-bottom: none;">
                        <div class="settings-row-label">Stock Movement</div>
                        <div class="toggle @(AppSettings.ShowReportStockMovement ? "on" : "")" @onclick="() => AppSettings.ShowReportStockMovement = !AppSettings.ShowReportStockMovement">
                            <div class="toggle-knob"></div>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary btn-sm" style="margin-top: 14px;" @onclick="SavePreferences"><i class="fa-solid fa-save"></i> Save Preferences</button>
            </div>
        }

        @* ── ACCOUNT ── *@
        @if (settingsTab == "account")
        {
            <div class="card card-p">
                <div class="card-title">Account</div>
                @if (currentUser != null)
                {
                    <div style="display: flex; align-items: center; gap: 11px; padding: 10px 0; border-bottom: 1px solid var(--border);">
                        <div style="width: 46px; height: 46px; border-radius: 50%; background: var(--lime); display: flex; align-items: center; justify-content: center; color: #0a0a0a; font-size: 15px; font-weight: 700; font-family: 'Space Mono', monospace;">
                            @(currentUser.Email?.Length >= 2 ? currentUser.Email[..2].ToUpper() : "U")
                        </div>
                        <div>
                            <div style="font-size: 13px; font-weight: 700; color: var(--fg);">@currentUser.Email</div>
                            <div style="font-size: 11px; color: var(--fg3);">@currentUser.Id</div>
                            <div style="display: flex; gap: 5px; margin-top: 4px;">
                                @if (AppSettings.IsPro)
                                {
                                    <span class="badge badge-lime">Pro</span>
                                }
                                else
                                {
                                    <span class="badge badge-gray">Free</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Created</div>
                            <div class="settings-row-desc">@currentUser.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-label">Last Sign In</div>
                            <div class="settings-row-desc">@(currentUser.LastSignInAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "N/A")</div>
                        </div>
                    </div>
                    @if (AppSettings.IsPro && AppSettings.SubscriptionExpiry.HasValue)
                    {
                        <div class="settings-row">
                            <div>
                                <div class="settings-row-label">Pro Expires</div>
                                <div class="settings-row-desc">@AppSettings.SubscriptionExpiry.Value.ToLocalTime().ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="display: flex; flex-direction: column; align-items: center; padding: 20px; color: var(--fg3);">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 20px; margin-bottom: 8px;"></i>
                        <span style="font-size: 11px;">Loading...</span>
                    </div>
                }
                @if (showInstallSection && !isAppStandalone)
                {
                    <div class="settings-row" style="border-bottom: none;">
                        <div>
                            <div class="settings-row-label">Install as App</div>
                            <div class="settings-row-desc">Add to home screen for faster access</div>
                        </div>
                        @if (canInstallNative)
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="InstallApp"><i class="fa-solid fa-download"></i> Install PWA</button>
                        }
                        else if (isIosDevice)
                        {
                            <span style="font-size: 10px; color: var(--fg3);">Tap Share → Add to Home Screen</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

</div>
