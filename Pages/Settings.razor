@page "/settings"

<PageTitle>Settings | @AppSettings.CompanyName</PageTitle>


<div class="page-header">
    <div>
        <h1>System Settings</h1>
        <p class="text-muted">Manage your application branding and global configurations.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
    <div class="glass-panel">
        <div class="mb-4">
            <h2>Brand Settings</h2>
            <p class="text-muted text-sm">Update how your app brand appears to all users.</p>
        </div>

        <div class="mb-3">
            <label for="companyName" class="form-label">Company Name</label>
            <input id="companyName" class="form-control" @bind="newCompanyName" placeholder="e.g. My Cafe" />
        </div>

        <div class="mb-3">
            <label class="form-label">Brand Logo</label>
            <div class="d-flex align-items-center gap-4 mb-2">
                @if (!string.IsNullOrEmpty(newLogoUrl))
                {
                    <img src="@newLogoUrl" style="width: 48px; height: 48px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border)" />
                }
                else
                {
                    <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--bg-surface); display: flex; align-items: center; justify-content: center; border: 1px solid var(--border)">
                        <i class="fa-solid fa-cube text-muted"></i>
                    </div>
                }
                <div class="flex-grow-1">
                    <InputFile OnChange="HandleLogoUpload" class="form-control" accept="image/*" />
                    @if (pendingLogoFile != null && !isUploading)
                    {
                        <button class="btn btn-sm btn-primary mt-2" @onclick="UploadLogo">
                            <i class="fa-solid fa-upload"></i> Upload Logo
                        </button>
                    }
                    @if (isUploading)
                    {
                        <p class="text-sm text-muted mt-1"><i class="fa-solid fa-spinner fa-spin"></i> Uploading...</p>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(newLogoUrl))
            {
                <button class="btn btn-sm btn-outline-danger mt-1" style="padding: 0.25rem 0.75rem" @onclick="() => newLogoUrl = null">
                    <i class="fa-solid fa-trash"></i> Remove Logo
                </button>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Brand Display Mode</label>
            <div class="d-flex gap-2">
                <button class="btn btn-sm @(!useLogo ? "btn-primary" : "btn-outline-secondary") w-100" @onclick="() => useLogo = false">
                    <i class="fa-solid fa-font"></i> Show Name
                </button>
                <button class="btn btn-sm @(useLogo ? "btn-primary" : "btn-outline-secondary") w-100" @onclick="() => useLogo = true">
                    <i class="fa-solid fa-image"></i> Show Logo
                </button>
            </div>
        </div>

        <button class="btn btn-primary mt-2" @onclick="SaveSettings">
            <i class="fa-solid fa-save"></i> Save Changes
        </button>

        @if (showSuccess)
        {
            <div class="alert alert-success mt-2">
                Settings saved successfully!
            </div>
        }
    </div>
    </div>

    <div class="col-12 col-lg-6">
    <div class="glass-panel">
        <div class="mb-4">
            <h2>Account Information</h2>
            <p class="text-muted text-sm">Your dynamic account details from the system.</p>
        </div>
        
        @if (currentUser != null)
        {
            <div class="alert alert-primary mb-4">
                <i class="fa-solid fa-circle-user"></i> Signed in as <strong>@currentUser.Email</strong>
            </div>
            
            <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--border)">
                    <span class="text-muted">User ID</span>
                    <span style="font-size: 0.75rem; font-family: monospace;">@currentUser.Id</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--border)">
                    <span class="text-muted">Created At</span>
                    <span>@currentUser.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--border)">
                    <span class="text-muted">Last Sign In</span>
                    <span>@(currentUser.LastSignInAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "N/A")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--border)">
                    <span class="text-muted">Role</span>
                    <span class="badge bg-primary-subtle">Administrator</span>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-items-center justify-content-center p-5 text-muted">
                <i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i>
                <p>Loading account details...</p>
            </div>
        }

        <div class="mt-5 pt-4" style="border-top: 1px solid var(--border)">
            <h2 class="mb-4">Security</h2>
            <p class="text-muted text-sm mb-4">Update your account password. Must be at least 6 characters.</p>

            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" class="form-control" @bind="newPassword" placeholder="Minimum 6 characters" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input type="password" class="form-control" @bind="confirmPassword" placeholder="Repeat new password" />
            </div>

            @if (!string.IsNullOrEmpty(passErrorMessage))
            {
                <div class="alert alert-danger mt-2">@passErrorMessage</div>
            }
            @if (showPassSuccess)
            {
                <div class="alert alert-success mt-2">Password updated successfully!</div>
            }

            <button class="btn btn-outline-secondary mt-2 w-100" @onclick="HandleChangePassword" disabled="@isChangingPass">
                @if (isChangingPass)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i> <span>Updating...</span>
                }
                else
                {
                    <i class="fa-solid fa-lock"></i> <span>Update Password</span>
                }
            </button>
        </div>
    </div>
    </div>
</div>

@* ── Dashboard & Report Preferences ── *@
<div class="row g-4 mt-2">
    <div class="col-12 col-lg-6">
    <div class="glass-panel">
        <h2 class="mb-2">Dashboard Widgets</h2>
        <p class="text-muted text-sm mb-4">Choose which widgets appear on your dashboard.</p>

        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowTodaySnapshot" /><span>Today's Snapshot</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowRevenueChart" /><span>Revenue Chart</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowTopProducts" /><span>Top Products</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowPaymentBreakdown" /><span>Payment Breakdown</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowProfitTrend" /><span>Profit Trend</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowLowStock" /><span>Low Stock Alerts</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowRecentSales" /><span>Recent Sales</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowQuickActions" /><span>Quick Actions</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowOnboardingOnLogin" /><span>Onboarding Wizard on Login</span></label>

        <button class="btn btn-primary mt-4 w-100" @onclick="SavePreferences">
            <i class="fa-solid fa-save"></i> Save Preferences
        </button>
    </div>
    </div>

    <div class="col-12 col-lg-6">
    <div class="glass-panel">
        <h2 class="mb-2">Report Sections</h2>
        <p class="text-muted text-sm mb-4">Choose which report sections are visible.</p>

        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportSalesSummary" /><span>Sales Summary</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportTopProducts" /><span>Top Products</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportPaymentMethods" /><span>Payment Methods</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportProfitLoss" /><span>Profit & Loss</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportInventoryValuation" /><span>Inventory Valuation</span></label>
        <label class="toggle-row"><input type="checkbox" @bind="AppSettings.ShowReportStockMovement" /><span>Stock Movement</span></label>

        <button class="btn btn-primary mt-4 w-100" @onclick="SavePreferences">
            <i class="fa-solid fa-save"></i> Save Preferences
        </button>
    </div>
    </div>
</div>